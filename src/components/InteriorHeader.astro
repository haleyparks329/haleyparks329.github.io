---
type Props = {
  eyebrow: string;
  title: string;
  text: string;
  meta?: string[];
  objectLabel?: string;
  objectText?: string;
  accent?: "raspberry" | "olive" | "sky" | "lavender" | "ochre" | "plant";
};

const {
  eyebrow,
  title,
  text,
  meta = [],
  objectLabel,
  objectText,
  accent = "raspberry",
} = Astro.props;
---

<header class={`interior-header interior-${accent}`}>
  <div class="interior-header-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{text}</p>
    {
      meta.length > 0 && (
        <ul class="interior-meta-row" aria-label={`${title} metadata`}>
          {meta.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
  </div>
  {
    objectLabel && objectText && (
      <aside class="interior-header-object">
        <p class="eyebrow">{objectLabel}</p>
        <p>{objectText}</p>
      </aside>
    )
  }
</header>

<style>
  .interior-header {
    --interior-accent: var(--rust);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.34fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
    padding-block: clamp(2.4rem, 5vw, 4.5rem);
  }

  .interior-olive {
    --interior-accent: var(--olive);
  }

  .interior-sky {
    --interior-accent: var(--blue);
  }

  .interior-lavender {
    --interior-accent: var(--lavender);
  }

  .interior-ochre {
    --interior-accent: var(--khaki);
  }

  .interior-plant {
    --interior-accent: var(--houseplant);
  }

  .interior-header-copy {
    max-width: var(--reading-width);
    min-width: 0;
  }

  h1 {
    max-width: 11ch;
    font-family: var(--font-serif);
    font-size: var(--font-size-page-title);
    line-height: var(--line-height-display);
  }

  .interior-header-copy > p:not(.eyebrow) {
    max-width: var(--reading-width);
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 1.5vw, 1.18rem);
    line-height: 1.55;
  }

  .interior-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: var(--space-5) 0 0;
    padding: 0;
    list-style: none;
  }

  .interior-meta-row li {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.26rem 0.58rem;
    background: var(--color-surface-raised);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
  }

  .interior-header-object {
    position: relative;
    min-width: 0;
    border: var(--border-width) solid var(--color-border);
    border-left: 0.42rem solid var(--interior-accent);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .interior-header-object::before {
    position: absolute;
    top: -0.72rem;
    left: 18%;
    width: 4rem;
    height: 1rem;
    background: color-mix(in srgb, var(--khaki) 42%, transparent);
    content: "";
    transform: rotate(-3deg);
  }

  .interior-header-object p:not(.eyebrow) {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1.8vw, 1.55rem);
    font-weight: 700;
    line-height: 1.22;
  }

  @media (max-width: 820px) {
    .interior-header {
      grid-template-columns: 1fr;
      padding-block: 2.5rem;
    }

    h1 {
      max-width: 100%;
    }
  }
</style>
