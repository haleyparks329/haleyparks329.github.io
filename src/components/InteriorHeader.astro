---
type Props = {
  eyebrow: string;
  title: string;
  text: string;
  meta?: string[];
  objectLabel?: string;
  objectText?: string;
  accent?: "raspberry" | "olive" | "sky" | "lavender" | "ochre" | "plant";
};

const {
  eyebrow,
  title,
  text,
  meta = [],
  objectLabel,
  objectText,
  accent = "raspberry",
} = Astro.props;
---

<header class={`interior-header interior-${accent}`}>
  <div class="interior-header-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{text}</p>
    {
      meta.length > 0 && (
        <ul class="interior-meta-row" aria-label={`${title} metadata`}>
          {meta.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
  </div>
  {
    objectLabel && objectText && (
      <aside class="interior-header-object workspace-object tape-center">
        <p class="eyebrow">{objectLabel}</p>
        <p>{objectText}</p>
      </aside>
    )
  }
</header>

<style>
  .interior-header {
    --interior-accent: var(--rust);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(12rem, 0.22fr);
    gap: clamp(1rem, 2.4vw, 2.25rem);
    align-items: center;
    padding-block: clamp(1.2rem, 2vw, 1.9rem);
  }

  .interior-olive {
    --interior-accent: var(--olive);
  }

  .interior-sky {
    --interior-accent: var(--blue);
  }

  .interior-lavender {
    --interior-accent: var(--lavender);
  }

  .interior-ochre {
    --interior-accent: var(--khaki);
  }

  .interior-plant {
    --interior-accent: var(--houseplant);
  }

  .interior-header-copy {
    max-width: var(--reading-width);
    min-width: 0;
    border-left: 0.38rem solid var(--interior-accent);
    padding-left: clamp(0.9rem, 2vw, 1.25rem);
  }

  h1 {
    max-width: 18ch;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 2.65vw, 2.75rem);
    line-height: 1;
  }

  .interior-header-copy > p:not(.eyebrow) {
    max-width: var(--reading-width);
    margin-top: 0.65rem;
    color: var(--color-text-muted);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.48;
  }

  .interior-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: var(--space-4) 0 0;
    padding: 0;
    list-style: none;
  }

  .interior-meta-row li {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.26rem 0.58rem;
    background: var(--color-surface-raised);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
  }

  .interior-header-object {
    --object-accent: var(--interior-accent);
    --object-surface: color-mix(
      in srgb,
      var(--interior-accent) 12%,
      var(--paper)
    );
    --object-tilt: -0.7deg;
    max-width: 15rem;
    justify-self: end;
    border-left: 0.42rem solid var(--interior-accent);
    padding: 0.9rem 1rem;
  }

  .interior-header-object p:not(.eyebrow) {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.3vw, 1.25rem);
    font-weight: 700;
    line-height: 1.2;
  }

  @media (max-width: 820px) {
    .interior-header {
      grid-template-columns: 1fr;
      padding-block: 2rem;
    }

    h1 {
      max-width: 100%;
    }
  }
</style>
