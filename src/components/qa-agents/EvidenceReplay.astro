---
import ExternalLink from "@/components/ExternalLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

type DetailItem = {
  label: string;
  value: string | number | boolean;
  tone?: string;
  code?: boolean;
};

type Notebook = {
  heading: string;
  observation: string;
  interpretation: string;
  why: string;
  boundary?: string;
};

type StoryNote = {
  actor: string;
  emoji: string;
  heading: string;
  body: string;
  handoff: string;
  evidenceLabel?: string;
  boundary?: string;
};

type Panel = {
  kind: "diff" | "command" | "inspection" | "record" | "recommendation";
  statusLabel?: string;
  action?: string;
  diffLines?: string[];
  diffBadges?: string[];
  diffNote?: string;
  facts?: DetailItem[];
  headerTitle?: string;
  headerText?: string;
};

type InvestigationStep = {
  id: string;
  timelineLabel: string;
  panelTitle: string;
  windowTitle: string;
  icon: string;
  accent: string;
  notebook: Notebook;
  story: StoryNote;
  panel: Panel;
};

type LinkItem = {
  href: string;
  label: string;
  external?: boolean;
};

type TechnicalDetail = {
  summary: string;
  items?: DetailItem[];
  raw?: string;
};

type Props = {
  pageTitle: string;
  pageDescription: string;
  canonicalPath: string;
  eyebrow: string;
  titleLines: string[];
  lede: string;
  safetyNote: string;
  links: LinkItem[];
  caseSummary: DetailItem[];
  storyIntro: {
    eyebrow: string;
    heading: string;
    paragraphs: string[];
    explanation: string;
  };
  castTitle: string;
  cast: string[];
  sessionMeta: string[];
  gapNote: string;
  defaultStepIndex?: number;
  steps: InvestigationStep[];
  result: {
    eyebrow: string;
    heading: string;
    story: string[];
    items: { marker: string; text: string; warning?: boolean }[];
    boundary: string[];
  };
  completionLinks?: LinkItem[];
  recordedReplayNote: string;
  technicalDetails: TechnicalDetail[];
};

const {
  pageTitle,
  pageDescription,
  canonicalPath,
  eyebrow,
  titleLines,
  lede,
  safetyNote,
  links,
  caseSummary,
  storyIntro,
  castTitle,
  cast,
  sessionMeta,
  gapNote,
  defaultStepIndex = 0,
  steps,
  result,
  completionLinks = [],
  recordedReplayNote,
  technicalDetails,
} = Astro.props;

if (!steps.length) {
  throw new Error("EvidenceReplay requires at least one replay step");
}

function classifyDiffLine(line: string): string {
  if (line.startsWith("+") && !line.startsWith("+++"))
    return "diff-line is-added";
  if (line.startsWith("-") && !line.startsWith("---"))
    return "diff-line is-removed";
  if (
    line.startsWith("@@") ||
    line.startsWith("diff --git") ||
    line.startsWith("index ") ||
    line.startsWith("---") ||
    line.startsWith("+++")
  )
    return "diff-line is-meta";
  if (line.includes("branch-") || line.includes("uncovered"))
    return "diff-line is-branch-gap";
  return "diff-line";
}

const stepDetails = steps.map((step) => ({
  id: step.id,
  label: step.timelineLabel,
  story: step.story,
}));
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPath}
>
  <section class="page-section wide-case replay-page" data-replay-root>
    <div class="replay-hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>
        {
          titleLines.map((line, index) => (
            <>
              {line}
              {index < titleLines.length - 1 && <br />}
            </>
          ))
        }
      </h1>
      <p class="lede">{lede}</p>
      <p class="safety-note">{safetyNote}</p>
      <div class="button-row">
        {
          links.map((link) =>
            link.external ? (
              <ExternalLink href={link.href} label={link.label} />
            ) : (
              <a class="button secondary" href={link.href}>
                {link.label}
              </a>
            ),
          )
        }
      </div>
    </div>

    <dl class="case-summary" aria-label="Compact case summary">
      {
        caseSummary.map((item) => (
          <div>
            <>
              <dt>{item.label}</dt>
              <dd>{String(item.value)}</dd>
            </>
          </div>
        ))
      }
    </dl>

    <section class="story-intro" aria-labelledby="story-heading">
      <p class="eyebrow">{storyIntro.eyebrow}</p>
      <h2 id="story-heading">{storyIntro.heading}</h2>
      {storyIntro.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <p class="replay-explanation">{storyIntro.explanation}</p>
    </section>

    <aside class="cast-key" aria-label={castTitle}>
      <h2>{castTitle}</h2>
      <ul>{cast.map((item) => <li>{item}</li>)}</ul>
    </aside>

    <div class="workstation-shell" id="replay-workstation">
      <div class="workstation-titlebar">
        <span>QA Replay Workstation</span><span
          class="window-controls"
          aria-hidden="true"><span>_</span><span>□</span><span>×</span></span
        >
      </div>
      <nav class="workstation-menu" aria-label="Replay workstation menu">
        <span>File</span><span>View</span><a href="#technical-details"
          >Evidence</a
        ><a href="#recorded-replay-note">Help</a>
      </nav>
      <div class="session-strip" aria-label="Recorded session status">
        <span class="recorded-badge">● Recorded replay</span>{
          sessionMeta.map((item) => <span>{item}</span>)
        }<span data-session-step
          >Step {defaultStepIndex + 1} of {steps.length}</span
        >
      </div>

      <section class="timeline-panel" aria-label="Investigation timeline">
        <div class="investigation-timeline">
          {
            steps.map((step, index) => (
              <button
                type="button"
                class:list={[
                  "timeline-button",
                  "accent-" + step.accent,
                  index < defaultStepIndex && "is-completed",
                  index === defaultStepIndex && "is-active",
                  index > defaultStepIndex && "is-upcoming",
                ]}
                data-step-button={index}
                aria-pressed={index === defaultStepIndex ? "true" : "false"}
                aria-current={index === defaultStepIndex ? "step" : undefined}
              >
                <>
                  <span class="tool-icon" aria-hidden="true">
                    {step.icon}
                  </span>
                  <span class="timeline-copy">
                    <>
                      <span class="timeline-number">Step {index + 1}</span>
                      <span class="timeline-label">{step.timelineLabel}</span>
                      <span class="timeline-state" data-step-state={index}>
                        {index < defaultStepIndex
                          ? "Completed"
                          : index === defaultStepIndex
                            ? "Active"
                            : "Upcoming"}
                      </span>
                    </>
                  </span>
                </>
              </button>
            ))
          }
        </div>
      </section>

      <div class="personality-note" data-gap-note>{gapNote}</div>

      <section class="team-notes" aria-live="polite" aria-label="Team notes">
        <div class="team-note-actor">
          <span class="team-note-emoji" data-story-emoji aria-hidden="true"
            >{steps[defaultStepIndex].story.emoji}</span
          ><span class="team-note-name" data-story-actor
            >{steps[defaultStepIndex].story.actor}</span
          >{
            steps[defaultStepIndex].story.evidenceLabel ? (
              <span class="team-note-evidence" data-story-evidence>
                {steps[defaultStepIndex].story.evidenceLabel}
              </span>
            ) : (
              <span class="team-note-evidence" data-story-evidence hidden />
            )
          }
        </div>
        <div class="team-note-copy">
          <h2 data-story-heading>{steps[defaultStepIndex].story.heading}</h2><p
            data-story-body
          >
            {steps[defaultStepIndex].story.body}
          </p>{
            steps[defaultStepIndex].story.boundary ? (
              <p class="team-note-boundary" data-story-boundary>
                {steps[defaultStepIndex].story.boundary}
              </p>
            ) : (
              <p class="team-note-boundary" data-story-boundary hidden />
            )
          }
        </div>
        <div class="team-note-handoff" data-story-handoff>
          {steps[defaultStepIndex].story.handoff}
        </div>
      </section>

      <section class="workspace" aria-live="polite">
        {
          steps.map((step, index) => (
            <article
              class:list={[
                "workspace-step",
                "accent-" + step.accent,
                index === defaultStepIndex && "is-active",
              ]}
              data-step-panel={index}
              hidden={index !== defaultStepIndex}
            >
              <div class="retro-window evidence-panel">
                <div class="retro-titlebar">
                  <>
                    <span>{step.windowTitle}</span>
                    <span class="mini-window-controls" aria-hidden="true">
                      <>
                        <span>_</span>
                        <span>□</span>
                        <span>×</span>
                      </>
                    </span>
                  </>
                </div>
                <div class="window-toolbar">
                  <>
                    <span>Evidence under review</span>
                    <span>{step.panelTitle}</span>
                  </>
                </div>
                <div class="window-body">
                  {step.panel.kind === "diff" && (
                    <>
                      {step.panel.diffBadges && (
                        <div class="diff-badges" aria-label="Diff summary">
                          {step.panel.diffBadges.map((badge) => (
                            <span>{badge}</span>
                          ))}
                        </div>
                      )}
                      {step.panel.facts && (
                        <dl class="evidence-facts">
                          {step.panel.facts.map((item) => (
                            <div>
                              <dt>{item.label}</dt>
                              <dd>
                                {item.code ? (
                                  <code>{String(item.value)}</code>
                                ) : (
                                  String(item.value)
                                )}
                              </dd>
                            </div>
                          ))}
                        </dl>
                      )}
                      {step.panel.diffLines && (
                        <pre
                          class="diff-view"
                          aria-label={step.panel.headerTitle ?? "Diff excerpt"}
                        >
                          <code>
                            {step.panel.diffLines.map((line) => (
                              <span class={classifyDiffLine(line)}>
                                {line || " "}
                              </span>
                            ))}
                          </code>
                        </pre>
                      )}
                      {step.panel.diffNote && (
                        <p class="coverage-link-note">{step.panel.diffNote}</p>
                      )}
                    </>
                  )}
                  {step.panel.kind === "command" && (
                    <div class="command-result">
                      {step.panel.statusLabel && (
                        <span class="status-indicator">
                          {step.panel.statusLabel}
                        </span>
                      )}
                      <dl class="evidence-facts compact">
                        {step.panel.facts?.map((item) => (
                          <div>
                            <dt>{item.label}</dt>
                            <dd
                              class={
                                item.tone ? "tone-" + item.tone : undefined
                              }
                            >
                              {item.code ? (
                                <code>{String(item.value)}</code>
                              ) : (
                                String(item.value)
                              )}
                            </dd>
                          </div>
                        ))}
                      </dl>
                    </div>
                  )}
                  {step.panel.kind === "inspection" && (
                    <div class="coverage-report">
                      <div class="coverage-report-header">
                        <span class="coverage-warning" aria-hidden="true">
                          !
                        </span>
                        <div>
                          <h3>{step.panel.headerTitle}</h3>
                          <p>{step.panel.headerText}</p>
                        </div>
                      </div>
                      <dl class="inspection-list">
                        {step.panel.facts?.map((item) => (
                          <div>
                            <dt>{item.label}</dt>
                            <dd
                              class={
                                item.tone ? "tone-" + item.tone : undefined
                              }
                            >
                              {item.code ? (
                                <code>{String(item.value)}</code>
                              ) : (
                                String(item.value)
                              )}
                            </dd>
                          </div>
                        ))}
                      </dl>
                      {step.panel.diffNote && (
                        <p class="coverage-link-note">{step.panel.diffNote}</p>
                      )}
                    </div>
                  )}
                  {step.panel.kind === "record" && (
                    <dl class="record-list">
                      {step.panel.facts?.map((item) => (
                        <div>
                          <dt>{item.label}</dt>
                          <dd>
                            {item.code ? (
                              <code>{String(item.value)}</code>
                            ) : (
                              String(item.value)
                            )}
                          </dd>
                        </div>
                      ))}
                    </dl>
                  )}
                  {step.panel.kind === "recommendation" && (
                    <div class="recommendation-card">
                      {step.panel.statusLabel && (
                        <span class="status-indicator recommendation-only">
                          {step.panel.statusLabel}
                        </span>
                      )}
                      {step.panel.action && (
                        <p class="recommendation-action">{step.panel.action}</p>
                      )}
                      <dl class="evidence-facts">
                        {step.panel.facts?.map((item) => (
                          <div>
                            <dt>{item.label}</dt>
                            <dd>
                              {item.code ? (
                                <code>{String(item.value)}</code>
                              ) : (
                                String(item.value)
                              )}
                            </dd>
                          </div>
                        ))}
                      </dl>
                    </div>
                  )}
                </div>
              </div>
              <aside
                class="retro-window notebook-panel"
                aria-label="Case notes"
              >
                <div class="retro-titlebar">
                  <span>Case Notes</span>
                  <span class="read-only-label">read-only</span>
                </div>
                <div class="window-body notebook-paper">
                  <p class="panel-kicker">Case notes</p>
                  <h2>{step.notebook.heading}</h2>
                  <div class="notebook-entry">
                    <h3>What happened</h3>
                    <p>{step.notebook.observation}</p>
                  </div>
                  <div class="notebook-entry">
                    <h3>Why the evidence matters</h3>
                    <p>{step.notebook.interpretation}</p>
                  </div>
                  <div class="notebook-entry">
                    <h3>Why engineers care</h3>
                    <p>{step.notebook.why}</p>
                  </div>
                  {step.notebook.boundary && (
                    <p class="boundary-note">{step.notebook.boundary}</p>
                  )}
                </div>
              </aside>
            </article>
          ))
        }
      </section>

      <div class="playback-shell" aria-label="Replay navigation controls">
        <button type="button" class="retro-control" data-step-prev
          >◀ Rewind</button
        ><span class="replay-mode">Replay</span><button
          type="button"
          class="retro-control primary"
          data-step-next>Continue ▶</button
        >
      </div>
    </div>

    <dialog
      class="result-dialog"
      aria-labelledby="investigation-result"
      data-completion-dialog
    >
      <div class="retro-titlebar">
        <span>Investigation Complete</span><span
          class="mini-window-controls"
          aria-hidden="true"><span>_</span><span>□</span><span>×</span></span
        >
      </div><div class="result-body">
        <p class="eyebrow">{result.eyebrow}</p><h2 id="investigation-result">
          {result.heading}
        </h2><div class="result-story">
          {result.story.map((line) => <p>{line}</p>)}
        </div><ol class="result-list">
          {
            result.items.map((item) => (
              <li class:list={[item.warning && "warning"]}>
                <span>{item.marker}</span> {item.text}
              </li>
            ))
          }
        </ol><div class="result-boundary">
          {result.boundary.map((line) => <p>{line}</p>)}
        </div>{
          completionLinks.length > 0 && (
            <nav class="result-links" aria-label="Replay completion links">
              {completionLinks.map((link) =>
                link.external ? (
                  <ExternalLink href={link.href} label={link.label} />
                ) : (
                  <a href={link.href}>{link.label}</a>
                ),
              )}
            </nav>
          )
        }<button class="retro-ok" type="button" data-result-ok>OK</button>
      </div>
    </dialog>

    <p class="safety-note" id="recorded-replay-note">{recordedReplayNote}</p>

    <section
      class="technical-details"
      id="technical-details"
      aria-label="Technical details"
    >
      {
        technicalDetails.map((detail) => (
          <details>
            <summary>{detail.summary}</summary>
            {detail.items && (
              <dl>
                {detail.items.map((item) => (
                  <>
                    <dt>{item.label}</dt>
                    <dd>
                      {item.code ? (
                        <code>{String(item.value)}</code>
                      ) : (
                        String(item.value)
                      )}
                    </dd>
                  </>
                ))}
              </dl>
            )}
            {detail.raw && (
              <pre>
                <code>{detail.raw}</code>
              </pre>
            )}
          </details>
        ))
      }
    </section>
  </section>

  <script is:inline define:vars={{ stepDetails, defaultStepIndex }}>
    const root = document.querySelector("[data-replay-root]");
    const buttons = Array.from(document.querySelectorAll("[data-step-button]"));
    const panels = Array.from(document.querySelectorAll("[data-step-panel]"));
    const stateLabels = Array.from(
      document.querySelectorAll("[data-step-state]"),
    );
    const sessionStep = document.querySelector("[data-session-step]");
    const gapNote = document.querySelector("[data-gap-note]");
    const storyEmoji = document.querySelector("[data-story-emoji]");
    const storyActor = document.querySelector("[data-story-actor]");
    const storyEvidence = document.querySelector("[data-story-evidence]");
    const storyHeading = document.querySelector("[data-story-heading]");
    const storyBody = document.querySelector("[data-story-body]");
    const storyBoundary = document.querySelector("[data-story-boundary]");
    const storyHandoff = document.querySelector("[data-story-handoff]");
    const previous = document.querySelector("[data-step-prev]");
    const next = document.querySelector("[data-step-next]");
    const completionDialog = document.querySelector("[data-completion-dialog]");
    const resultOk = document.querySelector("[data-result-ok]");
    let activeIndex = defaultStepIndex;
    let shouldResetOnDialogClose = false;

    function stateFor(index) {
      if (index < activeIndex) return "completed";
      if (index === activeIndex) return "active";
      return "upcoming";
    }

    function setActiveStep(index) {
      activeIndex = Math.min(Math.max(index, 0), stepDetails.length - 1);
      buttons.forEach((button, buttonIndex) => {
        const state = stateFor(buttonIndex);
        const isActive = buttonIndex === activeIndex;
        button.classList.toggle("is-completed", state === "completed");
        button.classList.toggle("is-active", isActive);
        button.classList.toggle("is-upcoming", state === "upcoming");
        button.setAttribute("aria-pressed", String(isActive));
        if (isActive) button.setAttribute("aria-current", "step");
        else button.removeAttribute("aria-current");
      });
      panels.forEach((panel, panelIndex) => {
        const isActive = panelIndex === activeIndex;
        panel.classList.toggle("is-active", isActive);
        panel.hidden = !isActive;
      });
      stateLabels.forEach((label, labelIndex) => {
        const state = stateFor(labelIndex);
        label.textContent = state.charAt(0).toUpperCase() + state.slice(1);
      });
      if (sessionStep)
        sessionStep.textContent = `Step ${activeIndex + 1} of ${stepDetails.length}`;
      gapNote?.classList.toggle(
        "is-muted",
        stepDetails[activeIndex]?.id !== "coverage",
      );
      const story = stepDetails[activeIndex]?.story;
      if (story) {
        if (storyEmoji) storyEmoji.textContent = story.emoji;
        if (storyActor) storyActor.textContent = story.actor;
        if (storyHeading) storyHeading.textContent = story.heading;
        if (storyBody) storyBody.textContent = story.body;
        if (storyHandoff) storyHandoff.textContent = story.handoff;
        if (storyEvidence) {
          storyEvidence.textContent = story.evidenceLabel || "";
          storyEvidence.hidden = !story.evidenceLabel;
        }
        if (storyBoundary) {
          storyBoundary.textContent = story.boundary || "";
          storyBoundary.hidden = !story.boundary;
        }
      }
    }

    function openCompletionDialog() {
      if (
        completionDialog instanceof HTMLDialogElement &&
        !completionDialog.open
      ) {
        completionDialog.showModal();
        resultOk?.focus();
      }
    }
    function resetReplay() {
      setActiveStep(0);
      buttons[0]?.focus();
    }

    root?.classList.add("is-enhanced");
    buttons.forEach((button, index) =>
      button.addEventListener("click", () => setActiveStep(index)),
    );
    previous?.addEventListener("click", () => setActiveStep(activeIndex - 1));
    next?.addEventListener("click", () => {
      if (activeIndex === stepDetails.length - 1) {
        openCompletionDialog();
        return;
      }
      setActiveStep(activeIndex + 1);
    });
    resultOk?.addEventListener("click", () => {
      shouldResetOnDialogClose = true;
      completionDialog?.close();
    });
    completionDialog?.addEventListener("close", () => {
      if (shouldResetOnDialogClose) {
        shouldResetOnDialogClose = false;
        resetReplay();
        return;
      }
      next?.focus();
    });
  </script>
</BaseLayout>

<style>
  .replay-page {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.25rem);
  }

  .replay-hero h1 {
    max-width: 1040px;
    font-size: var(--text-page-title);
  }

  .safety-note {
    max-width: 820px;
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .result-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: var(--space-4);
  }

  .result-links :global(a),
  .result-links a {
    border: 2px solid rgba(55, 40, 38, 0.65);
    border-radius: 4px;
    padding: 0.45rem 0.65rem;
    background: rgba(248, 240, 231, 0.92);
    color: var(--color-text);
    font-size: var(--font-size-small);
    font-weight: 600;
    text-decoration: none;
  }

  .case-summary {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--border-width);
    overflow: hidden;
    border: 2px solid rgba(55, 40, 38, 0.72);
    border-radius: 4px;
    background: rgba(55, 40, 38, 0.72);
    box-shadow: 3px 3px 0 rgba(55, 40, 38, 0.1);
  }

  .case-summary div {
    min-width: 0;
    padding: 0.85rem 1rem;
    background: rgba(248, 240, 231, 0.92);
  }

  .case-summary dt,
  .panel-kicker,
  .technical-details summary {
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-summary dd {
    margin: 0.3rem 0 0;
    overflow-wrap: anywhere;
    font-weight: 600;
  }

  .story-intro {
    max-width: 860px;
    border-left: 0.38rem solid var(--khaki);
    padding-left: var(--space-5);
  }

  .story-intro h2 {
    max-width: 760px;
    margin-bottom: var(--space-4);
    font-size: var(--font-size-supporting);
  }

  .story-intro p {
    max-width: var(--reading-width);
    color: var(--color-text-muted);
  }

  .replay-explanation {
    border: 1px solid rgba(55, 40, 38, 0.16);
    border-left: 0.32rem solid var(--blue);
    padding: 0.75rem 0.9rem;
    background: rgba(207, 231, 246, 0.24);
  }

  .cast-key {
    border: 2px solid rgba(55, 40, 38, 0.38);
    border-radius: 4px;
    padding: 0.85rem 1rem;
    background: rgba(248, 240, 231, 0.76);
    box-shadow:
      2px 2px 0 rgba(55, 40, 38, 0.08),
      inset 1px 1px 0 rgba(255, 248, 239, 0.86);
  }

  .cast-key h2 {
    margin-bottom: 0.55rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cast-key ul {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cast-key li {
    min-width: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
    font-weight: 600;
  }

  .cast-key span {
    margin-right: 0.25rem;
  }

  .workstation-shell {
    overflow: hidden;
    border: 2px solid rgba(55, 40, 38, 0.82);
    border-radius: 6px;
    background:
      linear-gradient(rgba(255, 248, 239, 0.35), rgba(255, 248, 239, 0.35)),
      repeating-linear-gradient(
        0deg,
        rgba(55, 40, 38, 0.025) 0,
        rgba(55, 40, 38, 0.025) 1px,
        transparent 1px,
        transparent 7px
      ),
      var(--paper);
    box-shadow:
      5px 5px 0 rgba(55, 40, 38, 0.16),
      inset 2px 2px 0 rgba(255, 248, 239, 0.85),
      inset -2px -2px 0 rgba(55, 40, 38, 0.12);
  }

  .workstation-titlebar,
  .retro-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid rgba(55, 40, 38, 0.72);
    background: color-mix(in srgb, var(--rust) 24%, var(--paper));
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: var(--font-size-small);
    font-weight: 600;
    line-height: 1.2;
  }

  .workstation-titlebar {
    padding: 0.55rem 0.8rem;
  }

  .retro-titlebar {
    min-height: 2.2rem;
    padding: 0.42rem 0.55rem;
  }

  .window-controls,
  .mini-window-controls {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .window-controls span,
  .mini-window-controls span {
    display: inline-grid;
    width: 1.25rem;
    height: 1.15rem;
    place-items: center;
    border: 1px solid rgba(55, 40, 38, 0.62);
    background: rgba(255, 248, 239, 0.58);
    line-height: 1;
  }

  .workstation-menu {
    display: flex;
    gap: 1.25rem;
    border-bottom: 1px solid rgba(55, 40, 38, 0.35);
    padding: 0.4rem 0.8rem;
    background: rgba(255, 248, 239, 0.54);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .workstation-menu a {
    color: var(--color-text);
    text-decoration: none;
  }

  .workstation-menu a:hover {
    color: var(--rust);
    text-decoration: underline;
  }

  .session-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    align-items: center;
    border-bottom: 1px solid rgba(55, 40, 38, 0.22);
    padding: 0.7rem 0.8rem;
    background: color-mix(in srgb, var(--blue-soft) 46%, var(--paper));
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .session-strip span:not(:last-child)::after {
    margin-left: 0.75rem;
    color: rgba(55, 40, 38, 0.38);
    content: "|";
  }

  .recorded-badge {
    color: var(--plum);
    text-transform: uppercase;
  }

  .timeline-panel {
    padding: 0.8rem 0.8rem 0;
  }

  .investigation-timeline {
    display: grid;
    grid-template-columns: repeat(5, minmax(9.5rem, 1fr));
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: var(--space-2);
  }

  .timeline-button {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.55rem;
    align-items: start;
    min-height: 5.25rem;
    border: 2px solid rgba(55, 40, 38, 0.55);
    border-radius: 4px;
    padding: 0.62rem;
    background: rgba(255, 248, 239, 0.72);
    color: var(--color-text);
    font: inherit;
    text-align: left;
    box-shadow:
      inset 2px 2px 0 rgba(255, 248, 239, 0.75),
      inset -2px -2px 0 rgba(55, 40, 38, 0.08);
    cursor: pointer;
  }

  .tool-icon {
    display: inline-grid;
    width: 1.85rem;
    height: 1.85rem;
    place-items: center;
    border: 1px solid rgba(55, 40, 38, 0.58);
    background: color-mix(in srgb, var(--blue-soft) 42%, var(--paper));
    color: var(--plum);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1;
  }

  .timeline-copy {
    display: grid;
    gap: 0.16rem;
  }

  .timeline-number {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .timeline-label {
    font-size: 0.93rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .timeline-state {
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .timeline-button.is-completed {
    background: color-mix(in srgb, var(--houseplant) 16%, var(--paper));
  }

  .timeline-button.is-active {
    border-color: rgba(55, 40, 38, 0.84);
    background: color-mix(in srgb, var(--khaki) 24%, var(--paper));
    box-shadow:
      3px 3px 0 rgba(55, 40, 38, 0.18),
      inset 2px 2px 0 rgba(255, 248, 239, 0.72);
  }

  .timeline-button.is-upcoming {
    color: color-mix(in srgb, var(--color-text) 78%, var(--color-text-muted));
  }

  .personality-note {
    width: fit-content;
    margin: 0.1rem 0.8rem 0.85rem auto;
    border: 1px solid rgba(145, 80, 91, 0.24);
    border-radius: 3px;
    padding: 0.3rem 0.58rem;
    background: rgba(255, 248, 239, 0.86);
    color: var(--plum);
    font-family: var(--font-hand);
    font-size: 1.08rem;
    font-weight: 600;
    line-height: 1.2;
    box-shadow: 2px 2px 0 rgba(210, 166, 58, 0.18);
    transition: opacity var(--motion-fast);
  }

  .personality-note.is-muted {
    opacity: 0.35;
  }

  .team-notes {
    display: grid;
    grid-template-columns: minmax(9rem, 0.23fr) minmax(0, 1fr) auto;
    gap: 0.85rem;
    align-items: center;
    margin: 0 0.8rem 0.8rem;
    border: 2px inset rgba(55, 40, 38, 0.3);
    border-left: 0.42rem solid var(--khaki);
    border-radius: 3px;
    padding: 0.85rem;
    background: rgba(255, 248, 239, 0.78);
    box-shadow: inset 1px 1px 0 rgba(255, 248, 239, 0.9);
    transition: background-color var(--motion-fast);
  }

  .team-note-actor {
    display: grid;
    gap: 0.18rem;
    align-content: center;
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .team-note-emoji {
    font-size: 1.25rem;
    line-height: 1;
  }

  .team-note-name {
    font-size: var(--font-size-small);
    text-transform: uppercase;
  }

  .team-note-evidence {
    width: fit-content;
    border: 1px solid rgba(55, 40, 38, 0.26);
    padding: 0.1rem 0.32rem;
    background: rgba(210, 166, 58, 0.15);
    color: var(--color-text-muted);
    font-size: 0.72rem;
  }

  .team-note-copy h2 {
    margin: 0 0 0.25rem;
    font-size: 1.08rem;
  }

  .team-note-copy p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .team-note-boundary {
    margin-top: 0.45rem !important;
    border-left: 3px solid var(--rust);
    padding-left: 0.55rem;
    font-weight: 600;
  }

  .team-note-handoff {
    justify-self: end;
    border: 1px solid rgba(55, 40, 38, 0.42);
    padding: 0.28rem 0.45rem;
    background: color-mix(in srgb, var(--lavender) 42%, var(--paper));
    color: var(--plum);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .workspace {
    min-height: 30rem;
    padding: 0 0.8rem 0.8rem;
  }

  .workspace-step {
    display: grid;
    grid-template-columns: minmax(0, 1.14fr) minmax(320px, 0.86fr);
    gap: 0.75rem;
  }

  .workspace-step[hidden] {
    display: none;
  }

  .retro-window {
    overflow: hidden;
    min-width: 0;
    border: 2px solid rgba(55, 40, 38, 0.74);
    border-radius: 4px;
    background: var(--paper);
    box-shadow:
      3px 3px 0 rgba(55, 40, 38, 0.14),
      inset 1px 1px 0 rgba(255, 248, 239, 0.76);
  }

  .evidence-panel,
  .notebook-panel {
    min-width: 0;
  }

  .window-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.65rem;
    justify-content: space-between;
    border-bottom: 1px solid rgba(55, 40, 38, 0.22);
    padding: 0.45rem 0.6rem;
    background: rgba(255, 248, 239, 0.58);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .window-body {
    padding: clamp(0.9rem, 2vw, 1.25rem);
  }

  .notebook-paper {
    min-height: 100%;
    background:
      repeating-linear-gradient(
        180deg,
        transparent 0,
        transparent 2.1rem,
        rgba(79, 134, 168, 0.11) 2.1rem,
        rgba(79, 134, 168, 0.11) calc(2.1rem + 1px)
      ),
      rgba(255, 248, 239, 0.78);
  }

  .notebook-panel h2,
  .result-dialog h2 {
    margin: 0.2rem 0 0.95rem;
    font-size: var(--text-h3);
  }

  .evidence-facts,
  .record-list,
  .technical-details dl {
    display: grid;
    gap: 0.58rem;
    margin: 0;
  }

  .evidence-facts {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 0.8rem;
  }

  .evidence-facts.compact {
    grid-template-columns: minmax(0, 1fr);
    margin-bottom: 0;
  }

  .evidence-facts div,
  .record-list div,
  .technical-details details {
    border: 1px solid rgba(55, 40, 38, 0.22);
    border-radius: 3px;
    padding: 0.62rem 0.68rem;
    background: rgba(255, 248, 239, 0.68);
    box-shadow: inset 1px 1px 0 rgba(255, 248, 239, 0.82);
  }

  .evidence-facts dt,
  .record-list dt,
  .technical-details dt {
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .evidence-facts dd,
  .record-list dd,
  .technical-details dd {
    margin: 0.25rem 0 0;
    overflow-wrap: anywhere;
    font-weight: 600;
  }

  code {
    font-size: 0.92em;
  }

  .diff-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 0.7rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .diff-badges span {
    border: 1px solid rgba(55, 40, 38, 0.28);
    padding: 0.18rem 0.4rem;
    background: rgba(255, 248, 239, 0.7);
  }

  .diff-badges .additions {
    background: rgba(111, 152, 117, 0.24);
    color: #304d34;
  }

  .diff-badges .deletions {
    background: rgba(145, 80, 91, 0.13);
    color: var(--plum);
  }

  .diff-view,
  .technical-details pre {
    overflow: auto;
    max-height: 25rem;
    border: 2px inset rgba(55, 40, 38, 0.36);
    border-radius: 2px;
    padding: 0.65rem 0;
    background: color-mix(in srgb, var(--blue-soft) 34%, var(--canvas));
    color: var(--color-text);
    font-size: 0.78rem;
    line-height: 1.45;
    text-align: left;
    counter-reset: diff-line;
  }

  .diff-line {
    display: grid;
    grid-template-columns: 2.7rem minmax(max-content, 1fr);
    gap: 0.75rem;
    min-width: max-content;
    padding-inline: 0.55rem 0.9rem;
    white-space: pre;
    counter-increment: diff-line;
  }

  .diff-line::before {
    color: rgba(55, 40, 38, 0.46);
    content: counter(diff-line);
    text-align: right;
    user-select: none;
  }

  .diff-line.is-meta {
    color: color-mix(in srgb, var(--blue) 72%, var(--ink));
    font-weight: 600;
  }

  .diff-line.is-added {
    background: rgba(111, 152, 117, 0.2);
    color: #304d34;
  }

  .diff-line.is-branch-gap {
    outline: 1px solid rgba(210, 166, 58, 0.48);
    outline-offset: -1px;
    background: rgba(210, 166, 58, 0.18);
  }

  .diff-line.is-removed {
    background: rgba(145, 80, 91, 0.14);
    color: var(--plum);
  }

  .coverage-link-note {
    margin: 0.7rem 0 0;
    border-left: 4px solid var(--khaki);
    padding-left: 0.65rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .command-result,
  .coverage-report,
  .recommendation-card {
    border: 2px inset rgba(55, 40, 38, 0.28);
    border-left: 0.42rem solid var(--houseplant);
    border-radius: 3px;
    padding: 0.95rem;
    background: rgba(255, 248, 239, 0.7);
  }

  .coverage-report {
    border-left-color: var(--khaki);
  }

  .coverage-report-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
    border-bottom: 1px solid rgba(55, 40, 38, 0.24);
    padding-bottom: 0.8rem;
  }

  .coverage-report-header h3 {
    margin: 0;
    font-size: 1.08rem;
  }

  .coverage-report-header p {
    margin: 0.2rem 0 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .coverage-warning {
    display: inline-grid;
    width: 2.15rem;
    height: 2.15rem;
    place-items: center;
    border-radius: 50%;
    border: 2px solid rgba(55, 40, 38, 0.42);
    background: rgba(210, 166, 58, 0.24);
    color: color-mix(in srgb, var(--khaki) 64%, var(--ink));
    font-weight: 600;
  }

  .inspection-list {
    display: grid;
    gap: 0;
    margin: 0.8rem 0 0;
  }

  .inspection-list div {
    display: grid;
    grid-template-columns: minmax(9rem, 0.34fr) minmax(0, 1fr);
    gap: 0.85rem;
    border-bottom: 1px solid rgba(55, 40, 38, 0.16);
    padding: 0.72rem 0;
  }

  .inspection-list div:last-child {
    border-bottom: 0;
  }

  .inspection-list dt {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .inspection-list dd {
    margin: 0;
    min-width: 0;
    overflow-wrap: anywhere;
    color: var(--color-text);
    font-weight: 600;
  }

  .inspection-status {
    color: #365f2c;
  }

  .recommendation-card {
    border-left-color: color-mix(in srgb, var(--lavender) 72%, var(--plum));
  }

  .recommendation-action {
    margin: 0.65rem 0 var(--space-4);
    color: var(--color-text);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .status-indicator {
    display: inline-block;
    margin-bottom: 0.65rem;
    border: 2px solid rgba(55, 40, 38, 0.44);
    padding: 0.18rem 0.45rem;
    background: color-mix(in srgb, var(--houseplant) 22%, var(--paper));
    color: #304d34;
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .status-indicator.recommendation-only {
    background: color-mix(in srgb, var(--lavender) 50%, var(--paper));
    color: var(--plum);
  }

  .tone-success {
    color: #435f22;
  }

  .notebook-entry {
    border-top: 1px solid rgba(55, 40, 38, 0.18);
    padding-top: 0.8rem;
  }

  .notebook-entry + .notebook-entry {
    margin-top: 0.8rem;
  }

  .notebook-entry h3 {
    margin-bottom: var(--space-2);
    font-size: 0.95rem;
  }

  .notebook-entry p,
  .boundary-note {
    color: var(--color-text-muted);
  }

  .boundary-note {
    margin-top: var(--space-5);
    border-left: 0.3rem solid var(--rust);
    padding-left: var(--space-4);
    font-weight: 600;
  }

  .read-only-label {
    border: 1px solid rgba(55, 40, 38, 0.28);
    padding: 0.08rem 0.35rem;
    background: rgba(255, 248, 239, 0.6);
    color: var(--color-text-muted);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .accent-sky .retro-titlebar {
    background: color-mix(in srgb, var(--blue) 24%, var(--paper));
  }

  .accent-sage .retro-titlebar {
    background: color-mix(in srgb, var(--houseplant) 24%, var(--paper));
  }

  .accent-ochre .retro-titlebar {
    background: color-mix(in srgb, var(--khaki) 36%, var(--paper));
  }

  .accent-burgundy .retro-titlebar {
    background: color-mix(in srgb, var(--rust) 24%, var(--paper));
  }

  .accent-lavender .retro-titlebar {
    background: color-mix(in srgb, var(--lavender) 70%, var(--paper));
  }

  .playback-shell {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    justify-content: center;
    border-top: 2px solid rgba(55, 40, 38, 0.32);
    padding: 0.8rem;
    background: rgba(255, 248, 239, 0.52);
  }

  .retro-control,
  .retro-ok {
    display: inline-flex;
    min-height: 2.55rem;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(55, 40, 38, 0.72);
    border-radius: 3px;
    padding: 0.48rem 0.78rem;
    background: rgba(255, 248, 239, 0.86);
    color: var(--color-text);
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--font-size-small);
    font-weight: 600;
    text-decoration: none;
    box-shadow:
      2px 2px 0 rgba(55, 40, 38, 0.16),
      inset 1px 1px 0 rgba(255, 248, 239, 0.9);
    cursor: pointer;
  }

  .retro-control:hover,
  .retro-ok:hover {
    background: color-mix(in srgb, var(--khaki) 18%, var(--paper));
    color: var(--color-text);
  }

  .retro-control.primary {
    background: color-mix(in srgb, var(--blue-soft) 50%, var(--paper));
  }

  .replay-mode {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .result-dialog {
    overflow: hidden;
    width: min(42rem, calc(100vw - 2rem));
    max-height: min(44rem, calc(100vh - 2rem));
    border: 2px solid rgba(55, 40, 38, 0.74);
    border-radius: 4px;
    padding: 0;
    background: rgba(248, 240, 231, 0.9);
    color: var(--color-text);
    box-shadow: 4px 4px 0 rgba(55, 40, 38, 0.12);
  }

  .result-dialog::backdrop {
    background: rgba(55, 40, 38, 0.38);
  }

  .result-dialog:not([open]) {
    display: none;
  }

  .result-body {
    overflow-y: auto;
    max-height: calc(min(44rem, 100vh - 2rem) - 2.2rem);
    padding: clamp(1.1rem, 2.4vw, 1.6rem);
  }

  .result-list {
    display: grid;
    gap: 0.6rem;
    max-width: 720px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .result-list li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    align-items: center;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .result-list span {
    color: var(--houseplant);
    font-weight: 600;
  }

  .result-list .warning span {
    color: color-mix(in srgb, var(--khaki) 72%, var(--ink));
  }

  .result-story {
    display: grid;
    gap: 0.3rem;
    max-width: 780px;
    margin-bottom: var(--space-5);
    color: var(--color-text-muted);
  }

  .result-story p {
    margin: 0;
  }

  .result-boundary {
    display: grid;
    gap: 0.25rem;
    max-width: 680px;
    margin-top: var(--space-5);
    border-left: 0.32rem solid var(--rust);
    padding-left: var(--space-4);
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .result-boundary p {
    margin: 0;
  }

  .retro-ok {
    width: min(8rem, 100%);
    margin-top: var(--space-5);
  }

  .technical-details {
    display: grid;
    gap: 0.55rem;
  }

  .technical-details summary {
    list-style-position: inside;
    cursor: pointer;
