---
import type { CollectionEntry } from "astro:content";
import ExternalLink from "./ExternalLink.astro";
import StatusBadge from "./StatusBadge.astro";
import TagList from "./TagList.astro";

type CaseItem = {
  title: string;
  text: string;
};

type CaseLink = {
  href: string;
  label: string;
  external?: boolean;
};

type RelatedLog = {
  title: string;
  summary: string;
  href: string;
};

type BoundaryItem = {
  label: "Implemented" | "Demonstrated" | "Planned" | "Boundary";
  text: string;
};

type Props = {
  project: CollectionEntry<"projects">;
  eyebrow: string;
  thesis: string;
  researchQuestion: string;
  evidence: CaseItem[];
  systems: CaseItem[];
  boundaries: string[];
  boundaryItems?: BoundaryItem[];
  links: CaseLink[];
  relatedLogs?: RelatedLog[];
  featuredObject?: CaseItem;
};

const {
  project,
  eyebrow,
  thesis,
  researchQuestion,
  evidence,
  systems,
  boundaries,
  boundaryItems,
  links,
  relatedLogs = [],
  featuredObject,
} = Astro.props;
const data = project.data;
const evidenceLabels = ["Implemented", "Inspectable", "Experimental"];
const resolvedBoundaries =
  boundaryItems ??
  boundaries.map((item, index) => ({
    label:
      index === 0 ? "Implemented" : index === 1 ? "Demonstrated" : "Boundary",
    text: item,
  }));
---

<article class={`case-study ${data.accent}`}>
  <header class="case-hero wide-case">
    <div class="case-hero-copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{data.title}</h1>
      <p class="lede">{data.summary}</p>
      <p class="case-thesis">{thesis}</p>
      <div class="case-meta">
        <StatusBadge status={data.status} accent={data.accent} />
        <TagList tags={data.tags} />
      </div>
    </div>

    <aside class="research-question artifact-card">
      <p class="eyebrow">Research question</p>
      <h2>{researchQuestion}</h2>
    </aside>
  </header>

  <section
    class="page-section evidence-band"
    aria-labelledby={`${data.slug}-evidence`}
  >
    <div class="wide-case">
      <div class="compact-section-intro">
        <p class="eyebrow">Case evidence</p>
        <h2 id={`${data.slug}-evidence`}>What the public case study shows</h2>
      </div>
      <div class="evidence-strip">
        {
          evidence.map((item, index) => (
            <section class="evidence-item">
              <p class="eyebrow">{evidenceLabels[index] ?? "Evidence"}</p>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="page-section wide-case"
    aria-labelledby={`${data.slug}-systems`}
  >
    <div class="case-grid">
      <div>
        <p class="eyebrow">System map</p>
        <h2 id={`${data.slug}-systems`}>How the parts connect</h2>
      </div>
      <div class="system-map" aria-label={`${data.title} system map`}>
        {
          systems.map((item, index) => (
            <div class="system-node">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{item.title}</strong>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="page-section content-band"
    aria-labelledby={`${data.slug}-current`}
  >
    <div class="wide-case case-grid">
      <div>
        <p class="eyebrow">Current work</p>
        <h2 id={`${data.slug}-current`}>Artifacts on the desk</h2>
      </div>
      <div class="editorial-list current-work-list">
        {
          systems.map((item) => (
            <section class="editorial-row">
              <p class="eyebrow">Module</p>
              <div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  {
    featuredObject && (
      <section
        class="page-section content-band"
        aria-labelledby={`${data.slug}-featured`}
      >
        <div class="wide-case featured-case-object">
          <div>
            <p class="eyebrow">Featured object</p>
            <h2 id={`${data.slug}-featured`}>{featuredObject.title}</h2>
          </div>
          <div class="featured-artifact">
            <p>{featuredObject.text}</p>
            <slot name="featured" />
          </div>
        </div>
      </section>
    )
  }

  <section
    class="page-section wide-case"
    aria-labelledby={`${data.slug}-status`}
  >
    <div class="case-grid">
      <div>
        <p class="eyebrow">Boundaries</p>
        <h2 id={`${data.slug}-status`}>
          What this page is careful not to claim
        </h2>
      </div>
      <div class="stack boundary-stack">
        <div class="boundary-grid">
          {
            resolvedBoundaries.map((item) => (
              <article
                class={`boundary-item boundary-${item.label.toLowerCase()}`}
              >
                <p class="eyebrow">{item.label}</p>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
        <div class="related-link-row">
          {
            links.map((link) =>
              link.external ? (
                <ExternalLink href={link.href} label={link.label} />
              ) : (
                <a href={link.href}>{link.label}</a>
              ),
            )
          }
        </div>
      </div>
    </div>
  </section>

  {
    relatedLogs.length > 0 && (
      <section
        class="page-section content-band"
        aria-labelledby={`${data.slug}-field-log`}
      >
        <div class="wide-case case-grid">
          <div>
            <p class="eyebrow">Related Field Log</p>
            <h2 id={`${data.slug}-field-log`}>Notes beside the case study</h2>
          </div>
          <div class="related-notes">
            {relatedLogs.map((entry) => (
              <article>
                <h3>{entry.title}</h3>
                <p>{entry.summary}</p>
                <a href={entry.href}>Read note</a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }
</article>

<style>
  .case-study {
    --case-accent: var(--khaki);
    --case-accent-soft: color-mix(
      in srgb,
      var(--case-accent) 16%,
      var(--paper)
    );
    --case-accent-line: color-mix(
      in srgb,
      var(--case-accent) 48%,
      var(--color-border)
    );
  }

  .case-study.rust {
    --case-accent: var(--rust);
    --case-accent-soft: color-mix(in srgb, var(--lavender) 28%, var(--paper));
    --case-accent-line: color-mix(
      in srgb,
      var(--rust) 48%,
      var(--color-border)
    );
  }

  .case-study.olive {
    --case-accent: var(--olive);
    --case-accent-soft: color-mix(in srgb, var(--olive) 20%, var(--paper));
    --case-accent-line: color-mix(
      in srgb,
      var(--olive) 52%,
      var(--color-border)
    );
  }

  .case-study.blue {
    --case-accent: var(--blue);
    --case-accent-soft: color-mix(in srgb, var(--blue-soft) 62%, var(--paper));
    --case-accent-line: color-mix(
      in srgb,
      var(--blue) 48%,
      var(--color-border)
    );
  }

  .case-study.plum {
    --case-accent: var(--plum);
  }

  .case-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.36fr);
    gap: var(--section-gap);
    align-items: end;
    padding-block: clamp(2.75rem, 6vw, 5.5rem);
  }

  .case-hero-copy {
    min-width: 0;
  }

  .case-hero h1 {
    max-width: 11ch;
    font-size: var(--font-size-page-title);
  }

  .case-thesis {
    max-width: var(--measure);
    margin-top: var(--space-4);
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: var(--font-size-supporting);
    font-weight: 700;
    line-height: 1.18;
  }

  .case-meta {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .research-question {
    border-left: 0.42rem solid var(--case-accent);
  }

  .research-question h2 {
    font-size: var(--font-size-object-heading);
  }

  .evidence-band {
    border-block: var(--border-width) solid var(--color-border);
    background:
      linear-gradient(90deg, var(--case-accent-soft), transparent 42%),
      var(--color-surface-band);
  }

  .evidence-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .evidence-item {
    min-width: 0;
    border-left: 0.34rem solid var(--case-accent);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    background: color-mix(in srgb, var(--paper) 78%, transparent);
  }

  .evidence-item h3 {
    margin-bottom: var(--space-2);
  }

  .evidence-item p:not(.eyebrow) {
    color: var(--color-text-muted);
  }

  .case-grid,
  .featured-case-object {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: var(--section-gap);
    align-items: start;
  }

  .case-grid h2,
  .featured-case-object h2 {
    font-family: var(--font-serif);
    font-size: var(--font-size-section-title);
  }

  .case-object-grid {
    display: grid;
    gap: var(--grid-gap);
  }

  .system-map {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.7rem;
    align-items: stretch;
  }

  .system-node {
    position: relative;
    display: grid;
    min-height: 7rem;
    align-content: space-between;
    border: var(--border-width) solid var(--case-accent-line);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    background: var(--case-accent-soft);
  }

  .system-node:not(:last-child)::after {
    position: absolute;
    top: 50%;
    right: -0.72rem;
    width: 0.72rem;
    height: 2px;
    background: var(--case-accent);
    content: "";
  }

  .system-node span {
    color: color-mix(in srgb, var(--case-accent) 78%, var(--color-text));
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 800;
  }

  .system-node strong {
    color: var(--color-text);
    line-height: 1.12;
  }

  .current-work-list .editorial-row:first-child {
    border-top-color: var(--case-accent-line);
  }

  .case-object-grid section,
  .case-object-grid article {
    min-width: 0;
  }

  .case-object-grid p,
  .featured-case-object p,
  .current-work-list p {
    color: var(--color-text-muted);
  }

  .featured-artifact {
    border: var(--border-width) solid var(--case-accent-line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    background:
      linear-gradient(135deg, var(--case-accent-soft), transparent 68%),
      var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .boundary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .boundary-item {
    border-top: 0.3rem solid var(--case-accent);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    background: var(--color-surface-raised);
  }

  .boundary-demonstrated {
    border-top-color: var(--houseplant);
  }

  .boundary-planned {
    border-top-color: var(--khaki);
  }

  .boundary-boundary {
    border-top-color: var(--rust);
  }

  .boundary-item p:not(.eyebrow) {
    color: var(--color-text-muted);
  }

  .related-notes {
    display: grid;
    gap: 0;
  }

  .related-notes article {
    border-top: var(--border-width) solid var(--color-border);
    padding-block: var(--space-4);
  }

  .related-notes article:last-child {
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .related-notes h3 {
    margin-bottom: var(--space-2);
    font-size: 1.1rem;
  }

  .related-notes p {
    color: var(--color-text-muted);
  }

  @media (max-width: 820px) {
    .case-hero,
    .case-grid,
    .featured-case-object,
    .evidence-strip,
    .system-map,
    .boundary-grid {
      grid-template-columns: 1fr;
    }

    .system-node:not(:last-child)::after {
      top: auto;
      right: auto;
      bottom: -0.72rem;
      left: 50%;
      width: 2px;
      height: 0.72rem;
    }
  }
</style>
