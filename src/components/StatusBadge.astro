---
type Props = {
  status: string;
  accent?: "rust" | "olive" | "plum" | "blue" | "khaki";
};

const { status, accent = "khaki" } = Astro.props;
---

<span class={`status ${accent}`}>{status}</span>

<style>
  .status {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.22rem 0.58rem;
    background: var(--color-surface-raised);
    color: var(--color-text);
    font-size: var(--font-size-micro);
    font-weight: 800;
  }

  .rust {
    border-color: var(--accent-primary-border);
    color: var(--rust);
  }

  .olive {
    border-color: var(--accent-secondary-border);
    color: var(--olive);
  }

  .plum {
    color: var(--plum);
  }

  .blue {
    border-color: var(--accent-tertiary-border);
    color: var(--blue);
  }

  .khaki {
    color: #6d5c30;
  }
</style>
