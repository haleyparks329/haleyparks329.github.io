---
type Props = {
  href: string;
  label: string;
  ariaLabel?: string;
  class?: string;
};

const { href, label, ariaLabel } = Astro.props;
const className = Astro.props.class;
---

<a
  aria-label={ariaLabel}
  class={`external-link ${className ?? ""}`}
  href={href}
  rel="noopener noreferrer"
  target="_blank"
>
  <span>{label}</span>
  <span aria-hidden="true">-&gt;</span>
</a>

<style>
  .external-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
  }
</style>
