---
type Props = {
  href: string;
  label: string;
};

const { href, label } = Astro.props;
---

<a class="external-link" href={href} rel="noreferrer" target="_blank">
  <span>{label}</span>
  <span aria-hidden="true">-&gt;</span>
</a>

<style>
  .external-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
  }
</style>
