---
import { siteConfig } from "@/site.config";

const nav = [
  { href: "/explore/", label: "What’s Here?" },
  { href: "/projects/", label: "Projects" },
  { href: "/writing/", label: "Writing" },
  { href: "/about/", label: "About" },
  { href: "/search/", label: "Search" },
];

const currentPath = Astro.url.pathname;

function isCurrent(href: string) {
  if (href === "/") {
    return currentPath === href;
  }

  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
      <span class="brand-mark" aria-hidden="true">HP</span>
      <span class="brand-copy">
        <span class="brand-name">{siteConfig.name}</span>
        <span class="brand-role">{siteConfig.role}</span>
      </span>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrent(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border-width) solid var(--color-border);
    background: var(--color-canvas);
  }

  .site-header-inner {
    display: flex;
    width: min(var(--site-max-width), calc(100% - (var(--site-gutter) * 2)));
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 4.5rem;
    margin: 0 auto;
    padding-block: 0.65rem;
  }

  .brand,
  .nav a {
    color: var(--color-text);
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 600;
    min-width: max-content;
  }

  .brand-mark {
    display: inline-grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border: var(--border-width) solid var(--color-border);
    border-radius: 50%;
    background: var(--color-paper-clean);
    color: var(--accent-primary);
    font-size: 0.78rem;
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
  }

  .brand-name {
    line-height: var(--line-height-tight);
  }

  .brand-role {
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 600;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(1.1rem, 2.4vw, 2rem);
  }

  .nav a {
    position: relative;
    padding-block: 0.45rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .nav a::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 2px;
    background: currentColor;
    content: "";
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition:
      opacity 140ms ease,
      transform 140ms ease;
  }

  .nav a:hover,
  .nav a[aria-current="page"] {
    color: var(--color-text);
  }

  .nav a:hover::after,
  .nav a[aria-current="page"]::after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav a::after {
      transition: none;
    }
  }

  @media (max-width: 620px) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.85rem;
    }

    .nav {
      width: 100%;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 0.65rem 1rem;
    }

    .nav a {
      white-space: nowrap;
    }
  }
</style>
