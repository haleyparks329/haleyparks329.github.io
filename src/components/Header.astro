---
import { siteConfig } from "@/site.config";

const nav = [
  { href: "/", label: "Home" },
  { href: "/explore/", label: "What’s Here?" },
  { href: "/projects/", label: "Projects" },
  { href: "/writing/", label: "Writing" },
  { href: "/field-log/", label: "Field Log" },
  { href: "/about/", label: "About" },
  { href: "/search/", label: "Search" },
];

const currentPath = Astro.url.pathname;

function isCurrent(href: string) {
  if (href === "/") {
    return currentPath === href;
  }

  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
      <span class="brand-mark" aria-hidden="true">HP</span>
      <span class="brand-copy">
        <span class="brand-name">{siteConfig.name}</span>
        <span class="brand-role">{siteConfig.role}</span>
      </span>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrent(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border-width) solid var(--color-border);
    background: color-mix(in srgb, var(--color-canvas) 86%, white);
  }

  .site-header-inner {
    display: flex;
    width: min(var(--container-width), calc(100% - var(--container-gutter)));
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin: 0 auto;
    padding-block: var(--space-4);
  }

  .brand,
  .nav a {
    color: var(--color-text);
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: var(--font-weight-heavy);
    min-width: max-content;
  }

  .brand-mark {
    display: inline-grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border: var(--border-width) solid var(--color-border);
    border-radius: 50%;
    background: var(--color-surface);
    color: var(--accent-primary);
    font-size: 0.78rem;
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
  }

  .brand-name {
    line-height: var(--line-height-tight);
  }

  .brand-role {
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 700;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.34rem;
    background: var(--color-surface-raised);
  }

  .nav a {
    border: var(--border-width) solid transparent;
    border-radius: calc(var(--radius-md) - 1px);
    padding: 0.42rem 0.72rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .nav a:hover,
  .nav a[aria-current="page"] {
    border-color: var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: 0 2px 0 rgba(55, 40, 38, 0.06);
  }

  @media (max-width: 620px) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.85rem;
    }

    .nav {
      width: 100%;
      flex-wrap: wrap;
      justify-content: flex-start;
    }

    .nav a {
      white-space: nowrap;
    }
  }
</style>
