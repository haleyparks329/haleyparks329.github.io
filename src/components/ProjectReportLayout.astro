---
import type { CollectionEntry } from "astro:content";
import ContinueExploring from "@/components/ContinueExploring.astro";
import ExternalLink from "@/components/ExternalLink.astro";
import ProjectNav from "@/components/ProjectNav.astro";
import StatusBadge from "@/components/StatusBadge.astro";
import TagList from "@/components/TagList.astro";
import type { ContentLink } from "@/data/navigation";

type ReportLink = {
  href: string;
  label: string;
  external?: boolean;
};

type ReportStep = {
  title: string;
  text: string;
};

type TechnicalGroup = {
  title: string;
  items: string[];
};

type StatusRow = {
  part: string;
  status:
    | "Working"
    | "Partial"
    | "Prototype"
    | "Experimental"
    | "Planned"
    | "Archived"
    | "Not built";
  does: string;
  inspect: ReportLink;
};

type Learning = {
  title: string;
  text: string;
};

type AppendixDetail = {
  summary: string;
  items: string[];
};

type Props = {
  project: CollectionEntry<"projects">;
  reportType: string;
  summary: string;
  links: ReportLink[];
  abstract: string[];
  why: string[];
  actuallyDoes: {
    intro: string;
    steps: string[];
  };
  howItWorks: {
    groups: TechnicalGroup[];
    note: string;
  };
  statusRows: StatusRow[];
  example: {
    title: string;
    steps: ReportStep[];
  };
  learnings: Learning[];
  notSolved: string[];
  appendix: {
    intro: string;
    details: AppendixDetail[];
    links: ReportLink[];
  };
  currentDirection: string[];
  projectNav?: {
    overviewHref: string;
    demoHref?: string;
    repositoryUrl?: string;
    buildLogHref?: string;
    relatedWriting?: ContentLink[];
  };
  continueLinks?: ContentLink[];
};

const {
  project,
  reportType,
  summary,
  links,
  abstract,
  why,
  actuallyDoes,
  howItWorks,
  statusRows,
  example,
  learnings,
  notSolved,
  appendix,
  currentDirection,
  projectNav,
  continueLinks = [],
} = Astro.props;
---

<article class="project-report">
  <header class="report-header">
    {
      projectNav && (
        <ProjectNav
          projectTitle={project.data.title}
          overviewHref={projectNav.overviewHref}
          demoHref={projectNav.demoHref}
          repositoryUrl={projectNav.repositoryUrl}
          buildLogHref={projectNav.buildLogHref}
          relatedWriting={projectNav.relatedWriting}
        />
      )
    }
    <p class="report-type">{reportType}</p>
    <h1>{project.data.title}</h1>
    <p class="report-summary">{summary}</p>
    <div class="report-meta">
      <span class="meta-label">Status</span>
      <StatusBadge status={project.data.status} />
    </div>
    <div class="report-tags">
      <span class="meta-label">Tags</span>
      <TagList tags={project.data.tags} />
    </div>
    <nav class="report-links" aria-label={`${project.data.title} links`}>
      {
        links.map((link) =>
          link.external ? (
            <ExternalLink href={link.href} label={link.label} />
          ) : (
            <a href={link.href}>{link.label}</a>
          ),
        )
      }
    </nav>
  </header>

  <section aria-labelledby="abstract">
    <h2 id="abstract">Abstract</h2>
    {abstract.map((paragraph) => <p>{paragraph}</p>)}
  </section>

  <section aria-labelledby="why-built">
    <h2 id="why-built">Why I built it</h2>
    {why.map((paragraph) => <p>{paragraph}</p>)}
  </section>

  <section aria-labelledby="actually-does">
    <h2 id="actually-does">What it actually does</h2>
    <p>{actuallyDoes.intro}</p>
    <ol>
      {actuallyDoes.steps.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section aria-labelledby="how-it-works" class="technical-block">
    <h2 id="how-it-works">How it works</h2>
    <div class="technical-groups">
      {
        howItWorks.groups.map((group) => (
          <section class="technical-group" aria-label={group.title}>
            <h3>{group.title}</h3>
            <ul>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
    <p>{howItWorks.note}</p>
  </section>

  <section aria-labelledby="exists-today" class="wide-section">
    <h2 id="exists-today">What exists today</h2>
    <div class="status-table-wrap">
      <table class="status-table">
        <thead>
          <tr>
            <th scope="col">Part</th>
            <th scope="col">Status</th>
            <th scope="col">What it does</th>
            <th scope="col">Where to inspect it</th>
          </tr>
        </thead>
        <tbody>
          {
            statusRows.map((row) => (
              <tr>
                <th scope="row">{row.part}</th>
                <td>
                  <span
                    class={`table-status ${row.status.toLowerCase().replaceAll(" ", "-")}`}
                  >
                    {row.status}
                  </span>
                </td>
                <td>{row.does}</td>
                <td>
                  {row.inspect.external ? (
                    <ExternalLink
                      href={row.inspect.href}
                      label={row.inspect.label}
                    />
                  ) : (
                    <a href={row.inspect.href}>{row.inspect.label}</a>
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section aria-labelledby="concrete-example">
    <h2 id="concrete-example">One concrete example</h2>
    <h3>{example.title}</h3>
    <ol class="step-list">
      {
        example.steps.map((step) => (
          <li>
            <strong>{step.title}</strong>
            <p>{step.text}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section aria-labelledby="learned">
    <h2 id="learned">What I learned</h2>
    <div class="learning-list">
      {
        learnings.map((learning) => (
          <article>
            <h3>{learning.title}</h3>
            <p>{learning.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section aria-labelledby="not-solved">
    <h2 id="not-solved">What is not solved</h2>
    <ul>
      {notSolved.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section aria-labelledby="appendix" class="technical-block">
    <h2 id="appendix">Technical appendix</h2>
    <p>{appendix.intro}</p>
    <div class="appendix-details">
      {
        appendix.details.map((detail) => (
          <details>
            <summary>{detail.summary}</summary>
            <ul>
              {detail.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </details>
        ))
      }
    </div>
    <nav
      class="appendix-links"
      aria-label={`${project.data.title} appendix links`}
    >
      {
        appendix.links.map((link) =>
          link.external ? (
            <ExternalLink href={link.href} label={link.label} />
          ) : (
            <a href={link.href}>{link.label}</a>
          ),
        )
      }
    </nav>
  </section>

  <section aria-labelledby="current-direction" class="current-direction">
    <h2 id="current-direction">Current direction</h2>
    {currentDirection.map((paragraph) => <p>{paragraph}</p>)}
  </section>
  <ContinueExploring links={continueLinks} />
</article>

<style>
  .project-report {
    width: min(860px, calc(100% - 2rem));
    margin: clamp(2rem, 5vw, 4rem) auto clamp(3rem, 7vw, 6rem);
  }

  .project-report h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 0.98;
  }

  .project-report h2 {
    margin-top: clamp(2.5rem, 5vw, 4.5rem);
    margin-bottom: var(--space-4);
    border-top: var(--border-width) solid var(--color-border);
    padding-top: clamp(1.5rem, 3vw, 2rem);
    font-size: clamp(1.5rem, 2.2vw, 2.1rem);
    line-height: 1.05;
  }

  .report-header + section h2 {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    border-top: 0;
    padding-top: 0;
  }

  .project-report h3 {
    margin-bottom: var(--space-2);
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    line-height: 1.15;
  }

  .project-report p,
  .project-report li,
  .project-report td,
  .project-report th {
    font-size: clamp(0.98rem, 1vw, 1.05rem);
    line-height: 1.6;
  }

  .project-report p,
  .project-report ul,
  .project-report ol {
    margin-bottom: var(--space-4);
  }

  .project-report ul,
  .project-report ol {
    padding-left: 1.25rem;
  }

  .project-report li + li {
    margin-top: 0.45rem;
  }

  .report-header {
    display: grid;
    gap: var(--space-4);
    border-bottom: var(--border-width) solid var(--color-border);
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .report-type,
  .meta-label {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .report-summary {
    max-width: 48rem;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    font-weight: 650;
  }

  .report-meta,
  .report-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .report-links,
  .appendix-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .report-links :global(a),
  .appendix-links :global(a),
  .status-table :global(a) {
    color: var(--plum);
    font-weight: 850;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .report-links :global(a),
  .appendix-links :global(a) {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.42rem 0.7rem;
    background: var(--color-surface-raised);
    text-decoration: none;
  }

  .technical-block {
    width: min(980px, calc(100vw - 2rem));
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .technical-groups {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--grid-gap);
    margin-bottom: var(--space-4);
  }

  .technical-group {
    border-top: 0.2rem solid var(--khaki);
    padding-top: var(--space-3);
  }

  .technical-group h3 {
    font-family: var(--font-sans);
    font-size: 1rem;
  }

  .wide-section {
    width: min(1040px, calc(100vw - 2rem));
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .status-table-wrap {
    overflow-x: auto;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .status-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }

  .status-table th,
  .status-table td {
    border-bottom: var(--border-width) solid var(--color-border);
    padding: 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .status-table thead th {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .status-table tbody tr:last-child th,
  .status-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .table-status {
    display: inline-flex;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.15rem 0.48rem;
    background: var(--color-surface-raised);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 850;
  }

  .working {
    color: var(--olive);
  }

  .prototype,
  .partial {
    color: var(--blue);
  }

  .experimental {
    color: var(--rust);
  }

  .planned,
  .not-built {
    color: var(--color-text-muted);
  }

  .step-list li {
    margin-bottom: var(--space-4);
  }

  .step-list p {
    margin: 0.2rem 0 0;
  }

  .learning-list {
    display: grid;
    gap: var(--space-4);
  }

  .learning-list article {
    border-left: 0.22rem solid var(--khaki);
    padding-left: var(--space-4);
  }

  .learning-list h3,
  .learning-list p {
    margin-bottom: var(--space-2);
  }

  .appendix-details {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .appendix-details details {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.9rem 1rem;
    background: var(--color-surface);
  }

  .appendix-details summary {
    cursor: pointer;
    font-weight: 850;
  }

  .appendix-details ul {
    margin-top: var(--space-3);
    margin-bottom: 0;
  }

  .current-direction {
    border-top: var(--border-width) solid var(--color-border);
    margin-top: clamp(2.5rem, 5vw, 4.5rem);
    padding-top: clamp(1.5rem, 3vw, 2rem);
  }

  .current-direction h2 {
    margin-top: 0;
    border-top: 0;
    padding-top: 0;
  }

  @media (max-width: 780px) {
    .technical-groups {
      grid-template-columns: 1fr;
    }

    .report-links :global(a),
    .appendix-links :global(a) {
      width: 100%;
      text-align: center;
    }
  }
</style>
