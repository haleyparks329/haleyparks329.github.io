---
type WritingEditorialRowEntry = {
  data: {
    title: string;
    description: string;
    pubDate: Date;
    status: "published" | "evolving" | "archived";
    relatedProject?: string;
  };
  href: string;
};

type Props = {
  entry: WritingEditorialRowEntry;
};

const { entry } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "2-digit",
  year: "numeric",
});

const projectLabels: Record<string, string> = {
  bridget: "Bridget",
  "career-intelligence": "Career Intelligence",
  "qa-agents": "QA Agents",
  website: "This Website",
};

const projectTone =
  entry.data.relatedProject === "career-intelligence"
    ? "career"
    : entry.data.relatedProject === "qa-agents"
      ? "qa"
      : entry.data.relatedProject === "bridget"
        ? "bridget"
        : "default";
const projectLabel = entry.data.relatedProject
  ? (projectLabels[entry.data.relatedProject] ?? entry.data.relatedProject)
  : undefined;
const statusLabel =
  entry.data.status.charAt(0).toUpperCase() + entry.data.status.slice(1);
---

<article class={`writing-editorial-card writing-editorial-card-${projectTone}`}>
  <div class="card-meta">
    <time datetime={entry.data.pubDate.toISOString().slice(0, 10)}>
      {dateFormatter.format(entry.data.pubDate)}
    </time>
    <span>{statusLabel}</span>
  </div>
  {projectLabel && <p class="project-marker">{projectLabel}</p>}
  <div class="card-article">
    <h2>
      <a href={entry.href}>{entry.data.title}</a>
    </h2>
    <p>{entry.data.description}</p>
  </div>
</article>

<style>
  .writing-editorial-card {
    --project-accent: var(--color-border-strong);
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: var(--space-3);
    border: var(--border-width) solid
      color-mix(in srgb, var(--project-accent) 22%, var(--color-border));
    border-top-width: 0.22rem;
    border-radius: var(--radius-md);
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    background: color-mix(in srgb, var(--color-surface) 88%, var(--paper));
    box-shadow: var(--shadow-paper);
    transition:
      background-color var(--motion-fast),
      border-color var(--motion-fast);
  }

  .writing-editorial-card-career {
    --project-accent: var(--olive);
  }

  .writing-editorial-card-qa {
    --project-accent: var(--blue);
  }

  .writing-editorial-card-bridget {
    --project-accent: var(--plum);
  }

  .writing-editorial-card:hover,
  .writing-editorial-card:focus-within {
    border-color: color-mix(
      in srgb,
      var(--project-accent) 48%,
      var(--color-border)
    );
    background: color-mix(
      in srgb,
      var(--project-accent) 4%,
      var(--color-surface)
    );
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .project-marker {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .project-marker::before {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--project-accent);
    content: "";
  }

  .card-article {
    min-width: 0;
  }

  h2 {
    max-width: 20ch;
    font-size: clamp(1.35rem, 2.15vw, 1.8rem);
    line-height: 1.12;
  }

  h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h2 a:hover,
  h2 a:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 0.06em;
    text-underline-offset: 0.14em;
  }

  .card-article > p {
    max-width: 42rem;
    margin-top: var(--space-3);
    color: var(--color-text-secondary);
    font-size: clamp(0.98rem, 1vw, 1.04rem);
    line-height: 1.58;
  }

  @media (max-width: 760px) {
    .writing-editorial-card {
      gap: var(--space-3);
      padding: var(--space-5);
    }
  }
</style>
