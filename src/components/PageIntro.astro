---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
  text?: string;
  meta?: string[];
  note?: string;
  accent?: "raspberry" | "olive" | "sky" | "lavender" | "ochre" | "plant";
  width?: "reading" | "standard" | "wide";
};

const {
  eyebrow,
  title,
  description,
  text,
  meta = [],
  note,
  accent = "raspberry",
  width = "standard",
} = Astro.props;

const mastheadDescription = description ?? text;
const supportingText = description ? text : undefined;
---

<header
  class={`page-intro page-intro-${accent} page-intro-${width} ${
    note ? "has-note" : ""
  }`}
>
  <div class="page-intro-title">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
  </div>
  <div class="page-intro-copy">
    {
      mastheadDescription && (
        <p class="page-intro-description">{mastheadDescription}</p>
      )
    }
    {supportingText && <p class="page-intro-text">{supportingText}</p>}
    {
      meta.length > 0 && (
        <ul class="metadata-row" aria-label={`${title} metadata`}>
          {meta.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
    {note && <p class="page-intro-note">{note}</p>}
  </div>
</header>

<style>
  .page-intro {
    --intro-accent: var(--accent-primary);
    display: grid;
    min-height: 26.5rem;
    grid-template-columns: minmax(16rem, 0.42fr) minmax(0, 0.58fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: start;
    border-bottom: var(--border-width) solid var(--color-border);
    padding-block: 5rem;
  }

  .page-intro-reading {
    width: min(var(--content-reading), 100%);
  }

  .page-intro-olive {
    --intro-accent: var(--olive);
  }

  .page-intro-sky {
    --intro-accent: var(--blue);
  }

  .page-intro-lavender {
    --intro-accent: var(--lavender);
  }

  .page-intro-ochre {
    --intro-accent: var(--khaki);
  }

  .page-intro-plant {
    --intro-accent: var(--houseplant);
  }

  .page-intro-title {
    border-top: 0.3rem solid var(--intro-accent);
    padding-top: var(--space-4);
  }

  h1 {
    max-width: 12ch;
    font-size: 5rem;
    font-weight: var(--weight-semibold);
    line-height: 0.95;
    letter-spacing: 0;
    text-wrap: nowrap;
    white-space: nowrap;
  }

  .page-intro-copy {
    display: grid;
    align-content: start;
    max-width: 38rem;
  }

  .page-intro-description {
    max-width: 34rem;
    margin: 0;
    color: var(--color-text);
    font-size: 1.75rem;
    line-height: 1.2;
  }

  .page-intro-text {
    max-width: 38rem;
    margin: var(--space-4) 0 0;
    color: var(--color-text-muted);
    font-size: var(--text-body);
    line-height: 1.55;
  }

  .page-intro :global(.metadata-row) {
    gap: 0.35rem;
    margin-top: var(--space-4);
  }

  .page-intro :global(.metadata-row li) {
    padding: 0.14rem 0.42rem;
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0;
  }

  .page-intro-note {
    position: relative;
    max-width: 15rem;
    margin: var(--space-5) 0 0;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    background: color-mix(
      in srgb,
      var(--intro-accent) 10%,
      var(--color-paper-clean)
    );
    box-shadow: var(--shadow-paper);
    color: var(--color-text);
    font-family: var(--font-hand);
    font-size: 1.05rem;
    line-height: 1.25;
  }

  @media (max-width: 760px) {
    .page-intro,
    .page-intro.has-note,
    .page-intro-wide {
      min-height: 0;
      grid-template-columns: 1fr;
      gap: var(--space-5);
      padding-block: 2.25rem 2.75rem;
    }

    h1 {
      max-width: 100%;
      font-size: 2.75rem;
      white-space: normal;
      text-wrap: balance;
    }

    .page-intro-description {
      font-size: 1.35rem;
    }

    .page-intro-note {
      max-width: 24rem;
    }
  }
</style>
