---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-intro">
      <p class="footer-title">{siteConfig.name}</p>
      <p>{siteConfig.role} based in {siteConfig.location}.</p>
      <p>{siteConfig.availability}</p>
    </div>
    <div class="footer-links">
      <nav aria-label="Footer site navigation">
        <p class="footer-label">Explore</p>
        <a href="/projects/">Projects</a>
        <a href="/field-log/">Field Log</a>
        <a href="/writing/">Writing</a>
        <a href="/about/">About</a>
      </nav>
      <nav aria-label="Footer contact navigation">
        <p class="footer-label">Connect</p>
        <a href={siteConfig.githubUrl}>GitHub</a>
        <a href={siteConfig.linkedinUrl}>LinkedIn</a>
        <a href={`mailto:${siteConfig.email}`}>Email</a>
      </nav>
    </div>
  </div>
  <div class="container footer-bottom">
    <p class="fine-print">
      {"(c) "}
      {year}
      {" "}
      {siteConfig.name}. Built with Astro and GitHub Pages.
    </p>
    <p class="desk-note">
      Haley stepped away for an iced matcha. The notes are safe to inspect.
    </p>
    <span class="pixel-cat" aria-hidden="true">
      <span class="pixel-cat-body"></span>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border-width) solid var(--color-border);
    background: var(--color-surface-band);
    color: var(--color-text-muted);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: var(--section-gap);
    padding-block: var(--space-8);
  }

  .footer-intro {
    max-width: 620px;
  }

  .footer-title {
    margin-bottom: 0.25rem;
    color: var(--color-text);
    font-weight: var(--font-weight-heavy);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
  }

  nav {
    display: grid;
    align-content: start;
    gap: 0.55rem;
  }

  nav a {
    color: var(--color-text);
    font-weight: 700;
  }

  .footer-label {
    margin-bottom: 0.1rem;
    color: var(--accent-secondary);
    font-size: var(--font-size-micro);
    font-weight: var(--font-weight-strong);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-bottom {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: var(--space-4);
    border-top: var(--border-width) solid var(--color-border);
    padding-block: var(--space-4);
  }

  .fine-print,
  .desk-note {
    margin: 0;
    font-size: 0.9rem;
  }

  .desk-note {
    grid-column: 1;
    color: var(--color-text-muted);
  }

  .pixel-cat {
    position: relative;
    grid-row: 1 / span 2;
    grid-column: 2;
    width: 44px;
    height: 32px;
    align-self: center;
  }

  .pixel-cat::before,
  .pixel-cat::after,
  .pixel-cat-body,
  .pixel-cat-body::before,
  .pixel-cat-body::after {
    position: absolute;
    content: "";
    image-rendering: pixelated;
  }

  .pixel-cat::before,
  .pixel-cat::after {
    top: 4px;
    width: 8px;
    height: 8px;
    background: var(--color-text);
  }

  .pixel-cat::before {
    left: 12px;
  }

  .pixel-cat::after {
    right: 12px;
  }

  .pixel-cat-body {
    right: 8px;
    bottom: 6px;
    width: 28px;
    height: 18px;
    border-radius: var(--radius-sm);
    background: var(--color-text);
  }

  .pixel-cat-body::before {
    top: 6px;
    left: 6px;
    width: 4px;
    height: 4px;
    background: var(--color-surface);
    box-shadow: 10px 0 0 var(--color-surface);
  }

  .pixel-cat-body::after {
    right: -8px;
    bottom: 4px;
    width: 12px;
    height: 4px;
    background: var(--color-text);
    box-shadow: 8px -4px 0 var(--color-text);
  }

  @media (max-width: 680px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-links {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .footer-bottom {
      grid-template-columns: 1fr;
    }

    .pixel-cat {
      grid-row: auto;
      grid-column: 1;
      justify-self: start;
    }
  }
</style>
