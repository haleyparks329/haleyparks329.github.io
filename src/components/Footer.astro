---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="interior-container footer-shell">
    <div class="footer-intro">
      <p class="footer-title">{siteConfig.name}</p>
      <p>{siteConfig.role} · {siteConfig.location}</p>
    </div>
    <div class="footer-rails">
      <nav aria-label="Footer site navigation" class="footer-links">
        <a href="/projects/">Projects</a>
        <a href="/field-log/">Field Log</a>
        <a href="/writing/">Writing</a>
        <a href="/about/">About</a>
      </nav>
      <nav aria-label="Footer contact navigation" class="footer-links">
        <a href={siteConfig.githubUrl}>GitHub</a>
        <a href={siteConfig.linkedinUrl}>LinkedIn</a>
        <a href={`mailto:${siteConfig.email}`}>Email</a>
      </nav>
    </div>
    <p class="desk-note">Iced matcha nearby. Notes still open.</p>
    <p class="fine-print">{"(c) "}{year} {siteConfig.name}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border-width) solid var(--color-border);
    background: var(--color-surface-band);
    color: var(--color-text-muted);
  }

  .footer-shell {
    display: grid;
    grid-template-areas:
      "intro rails"
      "fine note";
    grid-template-columns: minmax(0, 1fr) minmax(20rem, auto);
    gap: var(--space-5);
    align-items: center;
    padding-block: var(--space-5);
  }

  .footer-intro {
    grid-area: intro;
    min-width: 0;
  }

  .footer-title {
    margin-bottom: 0.25rem;
    color: var(--color-text);
    font-weight: var(--font-weight-heavy);
  }

  .footer-intro p {
    margin-bottom: 0;
  }

  .footer-rails {
    grid-area: rails;
    display: grid;
    justify-items: end;
    gap: 0.45rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.8rem;
  }

  .footer-links a {
    color: var(--color-text);
    font-size: var(--font-size-small);
    font-weight: 750;
  }

  .fine-print,
  .desk-note {
    margin: 0;
    font-size: 0.9rem;
  }

  .fine-print {
    grid-area: fine;
  }

  .desk-note {
    grid-area: note;
    justify-self: end;
    color: var(--rust);
    font-family: var(--font-hand);
  }

  @media (max-width: 680px) {
    .footer-shell {
      grid-template-areas:
        "intro"
        "rails"
        "note"
        "fine";
      grid-template-columns: 1fr;
      align-items: start;
    }

    .footer-rails,
    .footer-links,
    .desk-note {
      justify-items: start;
      justify-content: flex-start;
      justify-self: start;
    }
  }
</style>
