---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-title">{siteConfig.name}</p>
      <p>{siteConfig.role} based in {siteConfig.location}.</p>
    </div>
    <nav aria-label="Footer navigation">
      <a href="/projects/">Projects</a>
      <a href="/writing/">Writing</a>
      <a href={siteConfig.githubUrl}>GitHub</a>
      <a href={siteConfig.linkedinUrl}>LinkedIn</a>
      <a href={`mailto:${siteConfig.email}`}>Email</a>
    </nav>
  </div>
  <p class="container fine-print">
    {"(c) "}
    {year}
    {" "}
    {siteConfig.name}. Built with Astro and GitHub Pages.
  </p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding-block: 2rem;
    color: var(--muted);
  }

  .footer-grid {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer-title {
    margin-bottom: 0.25rem;
    color: var(--ink);
    font-weight: 850;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  nav a {
    color: var(--ink);
    font-weight: 700;
  }

  .fine-print {
    margin-top: 1.5rem;
    font-size: 0.9rem;
  }

  @media (max-width: 680px) {
    .footer-grid {
      flex-direction: column;
    }
  }
</style>
