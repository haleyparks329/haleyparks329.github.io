---
import type { CollectionEntry } from "astro:content";
import ExternalLink from "./ExternalLink.astro";
import StatusBadge from "./StatusBadge.astro";
import TagList from "./TagList.astro";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const data = project.data;
const visibleTags = data.tags.slice(0, 2);
const projectNotesLabel = "Case Study";
const repositoryLabel = "Repository";
const demoHref =
  data.slug === "qa-agents" ? "/projects/qa-agents/demo/" : undefined;
const objectNotes: Record<string, string> = {
  "the-human-model": "the long-running one",
  "career-intelligence": "filed under: evidence first",
  "qa-agents": "recorded evidence loop",
};
const toneClass =
  data.slug === "the-human-model"
    ? "surface-raspberry is-dominant"
    : data.slug === "career-intelligence"
      ? "surface-olive"
      : "surface-sky";
---

<article
  class={`project-card workspace-object ${toneClass} project-${data.slug}`}
>
  <p class="workspace-note">{objectNotes[data.slug]}</p>
  <div class="project-card-top">
    <StatusBadge status={data.status} accent={data.accent} />
    <h3>{data.title}</h3>
  </div>
  <div class={`project-motif motif-${data.slug}`} aria-hidden="true">
    {
      data.slug === "the-human-model" && (
        <>
          <span />
          <span />
          <span />
          <span />
        </>
      )
    }
    {
      data.slug === "career-intelligence" && (
        <>
          <span>evidence</span>
          <span>capability</span>
          <span>fit</span>
          <span>opportunity</span>
        </>
      )
    }
    {
      data.slug === "qa-agents" && (
        <>
          <span>change</span>
          <span>test</span>
          <span>gap</span>
          <span>review</span>
        </>
      )
    }
  </div>
  <p>{data.summary}</p>
  <p class="question">
    <strong>Question:</strong>
    {" "}
    {data.coreQuestion}
  </p>
  <div class="project-tags">
    <TagList tags={visibleTags} />
  </div>
  <div class="card-links">
    <a href={`/projects/${data.slug}/`}>{projectNotesLabel}</a>
    {
      data.repositoryUrl && (
        <ExternalLink href={data.repositoryUrl} label={repositoryLabel} />
      )
    }
    {demoHref && <a href={demoHref}>Demo</a>}
  </div>
</article>

<style>
  .project-card {
    --card-accent: var(--khaki);
    --card-mark: var(--card-accent);
    display: grid;
    height: auto;
    min-height: 0;
    align-self: start;
    gap: 0.68rem;
    padding: clamp(0.9rem, 1.2vw, 1.1rem);
    overflow: visible;
  }

  .project-card::before {
    position: absolute;
    top: 1rem;
    bottom: 1rem;
    left: 0;
    width: 0.34rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    background: var(--card-accent);
    content: "";
  }

  .project-card::after {
    left: 1.4rem;
    right: auto;
  }

  .rust {
    --card-accent: var(--rust);
    --card-mark: var(--houseplant);
  }

  .olive {
    --card-accent: var(--olive);
    --card-mark: var(--khaki);
  }

  .blue {
    --card-accent: var(--blue);
    --card-mark: var(--khaki);
  }

  .plum {
    --card-accent: var(--plum);
  }

  .khaki {
    --card-accent: var(--khaki);
  }

  .project-card-top {
    display: grid;
    gap: 0.62rem;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 1.8vw, 1.8rem);
    line-height: 1.04;
  }

  p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .project-motif {
    display: grid;
    min-height: 2.8rem;
    align-items: end;
    border-block: var(--border-width) solid var(--color-border);
    padding-block: 0.55rem;
  }

  .motif-the-human-model {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .motif-the-human-model span {
    position: relative;
    height: 2.5rem;
    border-bottom: 2px solid var(--card-accent);
  }

  .project-the-human-model {
    --card-accent: var(--rust);
    --card-mark: var(--houseplant);
    --object-tilt: -0.45deg;
    border-left: 0.5rem solid var(--rust);
  }

  .project-the-human-model h3 {
    font-size: clamp(1.55rem, 2vw, 2rem);
  }

  .project-career-intelligence {
    --card-accent: var(--olive);
    --card-mark: var(--khaki);
    --object-tilt: 0.55deg;
  }

  .project-career-intelligence::after {
    transform: rotate(2deg);
  }

  .project-qa-agents {
    --card-accent: var(--blue);
    --card-mark: var(--khaki);
    --object-tilt: -0.25deg;
    background-image:
      linear-gradient(rgba(79, 134, 168, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 134, 168, 0.1) 1px, transparent 1px);
    background-size: 1rem 1rem;
  }

  .motif-the-human-model span::before {
    position: absolute;
    bottom: calc(var(--i, 1) * 0.55rem);
    left: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--card-mark);
    content: "";
  }

  .motif-the-human-model span:nth-child(1) {
    --i: 1;
  }

  .motif-the-human-model span:nth-child(2) {
    --i: 3;
  }

  .motif-the-human-model span:nth-child(3) {
    --i: 2;
  }

  .motif-the-human-model span:nth-child(4) {
    --i: 5;
  }

  .motif-career-intelligence,
  .motif-qa-agents {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
    align-items: center;
  }

  .motif-career-intelligence span,
  .motif-qa-agents span {
    position: relative;
    border: var(--border-width) solid
      color-mix(in srgb, var(--card-accent) 45%, var(--color-border));
    border-radius: var(--radius-sm);
    padding: 0.36rem 0.3rem;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 800;
    text-align: center;
  }

  .motif-career-intelligence span:not(:last-child)::after,
  .motif-qa-agents span:not(:last-child)::after {
    position: absolute;
    top: 50%;
    right: -0.46rem;
    width: 0.46rem;
    height: 2px;
    background: var(--card-mark);
    content: "";
  }

  .motif-qa-agents span:nth-child(2) {
    background: color-mix(in srgb, var(--houseplant) 14%, transparent);
  }

  .motif-qa-agents span:nth-child(3) {
    background: color-mix(in srgb, var(--khaki) 18%, transparent);
  }

  .question {
    margin: 0;
    border-top: var(--border-width) solid var(--color-border);
    padding-top: 0.45rem;
    color: var(--color-text);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0;
    padding-top: 0.05rem;
    font-weight: var(--font-weight-strong);
  }

  .card-links a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    border: var(--border-width) solid
      color-mix(in srgb, var(--card-accent) 40%, var(--color-border));
    border-radius: var(--radius-md);
    padding: 0.38rem 0.55rem;
    background: rgba(255, 248, 239, 0.5);
    color: var(--color-text);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .card-links a:hover {
    border-color: var(--card-accent);
    color: var(--color-text);
  }

  .project-card > p,
  .project-card > .question,
  .project-tags {
    max-width: 38rem;
  }

  .project-card > p {
    font-size: 0.92rem;
    line-height: 1.45;
  }

  @media (max-width: 680px) {
    .project-card {
      min-height: auto;
      transform: none;
    }

    .motif-career-intelligence,
    .motif-qa-agents {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
