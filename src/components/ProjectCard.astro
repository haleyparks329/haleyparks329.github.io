---
import type { CollectionEntry } from "astro:content";
import ExternalLink from "./ExternalLink.astro";
import StatusBadge from "./StatusBadge.astro";
import TagList from "./TagList.astro";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const data = project.data;
---

<article class={`project-card ${data.accent}`}>
  <div class="project-card-top">
    <StatusBadge status={data.status} accent={data.accent} />
    <h3>{data.title}</h3>
  </div>
  <p>{data.summary}</p>
  <p class="question">
    <strong>Question:</strong>
    {" "}
    {data.coreQuestion}
  </p>
  <TagList tags={data.tags} />
  <div class="card-links">
    <a href={`/projects/${data.slug}/`}>Read project notes</a>
    {
      data.repositoryUrl && (
        <ExternalLink href={data.repositoryUrl} label="Repository" />
      )
    }
  </div>
</article>

<style>
  .project-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: var(--space-4);
    border: var(--border-width) solid var(--color-border);
    border-top: var(--border-accent) solid var(--khaki);
    border-radius: var(--radius-md);
    padding: 1.15rem;
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .rust {
    border-top-color: var(--rust);
  }

  .olive {
    border-top-color: var(--olive);
  }

  .blue {
    border-top-color: var(--blue);
  }

  .plum {
    border-top-color: var(--plum);
  }

  .khaki {
    border-top-color: var(--khaki);
  }

  .project-card-top {
    display: grid;
    gap: 0.8rem;
  }

  p {
    color: var(--color-text-muted);
  }

  .question {
    border-top: var(--border-width) solid var(--color-border);
    padding-top: 0.85rem;
    color: var(--color-text);
    font-size: 0.98rem;
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 0.5rem;
    font-weight: var(--font-weight-strong);
  }
</style>
