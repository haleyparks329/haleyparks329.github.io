---
type Props = {
  eyebrow?: string;
  title: string;
  text?: string;
};

const { eyebrow, title, text } = Astro.props;
---

<div class="section-heading">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>

<style>
  .section-heading {
    max-width: 760px;
  }

  p:not(.eyebrow) {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }
</style>
