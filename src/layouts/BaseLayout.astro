---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { siteConfig } from "@/site.config";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  imagePath?: string;
};

const {
  title = siteConfig.name,
  description = siteConfig.description,
  canonicalPath = Astro.url.pathname,
  imagePath = "/og-image.svg",
} = Astro.props;

const pageTitle =
  title === siteConfig.name
    ? `${siteConfig.name} | ${siteConfig.role}`
    : `${title} | ${siteConfig.name}`;
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const imageUrl = new URL(imagePath, siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="theme-color" content="#fff8ef" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="A warm desk-like portfolio surface for Haley Parks' public projects."
    />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
