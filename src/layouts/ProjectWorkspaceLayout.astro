---
import type { CollectionEntry } from "astro:content";
import ProjectEmblem from "@/components/ProjectEmblem.astro";
import ProjectSidebar from "@/components/ProjectSidebar.astro";
import StatusBadge from "@/components/StatusBadge.astro";
import type { ProjectWorkspaceConfig } from "@/data/project-workspaces";

type Props = {
  project: CollectionEntry<"projects">;
  workspace: ProjectWorkspaceConfig;
  documentTitle: string;
  documentSummary: string;
};

const { project, workspace, documentTitle, documentSummary } = Astro.props;
const data = project.data;
---

<section
  class={`project-workspace site-shell project-workspace-${data.accent}`}
>
  <header class="project-workspace-header">
    <ProjectEmblem slug={data.slug} size="large" />
    <div class="project-heading">
      <p class="project-file-label">{workspace.projectType}</p>
      <h1>{data.title}</h1>
      <p class="project-summary">{workspace.headerSummary}</p>
      <div class="project-meta" aria-label={`${data.title} metadata`}>
        <StatusBadge status={data.status} accent={data.accent} />
      </div>
    </div>
    <aside class="current-state" aria-label={`${data.title} current work`}>
      <p>Currently on the desk</p>
      <span>{workspace.currentNote}</span>
    </aside>
  </header>

  <div class="project-mobile-nav">
    <ProjectSidebar workspace={workspace} projectTitle={data.title} mobile />
  </div>

  <div class="project-workspace__layout">
    <ProjectSidebar workspace={workspace} projectTitle={data.title} />
    <section
      class="project-workspace__main"
      aria-labelledby="project-document-title"
    >
      <header class="project-document-header">
        <p>{workspace.annotation}</p>
        <h2 id="project-document-title">{documentTitle}</h2>
        <span>{documentSummary}</span>
      </header>
      <slot />
    </section>
  </div>
</section>

<style>
  .project-workspace {
    --workspace-accent: var(--rust);
    padding-block: clamp(1.75rem, 4vw, 3rem) var(--space-section);
  }

  .project-workspace-olive {
    --workspace-accent: var(--olive);
  }

  .project-workspace-blue {
    --workspace-accent: var(--blue);
  }

  .project-workspace-plum {
    --workspace-accent: var(--plum);
  }

  .project-workspace-khaki {
    --workspace-accent: var(--khaki);
  }

  .project-workspace-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(15rem, 0.34fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
    border-bottom: var(--border-width) solid var(--color-border);
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .project-heading {
    display: grid;
    gap: var(--space-3);
    min-width: 0;
  }

  .project-file-label,
  .current-state p,
  .project-document-header p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    max-width: 14ch;
    font-size: clamp(2.25rem, 4.6vw, 4.2rem);
    line-height: 0.98;
  }

  .project-summary {
    max-width: var(--reading-measure);
    margin: 0;
    color: var(--color-text-secondary);
    font-size: clamp(1.02rem, 1.5vw, 1.16rem);
    line-height: 1.48;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .current-state {
    display: grid;
    gap: var(--space-2);
    border: var(--border-width) solid
      color-mix(in srgb, var(--workspace-accent) 28%, var(--color-border));
    border-radius: var(--radius-md);
    padding: var(--space-4);
    background: color-mix(in srgb, var(--workspace-accent) 10%, var(--paper));
    box-shadow: var(--shadow-paper);
  }

  .current-state span {
    color: var(--color-text-secondary);
    font-size: 0.94rem;
    line-height: 1.5;
  }

  .project-mobile-nav {
    display: none;
    margin-top: var(--space-5);
  }

  .project-workspace__layout {
    display: grid;
    grid-template-columns: minmax(220px, 270px) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
    margin-top: clamp(1.5rem, 4vw, 3rem);
  }

  .project-workspace__main {
    min-width: 0;
  }

  .project-document-header {
    display: grid;
    gap: var(--space-2);
    max-width: var(--reading-measure-wide);
    border-bottom: var(--border-width) solid var(--color-border);
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
    padding-bottom: var(--space-5);
  }

  .project-document-header h2 {
    font-size: clamp(1.55rem, 2.4vw, 2.25rem);
    line-height: 1.05;
  }

  .project-document-header span {
    max-width: var(--reading-measure);
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .project-workspace-header {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .current-state {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 800px) {
    .project-mobile-nav {
      display: block;
    }

    .project-workspace__layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .project-workspace-header {
      grid-template-columns: 1fr;
    }
  }
</style>
