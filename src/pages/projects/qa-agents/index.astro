---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { relatedLinksForHrefs } from "@/data/navigation";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
const continueLinks = relatedLinksForHrefs(
  [
    "/projects/qa-agents/live/",
    "/projects/qa-agents/system/",
    "/projects/qa-agents/demo/",
    "/projects/qa-agents/meticulous/",
    "/explore/",
  ],
  "project-qa-agents",
);
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/qa-agents/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="Overview"
    documentSummary="What QA Agents is exploring and how the public project keeps evidence, uncertainty, and human review visible."
  >
    <ProjectDocumentContent
      abstract={document.abstract}
      why={document.why}
      actuallyDoes={document.actuallyDoes}
      links={document.links}
      continueLinks={continueLinks}
      nextHref="/projects/qa-agents/system/"
      nextLabel="Open the system file"
    />
    <aside class="live-review-callout">
      <p class="eyebrow">Real website evidence</p>
      <h2>See QA Agents reviewing this website.</h2>
      <p>
        The live system review shows the latest exported deterministic evidence.
        It is separate from the recorded product demo, and it keeps known
        coverage gaps visible.
      </p>
      <a class="button secondary" href="/projects/qa-agents/live/"
        >View the latest live system review</a
      >
    </aside>
  </ProjectWorkspaceLayout>
</BaseLayout>

<style>
  .live-review-callout {
    margin-top: 2rem;
    border: 1px solid var(--accent-tertiary-border);
    border-radius: 10px;
    padding: clamp(1rem, 4vw, 1.5rem);
    background: linear-gradient(
      135deg,
      var(--project-paper-blue),
      rgba(255, 249, 241, 0.8)
    );
  }
  .live-review-callout h2 {
    margin: 0.25rem 0 0.5rem;
  }
  .live-review-callout p:not(.eyebrow) {
    max-width: 42rem;
  }
</style>
