          <li><span>✓</span> Existing tests passed</li>
          <li class="warning"><span>⚠</span> New behavior remained untested</li>
          <li><span>✓</span> Gap recorded as evidence</li>
          <li><span>→</span> Regression test recommended</li>
        </ol>
        <div class="result-boundary">
          <p>The investigation is complete.</p>
          <p>The decision isn't.</p>
          <p>
            The evidence is ready for a human reviewer to decide what happens
            next.
          </p>
        </div>
        <a class="retro-ok" href="#replay-workstation">OK</a>
      </div>
    </section>

    <p class="safety-note" id="recorded-replay-note">
      This workstation is a static interface around one canonical artifact. It
      does not start a browser session, dispatch an agent, generate code, or run
      tests.
    </p>

    <section
      class="technical-details"
      id="technical-details"
      aria-label="Technical details"
    >
      <details>
        <summary>Canonical artifact</summary>
        <dl>
          <dt>Local artifact path</dt>
          <dd><code>{artifactPath}</code></dd>
          <dt>Repository artifact path</dt>
          <dd><code>examples/demo-runs/little-bytes-pricing.json</code></dd>
          <dt>Schema version</dt>
          <dd>{artifact.schema_version}</dd>
          <dt>Demo ID</dt>
          <dd><code>{artifact.demo_id}</code></dd>
        </dl>
      </details>

      <details>
        <summary>Provenance</summary>
        <dl>
          <dt>Application</dt>
          <dd>{artifact.application.name}</dd>
          <dt>Application repository</dt>
          <dd><code>{artifact.application.repository}</code></dd>
          <dt>Application profile</dt>
          <dd><code>{artifact.application.profile}</code></dd>
          <dt>Base branch</dt>
          <dd><code>{artifact.scenario.base}</code></dd>
          <dt>Head branch</dt>
          <dd><code>{artifact.scenario.head}</code></dd>
        </dl>
      </details>

      <details>
        <summary>Raw replay data</summary>
        <pre><code>{rawArtifact}</code></pre>
      </details>

      <details>
        <summary>Safety boundaries</summary>
        <dl>
          {
            safetyItems.map(([label, value]) => (
              <>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </>
            ))
          }
        </dl>
      </details>
    </section>
  </section>

  <script is:inline define:vars={{ stepDetails, defaultStepIndex }}>
    const root = document.querySelector("[data-replay-root]");
    const buttons = Array.from(document.querySelectorAll("[data-step-button]"));
    const panels = Array.from(document.querySelectorAll("[data-step-panel]"));
    const stateLabels = Array.from(
      document.querySelectorAll("[data-step-state]"),
    );
    const sessionStep = document.querySelector("[data-session-step]");
    const gapNote = document.querySelector("[data-gap-note]");
    const storyEmoji = document.querySelector("[data-story-emoji]");
    const storyActor = document.querySelector("[data-story-actor]");
    const storyEvidence = document.querySelector("[data-story-evidence]");
    const storyHeading = document.querySelector("[data-story-heading]");
    const storyBody = document.querySelector("[data-story-body]");
    const storyBoundary = document.querySelector("[data-story-boundary]");
    const storyHandoff = document.querySelector("[data-story-handoff]");
    const previous = document.querySelector("[data-step-prev]");
    const next = document.querySelector("[data-step-next]");
    let activeIndex = defaultStepIndex;

    function stateFor(index) {
      if (index < activeIndex) return "completed";
      if (index === activeIndex) return "active";
      return "upcoming";
    }

    function setActiveStep(index) {
      activeIndex = (index + stepDetails.length) % stepDetails.length;

      buttons.forEach((button, buttonIndex) => {
        const state = stateFor(buttonIndex);
        const isActive = buttonIndex === activeIndex;
        button.classList.toggle("is-completed", state === "completed");
        button.classList.toggle("is-active", isActive);
        button.classList.toggle("is-upcoming", state === "upcoming");
        button.setAttribute("aria-pressed", String(isActive));
        if (isActive) {
          button.setAttribute("aria-current", "step");
        } else {
          button.removeAttribute("aria-current");
        }
      });

      panels.forEach((panel, panelIndex) => {
        const isActive = panelIndex === activeIndex;
        panel.classList.toggle("is-active", isActive);
        panel.hidden = !isActive;
      });

      stateLabels.forEach((label, labelIndex) => {
        const state = stateFor(labelIndex);
        label.textContent = state.charAt(0).toUpperCase() + state.slice(1);
      });

      if (sessionStep) {
        sessionStep.textContent = `Step ${activeIndex + 1} of ${stepDetails.length}`;
      }

      gapNote?.classList.toggle(
        "is-muted",
        stepDetails[activeIndex]?.id !== "coverage",
      );

      const story = stepDetails[activeIndex]?.story;
      if (story) {
        if (storyEmoji) storyEmoji.textContent = story.emoji;
        if (storyActor) storyActor.textContent = story.actor;
        if (storyHeading) storyHeading.textContent = story.heading;
        if (storyBody) storyBody.textContent = story.body;
        if (storyHandoff) storyHandoff.textContent = story.handoff;

        if (storyEvidence) {
          storyEvidence.textContent = story.evidenceLabel || "";
          storyEvidence.hidden = !story.evidenceLabel;
        }

        if (storyBoundary) {
          storyBoundary.textContent = story.boundary || "";
          storyBoundary.hidden = !story.boundary;
        }
      }
    }

    root?.classList.add("is-enhanced");
    buttons.forEach((button, index) => {
      button.addEventListener("click", () => setActiveStep(index));
    });
    previous?.addEventListener("click", () => setActiveStep(activeIndex - 1));
    next?.addEventListener("click", () => setActiveStep(activeIndex + 1));
  </script>
</BaseLayout>

