---
import { getCollection } from "astro:content";
import demoArtifact from "@/data/qa-agents/little-bytes-pricing.json";
import EvidenceReplay from "@/components/qa-agents/EvidenceReplay.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const repositoryUrl = project.data.repositoryUrl;
const canonicalArtifactUrl = repositoryUrl
  ? `${repositoryUrl}/blob/main/examples/demo-runs/little-bytes-pricing.json`
  : undefined;
const rawArtifact = JSON.stringify(demoArtifact, null, 2);
const diffLines = demoArtifact.change.diff_excerpt.split("\n");
---

<EvidenceReplay
  pageTitle="QA Replay Workstation"
  pageDescription="Recorded QA Agents investigation replay for the Little Bytes pricing scenario."
  canonicalPath="/projects/qa-agents/demo/"
  eyebrow="Recorded investigation replay"
  titleLines={[
    "The tests passed.",
    "The new pricing behavior still wasn't tested.",
  ]}
  lede="This replay exists for the uncomfortable little gap between CI is green and the new behavior is actually protected."
  safetyNote="Static replay from a canonical Little Bytes artifact. No live browser session, autonomous code change, or hidden agent execution is occurring on this page."
  links={[
    { href: "/projects/qa-agents/", label: "Main QA Agents page" },
    ...(repositoryUrl
      ? [{ href: repositoryUrl, label: "QA Agents repository", external: true }]
      : []),
    ...(canonicalArtifactUrl
      ? [
          {
            href: canonicalArtifactUrl,
            label: "Canonical artifact",
            external: true,
          },
        ]
      : []),
  ]}
  caseSummary={[
    {
      label: "Repository",
      value: demoArtifact.application.name.toLowerCase().replace(/\s+/g, "-"),
    },
    { label: "Branch", value: demoArtifact.scenario.head },
    { label: "Outcome", value: "Coverage gap found" },
    { label: "Action", value: "Regression test recommended" },
  ]}
  storyIntro={{
    eyebrow: "The story behind the evidence",
    heading: "A green test run is not the end of the story.",
    paragraphs: [
      "Imagine you are reviewing a pull request. The pricing logic changed, the existing tests still pass, and it would be easy to move on.",
      "QA Agents keeps looking. Lookout notices the change. Beacon checks the existing tests. Inspector reviews the coverage gap. Scribe recommends what to do next.",
    ],
    explanation:
      "I could have recorded a terminal session, but watching someone click around does not explain the investigation very well. This workstation reconstructs the evidence so you can inspect the reasoning step by step.",
  }}
  castTitle="Who's investigating?"
  cast={[
    "🔭 Lookout notices relevant changes",
    "🧭 Beacon scopes and verifies the investigation",
    "🔍 Inspector reviews coverage and records gaps",
    "✍️ Scribe recommends or authors accepted tests",
    "👩‍💻 A human reviewer decides",
  ]}
  sessionMeta={[
    demoArtifact.application.name.toLowerCase().replace(/\s+/g, "-"),
    demoArtifact.scenario.head,
  ]}
  gapNote="tests passed ≠ behavior tested"
  defaultStepIndex={0}
  steps={[
    {
      id: "change",
      timelineLabel: "Change detected",
      panelTitle: "Pricing diff",
      windowTitle: "pricing.py",
      icon: "▤",
      accent: "sky",
      notebook: {
        heading: "Pricing logic changed",
        observation:
          "The pricing code changed in a branch that affects discount handling.",
        interpretation: `${demoArtifact.change.diff_summary} in ${demoArtifact.change.files.join(", ")}. That is enough to ask a simple QA question: did the tests actually reach this new path?`,
        why: "Any new branch in business logic deserves coverage, especially when it changes money-related behavior.",
      },
      story: {
        actor: "Lookout",
        emoji: "🔭",
        heading: "Lookout spotted the changed pricing file.",
        body: "The pricing module changed. Beacon takes the next look.",
        handoff: "Passing investigation → Beacon",
      },
      panel: {
        kind: "diff",
        diffBadges: [demoArtifact.change.files.join(", "), "+6", "-1"],
        facts: [
          {
            label: "Filename",
            value: demoArtifact.change.files.join(", "),
            code: true,
          },
          {
            label: "Diff summary",
            value: demoArtifact.change.diff_summary,
            code: true,
          },
          {
            label: "Changed path",
            value: demoArtifact.evidence.gap_path,
            code: true,
          },
        ],
        diffLines,
        diffNote: "coverage gap associated with changed pricing path",
      },
    },
    {
      id: "tests",
      timelineLabel: "Tests passed",
      panelTitle: "Test execution result",
      windowTitle: "unit-tests.log",
      icon: "✓",
      accent: "sage",
      notebook: {
        heading: "Existing tests passed",
        observation:
          "The current test suite still reports a clean pass after the pricing change.",
        interpretation:
          "A green test run means the old assertions still hold. It does not prove the new pricing path was exercised.",
        why: "Engineers care because CI can look healthy while a new branch has no real protection.",
      },
      story: {
        actor: "Beacon",
        emoji: "🧭",
        heading: "Beacon checked the existing tests.",
        body: "The existing tests all passed. Now Beacon checks what they actually covered.",
        handoff: "Checking coverage evidence",
      },
      panel: {
        kind: "command",
        statusLabel: "PASS",
        facts: [
          {
            label: "Command",
            value: demoArtifact.execution.command_name,
            code: true,
          },
          {
            label: "Status",
            value: demoArtifact.execution.status,
            tone: "success",
          },
          { label: "Exit status", value: demoArtifact.execution.exit_code },
          {
            label: "Output excerpt",
            value: demoArtifact.execution.test_summary,
          },
        ],
      },
    },
    {
      id: "coverage",
      timelineLabel: "Gap discovered",
      panelTitle: "Coverage evidence",
      windowTitle: "coverage-report.json",
      icon: "⌕",
      accent: "ochre",
      notebook: {
        heading: "New behavior was not exercised",
        observation:
          "Coverage links the passing test run back to the changed pricing file.",
        interpretation:
          "The tests passed, but the changed branch was not reached. That is a verification gap, not a product bug by itself.",
        why: "This is the core lesson: tests only protect behavior they execute.",
      },
      story: {
        actor: "Inspector",
        emoji: "🔍",
        heading: "Inspector found the missing coverage.",
        body: "Coverage showed the changed pricing path was never reached.",
        handoff: "Recording the verification gap",
        evidenceLabel: "📊 Coverage evidence",
      },
      panel: {
        kind: "inspection",
        headerTitle: "Coverage report",
        headerText: "Inspection summary for the changed pricing path.",
        facts: [
          {
            label: "Coverage report captured",
            value: String(demoArtifact.evidence.coverage_report_found),
            tone: "success",
          },
          {
            label: "Affected file",
            value: demoArtifact.evidence.gap_path,
            code: true,
          },
          {
            label: "Finding",
            value: "Changed pricing branch was never executed",
          },
          {
            label: "Artifact",
            value: demoArtifact.evidence.coverage_report_path,
            code: true,
          },
          { label: "Recorded gap", value: demoArtifact.evidence.gap_detail },
        ],
        diffNote: "coverage gap associated with changed pricing path",
      },
    },
    {
      id: "recorded",
      timelineLabel: "Evidence recorded",
      panelTitle: "Persisted gap record",
      windowTitle: "gap-record.json",
      icon: "▣",
      accent: "burgundy",
      notebook: {
        heading: "The gap was recorded",
        observation:
          "The finding is no longer just a transient test-run detail.",
        interpretation:
          "The affected file, gap type, and supporting detail are preserved in a small reviewable record.",
        why: "This matters because handoffs fail when evidence lives only in terminal scrollback or someone's memory.",
      },
      story: {
        actor: "Inspector",
        emoji: "🔍",
        heading: "Inspector saved the gap.",
        body: "The missing test is now a reviewable record, not a disappearing note.",
        handoff: "Next reviewer → Scribe",
      },
      panel: {
        kind: "record",
        facts: [
          {
            label: "Gap type",
            value: demoArtifact.evidence.gap_type.replace(/_/g, " "),
          },
          { label: "Affected area", value: "Pricing logic" },
          { label: "Affected file", value: demoArtifact.evidence.gap_path },
          { label: "Status", value: "Open for review" },
          { label: "Detail", value: demoArtifact.evidence.gap_detail },
        ],
      },
    },
    {
      id: "recommendation",
      timelineLabel: "Test recommended",
      panelTitle: "Recommendation artifact",
      windowTitle: "recommendation.md",
      icon: "✎",
      accent: "lavender",
      notebook: {
        heading: "Add a regression test",
        observation:
          "The recommendation is narrow: add a regression test for quantity and discount ordering.",
        interpretation:
          "The proposed test targets the exact behavior the current suite missed. It does not claim any code was written.",
        why: "Good QA output should make the next human decision easier, not pretend the decision has already been made.",
        boundary:
          "Recommendation only. No test was authored or committed during this replay.",
      },
      story: {
        actor: "Scribe",
        emoji: "✍️",
        heading: "Scribe recommended the next step.",
        body: "Add a regression test before treating this pricing behavior as verified.",
        handoff: "Ready for human review",
        boundary:
          "Recommendation only. No test was authored or committed during this replay.",
      },
      panel: {
        kind: "recommendation",
        statusLabel: "recommendation only",
        action: demoArtifact.recommendation.next_action,
        facts: [
          { label: "Target behavior", value: "Quantity and discount ordering" },
          {
            label: "Suggested agent",
            value: demoArtifact.recommendation.agent,
          },
          {
            label: "Route reason",
            value: demoArtifact.recommendation.route_reason,
          },
          {
            label: "Supporting evidence",
            value: demoArtifact.evidence.gap_path,
            code: true,
          },
        ],
      },
    },
  ]}
  result={{
    eyebrow: "Investigation result",
    heading: "Human review required",
    story: [
      "Pricing logic changed.",
      "Existing tests still passed.",
      "Coverage showed the new path wasn't exercised.",
      "A regression test was recommended.",
    ],
    items: [
      { marker: "✓", text: "Pricing change detected" },
      { marker: "✓", text: "Existing tests passed" },
      { marker: "⚠", text: "New behavior remained untested", warning: true },
      { marker: "✓", text: "Gap recorded as evidence" },
      { marker: "→", text: "Regression test recommended" },
    ],
    boundary: [
      "The investigation is complete.",
      "The decision isn't.",
      "The evidence is ready for a human reviewer to decide what happens next.",
    ],
  }}
  recordedReplayNote="This workstation is a static interface around one canonical artifact. It does not start a browser session, dispatch an agent, generate code, or run tests."
  technicalDetails={[
    {
      summary: "Canonical artifact",
      items: [
        {
          label: "Local artifact path",
          value: "src/data/qa-agents/little-bytes-pricing.json",
          code: true,
        },
        {
          label: "Repository artifact path",
          value: "examples/demo-runs/little-bytes-pricing.json",
          code: true,
        },
        { label: "Schema version", value: demoArtifact.schema_version },
        { label: "Demo ID", value: demoArtifact.demo_id, code: true },
      ],
    },
    {
      summary: "Provenance",
      items: [
        { label: "Application", value: demoArtifact.application.name },
        {
          label: "Application repository",
          value: demoArtifact.application.repository,
          code: true,
        },
        {
          label: "Application profile",
          value: demoArtifact.application.profile,
          code: true,
        },
        { label: "Base branch", value: demoArtifact.scenario.base, code: true },
        { label: "Head branch", value: demoArtifact.scenario.head, code: true },
      ],
    },
    { summary: "Raw replay data", raw: rawArtifact },
    {
      summary: "Safety boundaries",
      items: [
        {
          label: "Tests generated",
          value: demoArtifact.safety.tests_generated,
        },
        {
          label: "Patches generated",
          value: demoArtifact.safety.patches_generated,
        },
        {
          label: "Agents dispatched",
          value: demoArtifact.safety.agents_dispatched,
        },
        {
          label: "Human review required",
          value: String(demoArtifact.safety.human_review_required),
        },
      ],
    },
  ]}
/>
