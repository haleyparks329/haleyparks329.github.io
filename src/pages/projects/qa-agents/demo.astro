---
import { getCollection } from "astro:content";
import demoArtifact from "@/data/qa-agents/little-bytes-pricing.json";
import ExternalLink from "@/components/ExternalLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

type DemoArtifact = {
  schema_version: number;
  demo_id: string;
  title: string;
  application: {
    name: string;
    profile: string;
    repository: string;
  };
  scenario: {
    base: string;
    head: string;
    summary: string;
  };
  change: {
    files: string[];
    diff_summary: string;
    diff_excerpt: string;
  };
  execution: {
    command_name: string;
    status: string;
    exit_code: number;
    duration_ms: number;
    test_summary: string;
  };
  evidence: {
    coverage_report_found: boolean;
    coverage_report_path: string;
    gap_type: string;
    gap_path: string;
    gap_detail: string;
  };
  recommendation: {
    agent: string;
    route_reason: string;
    next_action: string;
  };
  safety: {
    tests_generated: number;
    patches_generated: number;
    agents_dispatched: number;
    human_review_required: boolean;
  };
};

type DetailItem = {
  label: string;
  value: string | number | boolean;
  tone?: string;
};

type Notebook = {
  heading: string;
  observation: string;
  interpretation: string;
  why: string;
  boundary?: string;
};

type StoryNote = {
  actor: "Scout" | "Herbie" | "Quill";
  emoji: string;
  heading: string;
  body: string;
  handoff: string;
  evidenceLabel?: string;
  boundary?: string;
};

type InvestigationStep = {
  id: string;
  timelineLabel: string;
  panelTitle: string;
  windowTitle: string;
  icon: string;
  accent: string;
  notebook: Notebook;
  story: StoryNote;
  details?: DetailItem[];
};

function isRecord(value: unknown): value is Record<string, unknown> {
  return typeof value === "object" && value !== null;
}

function requireRecord(value: unknown, path: string): Record<string, unknown> {
  if (!isRecord(value)) {
    throw new Error(`QA Agents demo artifact missing required object: ${path}`);
  }
  return value;
}

function requireString(value: unknown, path: string): string {
  if (typeof value !== "string" || value.length === 0) {
    throw new Error(`QA Agents demo artifact missing required string: ${path}`);
  }
  return value;
}

function requireNumber(value: unknown, path: string): number {
  if (typeof value !== "number") {
    throw new Error(`QA Agents demo artifact missing required number: ${path}`);
  }
  return value;
}

function requireBoolean(value: unknown, path: string): boolean {
  if (typeof value !== "boolean") {
    throw new Error(
      `QA Agents demo artifact missing required boolean: ${path}`,
    );
  }
  return value;
}

function requireStringArray(value: unknown, path: string): string[] {
  if (
    !Array.isArray(value) ||
    value.length === 0 ||
    !value.every((item) => typeof item === "string" && item.length > 0)
  ) {
    throw new Error(
      `QA Agents demo artifact missing required string array: ${path}`,
    );
  }
  return value;
}

function assertDemoArtifact(value: unknown): DemoArtifact {
  const root = requireRecord(value, "artifact");
  const application = requireRecord(root.application, "application");
  const scenario = requireRecord(root.scenario, "scenario");
  const change = requireRecord(root.change, "change");
  const execution = requireRecord(root.execution, "execution");
  const evidence = requireRecord(root.evidence, "evidence");
  const recommendation = requireRecord(root.recommendation, "recommendation");
  const safety = requireRecord(root.safety, "safety");

  return {
    schema_version: requireNumber(root.schema_version, "schema_version"),
    demo_id: requireString(root.demo_id, "demo_id"),
    title: requireString(root.title, "title"),
    application: {
      name: requireString(application.name, "application.name"),
      profile: requireString(application.profile, "application.profile"),
      repository: requireString(
        application.repository,
        "application.repository",
      ),
    },
    scenario: {
      base: requireString(scenario.base, "scenario.base"),
      head: requireString(scenario.head, "scenario.head"),
      summary: requireString(scenario.summary, "scenario.summary"),
    },
    change: {
      files: requireStringArray(change.files, "change.files"),
      diff_summary: requireString(change.diff_summary, "change.diff_summary"),
      diff_excerpt: requireString(change.diff_excerpt, "change.diff_excerpt"),
    },
    execution: {
      command_name: requireString(
        execution.command_name,
        "execution.command_name",
      ),
      status: requireString(execution.status, "execution.status"),
      exit_code: requireNumber(execution.exit_code, "execution.exit_code"),
      duration_ms: requireNumber(
        execution.duration_ms,
        "execution.duration_ms",
      ),
      test_summary: requireString(
        execution.test_summary,
        "execution.test_summary",
      ),
    },
    evidence: {
      coverage_report_found: requireBoolean(
        evidence.coverage_report_found,
        "evidence.coverage_report_found",
      ),
      coverage_report_path: requireString(
        evidence.coverage_report_path,
        "evidence.coverage_report_path",
      ),
      gap_type: requireString(evidence.gap_type, "evidence.gap_type"),
      gap_path: requireString(evidence.gap_path, "evidence.gap_path"),
      gap_detail: requireString(evidence.gap_detail, "evidence.gap_detail"),
    },
    recommendation: {
      agent: requireString(recommendation.agent, "recommendation.agent"),
      route_reason: requireString(
        recommendation.route_reason,
        "recommendation.route_reason",
      ),
      next_action: requireString(
        recommendation.next_action,
        "recommendation.next_action",
      ),
    },
    safety: {
      tests_generated: requireNumber(
        safety.tests_generated,
        "safety.tests_generated",
      ),
      patches_generated: requireNumber(
        safety.patches_generated,
        "safety.patches_generated",
      ),
      agents_dispatched: requireNumber(
        safety.agents_dispatched,
        "safety.agents_dispatched",
      ),
      human_review_required: requireBoolean(
        safety.human_review_required,
        "safety.human_review_required",
      ),
    },
  };
}

function formatLabel(value: string): string {
  return value
    .replace(/_/g, " ")
    .replace(/\b\w/g, (character) => character.toUpperCase());
}

function classifyDiffLine(line: string): string {
  if (
    line.includes("if discount_percent:") ||
    line.includes("calculate_discount_cents(unit_price_cents")
  ) {
    return "diff-line is-added is-branch-gap";
  }

  if (line.startsWith("+") && !line.startsWith("+++")) {
    return "diff-line is-added";
  }

  if (line.startsWith("-") && !line.startsWith("---")) {
    return "diff-line is-removed";
  }

  if (
    line.startsWith("@@") ||
    line.startsWith("diff --git") ||
    line.startsWith("index ") ||
    line.startsWith("---") ||
    line.startsWith("+++")
  ) {
    return "diff-line is-meta";
  }

  return "diff-line";
}

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const artifact = assertDemoArtifact(demoArtifact);
const repositoryUrl = project.data.repositoryUrl;
const canonicalArtifactUrl = repositoryUrl
  ? `${repositoryUrl}/blob/main/examples/demo-runs/little-bytes-pricing.json`
  : undefined;
const artifactPath = "src/data/qa-agents/little-bytes-pricing.json";
const defaultStepIndex = 2;
const diffLines = artifact.change.diff_excerpt.split("\n");
const rawArtifact = JSON.stringify(artifact, null, 2);

const steps: InvestigationStep[] = [
  {
    id: "change",
    timelineLabel: "Change detected",
    panelTitle: "Pricing diff",
    windowTitle: "pricing.py",
    icon: "▤",
    accent: "sky",
    details: [
      { label: "Filename", value: artifact.change.files.join(", ") },
      { label: "Diff summary", value: artifact.change.diff_summary },
      { label: "Changed path", value: artifact.evidence.gap_path },
    ],
    notebook: {
      heading: "Pricing logic changed",
      observation:
        "The pricing code changed in a branch that affects discount handling.",
      interpretation: `${artifact.change.diff_summary} in ${artifact.change.files.join(
        ", ",
      )}. That is enough to ask a simple QA question: did the tests actually reach this new path?`,
      why: "Any new branch in business logic deserves coverage, especially when it changes money-related behavior.",
    },
    story: {
      actor: "Scout",
      emoji: "🔍",
      heading: "Scout spotted the changed pricing file.",
      body: "The pricing module changed. Herbie takes the next look.",
      handoff: "Passing investigation → Herbie",
    },
  },
  {
    id: "tests",
    timelineLabel: "Tests passed",
    panelTitle: "Test execution result",
    windowTitle: "unit-tests.log",
    icon: "✓",
    accent: "sage",
    details: [
      { label: "Command", value: artifact.execution.command_name },
      { label: "Status", value: artifact.execution.status, tone: "success" },
      { label: "Exit status", value: artifact.execution.exit_code },
      { label: "Output excerpt", value: artifact.execution.test_summary },
    ],
    notebook: {
      heading: "Existing tests passed",
      observation:
        "The current test suite still reports a clean pass after the pricing change.",
      interpretation:
        "A green test run means the old assertions still hold. It does not prove the new pricing path was exercised.",
      why: "Engineers care because CI can look healthy while a new branch has no real protection.",
    },
    story: {
      actor: "Herbie",
      emoji: "🧪",
      heading: "Herbie checked the existing tests.",
      body: "The existing tests all passed. Now Herbie checks what they actually covered.",
      handoff: "Checking coverage evidence",
    },
  },
  {
    id: "coverage",
    timelineLabel: "Gap discovered",
    panelTitle: "Coverage evidence",
    windowTitle: "coverage-report.json",
    icon: "⌕",
    accent: "ochre",
    details: [
      {
        label: "Coverage report",
        value: artifact.evidence.coverage_report_path,
      },
      {
        label: "Coverage report found",
        value: artifact.evidence.coverage_report_found,
      },
      { label: "Affected file", value: artifact.evidence.gap_path },
      { label: "Uncovered behavior", value: artifact.evidence.gap_detail },
    ],
    notebook: {
      heading: "New behavior was not exercised",
      observation:
        "Coverage links the passing test run back to the changed pricing file.",
      interpretation:
        "The tests passed, but the changed branch was not reached. That is a verification gap, not a product bug by itself.",
      why: "This is the core lesson: tests only protect behavior they execute.",
    },
    story: {
      actor: "Herbie",
      emoji: "🧪",
      heading: "Herbie found the missing coverage.",
      body: "Coverage showed the changed pricing path was never reached.",
      handoff: "Recording the verification gap",
      evidenceLabel: "📊 Coverage evidence",
    },
  },
  {
    id: "recorded",
    timelineLabel: "Evidence recorded",
    panelTitle: "Persisted gap record",
    windowTitle: "gap-record.json",
    icon: "▣",
    accent: "burgundy",
    details: [
      { label: "Gap type", value: formatLabel(artifact.evidence.gap_type) },
      { label: "Affected area", value: "Pricing logic" },
      { label: "Affected file", value: artifact.evidence.gap_path },
      { label: "Status", value: "Open for review" },
      { label: "Detail", value: artifact.evidence.gap_detail },
    ],
    notebook: {
      heading: "The gap was recorded",
      observation: "The finding is no longer just a transient test-run detail.",
      interpretation:
        "The affected file, gap type, and supporting detail are preserved in a small reviewable record.",
      why: "This matters because handoffs fail when evidence lives only in terminal scrollback or someone’s memory.",
    },
    story: {
      actor: "Herbie",
      emoji: "🧪",
      heading: "Herbie saved the gap.",
      body: "The missing test is now a reviewable record, not a disappearing note.",
      handoff: "Next reviewer → Quill",
    },
  },
  {
    id: "recommendation",
    timelineLabel: "Test recommended",
    panelTitle: "Recommendation artifact",
    windowTitle: "recommendation.md",
    icon: "✎",
    accent: "lavender",
    details: [
      {
        label: "Recommended action",
        value: artifact.recommendation.next_action,
      },
      { label: "Target behavior", value: "Quantity and discount ordering" },
      { label: "Suggested agent", value: artifact.recommendation.agent },
      { label: "Route reason", value: artifact.recommendation.route_reason },
      { label: "Supporting evidence", value: artifact.evidence.gap_path },
    ],
    notebook: {
      heading: "Add a regression test",
      observation:
        "The recommendation is narrow: add a regression test for quantity and discount ordering.",
      interpretation:
        "The proposed test targets the exact behavior the current suite missed. It does not claim any code was written.",
      why: "Good QA output should make the next human decision easier, not pretend the decision has already been made.",
      boundary:
        "Recommendation only. No test was authored or committed during this replay.",
    },
    story: {
      actor: "Quill",
      emoji: "🪶",
      heading: "Quill recommended the next step.",
      body: "Add a regression test before treating this pricing behavior as verified.",
      handoff: "Ready for human review",
      boundary:
        "Recommendation only. No test was authored or committed during this replay.",
    },
  },
];

const stepDetails = steps.map((step) => ({
  id: step.id,
  label: step.timelineLabel,
  story: step.story,
}));

const safetyItems = [
  ["Tests generated", artifact.safety.tests_generated],
  ["Patches generated", artifact.safety.patches_generated],
  ["Agents dispatched", artifact.safety.agents_dispatched],
  ["Human review required", String(artifact.safety.human_review_required)],
];
---

<BaseLayout
  title="QA Replay Workstation"
  description="Recorded QA Agents investigation replay for the Little Bytes pricing scenario."
  canonicalPath="/projects/qa-agents/demo/"
>
  <section class="page-section wide-case replay-page" data-replay-root>
    <div class="replay-hero">
      <p class="eyebrow">Recorded investigation replay</p>
      <h1>
        The tests passed.<br />
        The new pricing behavior still wasn't tested.
      </h1>
      <p class="lede">
        This replay exists for the uncomfortable little gap between “CI is
        green” and “the new behavior is actually protected.”
      </p>
      <p class="safety-note">
        Static replay from a canonical Little Bytes artifact. No live browser
        session, autonomous code change, or hidden agent execution is occurring
        on this page.
      </p>

      <div class="button-row">
        <a class="button secondary" href="/projects/qa-agents/">
          Main QA Agents page
        </a>
        {
          repositoryUrl && (
            <ExternalLink href={repositoryUrl} label="QA Agents repository" />
          )
        }
        {
          canonicalArtifactUrl && (
            <ExternalLink
              href={canonicalArtifactUrl}
              label="Canonical artifact"
            />
          )
        }
      </div>
    </div>

    <dl class="case-summary" aria-label="Compact case summary">
      <div>
        <dt>Repository</dt>
        <dd>{artifact.application.name.toLowerCase().replace(/\s+/g, "-")}</dd>
      </div>
      <div>
        <dt>Branch</dt>
        <dd>{artifact.scenario.head}</dd>
      </div>
      <div>
        <dt>Outcome</dt>
        <dd>Coverage gap found</dd>
      </div>
      <div>
        <dt>Action</dt>
        <dd>Regression test recommended</dd>
      </div>
    </dl>

    <section class="story-intro" aria-labelledby="story-heading">
      <p class="eyebrow">The story behind the evidence</p>
      <h2 id="story-heading">A green test run is not the end of the story.</h2>
      <p>
        Imagine you are reviewing a pull request. The pricing logic changed, the
        existing tests still pass, and it would be easy to move on.
      </p>
      <p>
        QA Agents keeps looking. Scout notices the change. Herbie starts
        digging. Coverage reveals the missing branch. Quill recommends what to
        do next.
      </p>
      <p class="replay-explanation">
        I could have recorded a terminal session, but watching someone click
        around does not explain the investigation very well. This workstation
        reconstructs the evidence so you can inspect the reasoning step by step.
      </p>
    </section>

    <aside class="cast-key" aria-label="Who's investigating?">
      <h2>Who's investigating?</h2>
      <ul>
        <li>
          <span aria-hidden="true">🔍</span> Scout notices relevant changes
        </li>
        <li>
          <span aria-hidden="true">🧪</span> Herbie investigates and verifies
        </li>
        <li>
          <span aria-hidden="true">🪶</span> Quill recommends the next action
        </li>
        <li><span aria-hidden="true">👩‍💻</span> A human reviewer decides</li>
      </ul>
    </aside>

    <div class="workstation-shell" id="replay-workstation">
      <div class="workstation-titlebar">
        <span>QA Replay Workstation</span>
        <span class="window-controls" aria-hidden="true">
          <span>_</span>
          <span>□</span>
          <span>×</span>
        </span>
      </div>

      <nav class="workstation-menu" aria-label="Replay workstation menu">
        <span>File</span>
        <span>View</span>
        <a href="#technical-details">Evidence</a>
        <a href="#recorded-replay-note">Help</a>
      </nav>

      <div class="session-strip" aria-label="Recorded session status">
        <span class="recorded-badge">● Recorded replay</span>
        <span
          >{artifact.application.name.toLowerCase().replace(/\s+/g, "-")}</span
        >
        <span>{artifact.scenario.head}</span>
        <span data-session-step
          >Step {defaultStepIndex + 1} of {steps.length}</span
        >
      </div>

      <section class="timeline-panel" aria-label="Investigation timeline">
        <div class="investigation-timeline" role="list">
          {
            steps.map((step, index) => (
              <button
                type="button"
                class:list={[
                  "timeline-button",
                  `accent-${step.accent}`,
                  index < defaultStepIndex && "is-completed",
                  index === defaultStepIndex && "is-active",
                  index > defaultStepIndex && "is-upcoming",
                ]}
                data-step-button={index}
                aria-pressed={index === defaultStepIndex ? "true" : "false"}
                aria-current={index === defaultStepIndex ? "step" : undefined}
                role="listitem"
              >
                <span class="tool-icon" aria-hidden="true">
                  {step.icon}
                </span>
                <span class="timeline-copy">
                  <span class="timeline-number">Step {index + 1}</span>
                  <span class="timeline-label">{step.timelineLabel}</span>
                  <span class="timeline-state" data-step-state={index}>
                    {index < defaultStepIndex
                      ? "Completed"
                      : index === defaultStepIndex
                        ? "Active"
                        : "Upcoming"}
                  </span>
                </span>
              </button>
            ))
          }
        </div>
      </section>

      <div class="personality-note" data-gap-note>
        tests passed ≠ behavior tested
      </div>

      <section class="team-notes" aria-live="polite" aria-label="Team notes">
        <div class="team-note-actor">
          <span class="team-note-emoji" data-story-emoji aria-hidden="true">
            {steps[defaultStepIndex].story.emoji}
          </span>
          <span class="team-note-name" data-story-actor>
            {steps[defaultStepIndex].story.actor}
          </span>
          {
            steps[defaultStepIndex].story.evidenceLabel && (
              <span class="team-note-evidence" data-story-evidence>
                {steps[defaultStepIndex].story.evidenceLabel}
              </span>
            )
          }
          {
            !steps[defaultStepIndex].story.evidenceLabel && (
              <span class="team-note-evidence" data-story-evidence hidden />
            )
          }
        </div>
        <div class="team-note-copy">
          <h2 data-story-heading>{steps[defaultStepIndex].story.heading}</h2>
          <p data-story-body>{steps[defaultStepIndex].story.body}</p>
          {
            steps[defaultStepIndex].story.boundary && (
              <p class="team-note-boundary" data-story-boundary>
                {steps[defaultStepIndex].story.boundary}
              </p>
            )
          }
          {
            !steps[defaultStepIndex].story.boundary && (
              <p class="team-note-boundary" data-story-boundary hidden />
            )
          }
        </div>
        <div class="team-note-handoff" data-story-handoff>
          {steps[defaultStepIndex].story.handoff}
        </div>
      </section>

      <section class="workspace" aria-live="polite">
        {
          steps.map((step, index) => (
            <article
              class:list={[
                "workspace-step",
                `accent-${step.accent}`,
                index === defaultStepIndex && "is-active",
              ]}
              data-step-panel={index}
              hidden={index !== defaultStepIndex}
            >
              <div class="retro-window evidence-panel">
                <div class="retro-titlebar">
                  <span>{step.windowTitle}</span>
                  <span class="mini-window-controls" aria-hidden="true">
                    <span>_</span>
                    <span>□</span>
                    <span>×</span>
                  </span>
                </div>
                <div class="window-toolbar">
                  <span>Evidence under review</span>
                  <span>{step.panelTitle}</span>
                </div>
                <div class="window-body">
                  {step.id === "change" && (
                    <>
                      <div class="diff-badges" aria-label="Diff summary">
                        <span>{artifact.change.files.join(", ")}</span>
                        <span class="additions">+6</span>
                        <span class="deletions">-1</span>
                      </div>
                      <dl class="evidence-facts">
                        {step.details?.map((item) => (
                          <div>
                            <dt>{item.label}</dt>
                            <dd>
                              <code>{String(item.value)}</code>
                            </dd>
                          </div>
                        ))}
                      </dl>
                      <pre class="diff-view" aria-label="Pricing diff excerpt">
                        <code>
                          {diffLines.map((line) => (
                            <span class={classifyDiffLine(line)}>
                              {line || " "}
                            </span>
                          ))}
                        </code>
                      </pre>
                      <p class="coverage-link-note">
                        coverage gap associated with changed pricing path
                      </p>
                    </>
                  )}

                  {step.id === "tests" && (
                    <div class="command-result">
                      <span class="status-indicator">PASS</span>
                      <dl class="evidence-facts compact">
                        {step.details?.map((item) => (
                          <div>
                            <dt>{item.label}</dt>
                            <dd
                              class={
                                item.tone ? `tone-${item.tone}` : undefined
                              }
                            >
                              {item.label === "Command" ? (
                                <code>{String(item.value)}</code>
                              ) : (
                                String(item.value)
                              )}
                            </dd>
                          </div>
                        ))}
                      </dl>
                    </div>
                  )}

                  {step.id === "coverage" && (
                    <div class="coverage-report">
                      <div class="coverage-report-header">
                        <span class="coverage-warning" aria-hidden="true">
                          !
                        </span>
                        <div>
                          <h3>Coverage report</h3>
                          <p>
                            Inspection summary for the changed pricing path.
                          </p>
                        </div>
                      </div>
                      <dl class="inspection-list">
                        <div>
                          <dt>Coverage report captured</dt>
                          <dd class="inspection-status">
                            ✓ {String(artifact.evidence.coverage_report_found)}
                          </dd>
                        </div>
                        <div>
                          <dt>Affected file</dt>
                          <dd>
                            <code>{artifact.evidence.gap_path}</code>
                          </dd>
                        </div>
                        <div>
                          <dt>Finding</dt>
                          <dd>Changed pricing branch was never executed</dd>
                        </div>
                        <div>
                          <dt>Artifact</dt>
                          <dd>
                            <code>
                              {artifact.evidence.coverage_report_path}
                            </code>
                          </dd>
                        </div>
                        <div>
                          <dt>Recorded gap</dt>
                          <dd>{artifact.evidence.gap_detail}</dd>
                        </div>
                      </dl>
                      <p class="coverage-link-note">
                        coverage gap associated with changed pricing path
                      </p>
                    </div>
                  )}

                  {step.id === "recorded" && (
                    <dl class="record-list">
                      {step.details?.map((item) => (
                        <div>
                          <dt>{item.label}</dt>
                          <dd>{String(item.value)}</dd>
                        </div>
                      ))}
                    </dl>
                  )}

                  {step.id === "recommendation" && (
                    <div class="recommendation-card">
                      <span class="status-indicator recommendation-only">
                        recommendation only
                      </span>
                      <p class="recommendation-action">
                        {artifact.recommendation.next_action}
                      </p>
                      <dl class="evidence-facts">
                        {step.details?.slice(1).map((item) => (
                          <div>
                            <dt>{item.label}</dt>
                            <dd>
                              {item.label === "Supporting evidence" ? (
                                <code>{String(item.value)}</code>
                              ) : (
                                String(item.value)
                              )}
                            </dd>
                          </div>
                        ))}
                      </dl>
                    </div>
                  )}
                </div>
              </div>

              <aside
                class="retro-window notebook-panel"
                aria-label="Case notes"
              >
                <div class="retro-titlebar">
                  <span>Case Notes</span>
                  <span class="read-only-label">read-only</span>
                </div>
                <div class="window-body notebook-paper">
                  <p class="panel-kicker">Case notes</p>
                  <h2>{step.notebook.heading}</h2>
                  <div class="notebook-entry">
                    <h3>What happened</h3>
                    <p>{step.notebook.observation}</p>
                  </div>
                  <div class="notebook-entry">
                    <h3>Why the evidence matters</h3>
                    <p>{step.notebook.interpretation}</p>
                  </div>
                  <div class="notebook-entry">
                    <h3>Why engineers care</h3>
                    <p>{step.notebook.why}</p>
                  </div>
                  {step.notebook.boundary && (
                    <p class="boundary-note">{step.notebook.boundary}</p>
                  )}
                </div>
              </aside>
            </article>
          ))
        }
      </section>

      <div class="playback-shell" aria-label="Replay navigation controls">
        <button type="button" class="retro-control" data-step-prev>
          ◀ Rewind
        </button>
        <span class="replay-mode">Replay</span>
        <button type="button" class="retro-control primary" data-step-next>
