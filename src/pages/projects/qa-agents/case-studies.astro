---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { connectedDestinations } from "@/data/navigation";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
const continueLinks = connectedDestinations("project-qa-agents-case-studies");
---

<BaseLayout
  title={`Case Studies | ${project.data.title}`}
  description="QA Agents case-study material, evidence examples, learnings, and limitations."
  canonicalPath="/projects/qa-agents/case-studies/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/qa-agents/" },
    { label: "Case Studies" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="Case Studies"
    documentSummary="The recorded investigation examples and the boundaries that keep the public project honest."
  >
    <ProjectDocumentContent
      example={document.example}
      learnings={document.learnings}
      notSolved={document.notSolved}
      continueLinks={continueLinks}
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
