---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
---

<BaseLayout
  title={`System | ${project.data.title}`}
  description="How QA Agents separates evidence, routing, agent roles, handoff, and review."
  canonicalPath="/projects/qa-agents/system/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/qa-agents/" },
    { label: "System" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="System"
    documentSummary="Inputs, agent responsibilities, outputs, current status, and the boundary between routing and repair."
  >
    <ProjectDocumentContent
      statusRows={document.statusRows}
      currentDirection={document.currentDirection}
      howItWorks={document.howItWorks}
      appendix={document.appendix}
      nextHref="/projects/qa-agents/case-studies/"
      nextLabel="View the case studies"
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
