        why: "Pricing changes are risky because a small calculation or copy change can affect checkout totals, customer expectations, and merge confidence.",
        boundary:
          "PHASE 1 - DETERMINISTIC EVIDENCE begins with the code change.",
      },
      story: {
        actor: "REPOSITORY",
        emoji: "▤",
        heading: "A pull request changes annual-plan pricing.",
        body: "The pricing change triggers deterministic replay before merge so the changed code can be compared against recorded behavior.",
        handoff: "TRIGGER REPLAY",
        evidenceLabel: "What started this?",
