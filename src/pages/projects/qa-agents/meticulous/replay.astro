---
import { getCollection } from "astro:content";
import investigation from "@/data/qa-agents/meticulous-pricing-investigation.json";
import input from "@/data/qa-agents/meticulous-pricing-input.json";
import EvidenceReplay from "@/components/qa-agents/EvidenceReplay.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const rawInvestigationArtifact = JSON.stringify(investigation, null, 2);
const rawInputArtifact = JSON.stringify(input, null, 2);
const changedFiles = input.change.changed_files.join(", ");
const changedBranches = input.change.changed_branches.join(", ");
const allDiffs = input.sessions.flatMap((session) =>
  session.differences.map((difference) => ({
    ...difference,
    session_id: session.session_id,
    workflow_hint: session.workflow_hint,
  })),
);
const expectedDiffs = allDiffs.filter(
  (difference) => "expected" in difference && difference.expected,
);
const regressionDiffs = allDiffs.filter(
  (difference) =>
    "severity" in difference && difference.severity === "regression",
);
const expectedFinding = investigation.findings.find(
  (finding) => finding.classification === "expected_change",
);
const regressionFinding = investigation.findings.find(
  (finding) => finding.classification === "confirmed_regression",
);
const knownExpectation = input.known_expectations[0];
const missingWorkflow = investigation.coverage_audit.missing_workflows[0];
const uncoveredBranch =
  investigation.coverage_audit.uncovered_changed_branches[0];
const uncoveredExpectation =
  (input.coverage.branch_expectations as Record<string, string>)[
    uncoveredBranch
  ] ?? missingWorkflow;
const decision =
  investigation.policy_decision.decision[0].toUpperCase() +
  investigation.policy_decision.decision.slice(1);
const workflowDetails = investigation.workflow_clusters
  .map(
    (cluster) =>
      `${cluster.name}: ${cluster.session_ids.join(", ")} | routes ${cluster.shared_routes.join(" -> ")}`,
  )
  .join("\n");
const workflowSummary = investigation.workflow_clusters
  .map((cluster) => `${cluster.name} (${cluster.session_ids.length} sessions)`)
  .join("\n");
const expectedSessionIds = expectedFinding?.session_ids.join(", ") ?? "";
const expectedDiffIds = expectedFinding?.diff_ids.join(", ") ?? "";
const regressionSessionIds = regressionFinding?.session_ids.join(", ") ?? "";
const regressionDiffIds = regressionFinding?.diff_ids.join(", ") ?? "";
const regressionBaseValues = [
  ...new Set(regressionDiffs.map((difference) => difference.base_value)),
].join(", ");
const regressionHeadValues = [
  ...new Set(regressionDiffs.map((difference) => difference.head_value)),
].join(", ");
const packageContents = [
  `${investigation.replay_summary.sessions_affected} affected sessions`,
  `${investigation.findings.length} findings`,
  `${allDiffs.length} deterministic differences`,
  `${investigation.change.changed_branches.length} changed branches`,
  `${input.known_expectations.length} known expectation`,
].join(" | ");
---

<EvidenceReplay
  pageTitle="Meticulous-Inspired Interactive Replay | QA Agents"
  pageDescription="An interactive simulated replay showing how QA Agents investigate deterministic replay evidence downstream of a replay platform."
  canonicalPath="/projects/qa-agents/meticulous/replay/"
  eyebrow="QA AGENTS STRATEGY EXPLORATION"
  titleLines={["From deterministic replay", "to engineering decision"]}
  lede="A simulated pricing change moves through two distinct layers: a replay engine produces deterministic base-versus-head evidence, then QA Agents group, interpret, audit, and convert that evidence into a policy-constrained recommendation."
  safetyNote="This is an independent technical exploration based on publicly documented replay-testing concepts. It uses simulated data and is not an official Meticulous integration."
  links={[
    { href: "/projects/qa-agents/", label: "Main QA Agents page" },
    ...(project.data.repositoryUrl
      ? [
          {
            href: project.data.repositoryUrl,
            label: "QA Agents repository",
            external: true,
          },
        ]
      : []),
  ]}
  caseSummary={[
    { label: "Change", value: "Annual-plan pricing" },
    {
      label: "Replay evaluated",
      value: `${investigation.replay_summary.sessions_evaluated.toLocaleString()} sessions`,
    },
    {
      label: "Affected",
      value: `${investigation.replay_summary.sessions_affected} sessions`,
    },
    { label: "Decision", value: decision },
  ]}
  storyIntro={{
    eyebrow: "Two-phase replay",
    heading: "The replay engine finishes first. The investigation starts next.",
    paragraphs: [
      "A pull request changes annual-plan pricing. The replay layer evaluates recorded user sessions, selects those relevant to the changed code, replays base and head behavior, and produces a deterministic comparison package.",
      "QA Agents do not replace that machinery. They begin where it ends: turning 17 affected sessions into workflows, separating expected changes from a real regression, exposing missing coverage, and handing a bounded recommendation to a human.",
    ],
    explanation:
      "PHASE 1 - DETERMINISTIC EVIDENCE: replay finds what changed. PHASE 2 - QA INVESTIGATION: QA Agents investigate what it means.",
  }}
  castTitle="Responsibility map"
  cast={[
    "Replay Engine - captures, replays, and compares deterministic evidence",
    "Beacon - groups affected sessions into product workflows",
    "Inspector - separates expected changes from regressions",
    "Inspector - audits missing workflow coverage",
    "Scribe / Policy - applies bounded decision rules",
    "Human - makes the final decision",
  ]}
  sessionMeta={[
    "PHASE 1 - DETERMINISTIC EVIDENCE",
    "PHASE 2 - QA INVESTIGATION",
    investigation.case_id,
  ]}
  gapNote="Replay finds what changed. QA Agents investigate what it means."
  defaultStepIndex={0}
  steps={[
    {
      id: "change",
      timelineLabel: "PR changes pricing",
      panelTitle: "Change context",
      windowTitle: "pull-request.json",
