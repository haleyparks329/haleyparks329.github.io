---
import { getCollection } from "astro:content";
import ExternalLink from "@/components/ExternalLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import investigation from "@/data/qa-agents/meticulous-pricing-investigation.json";
import input from "@/data/qa-agents/meticulous-pricing-input.json";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const meticulousUrl = "https://www.meticulous.ai/";
const repositoryUrl = project.data.repositoryUrl;
const architectureUrl = repositoryUrl
  ? `${repositoryUrl}/blob/main/docs/strategy-architecture.md`
  : undefined;
const artifactUrl = repositoryUrl
  ? `${repositoryUrl}/blob/main/strategies/meticulous/examples/pricing-change.investigation.json`
  : undefined;

const allDiffs: Record<string, unknown>[] = input.sessions.flatMap((session) =>
  session.differences.map((difference) => ({ ...difference })),
);
const expectedDiffs = allDiffs.filter(
  (difference) => difference.expected === true,
);
const regressionDiffs = allDiffs.filter(
  (difference) => difference.severity === "regression",
);
const knownExpectation = input.known_expectations[0];

const evaluatedSessions =
  investigation.replay_summary.sessions_evaluated.toLocaleString();
const selectedSessions =
  investigation.replay_summary.sessions_selected.toLocaleString();
const affectedSessions = investigation.replay_summary.sessions_affected;
const workflowCount = investigation.summary.affected_workflows;
const expectedDiffCount = expectedDiffs.length;
const regressionDiffCount = regressionDiffs.length;
const recommendation = investigation.summary.recommendation.toUpperCase();

const strategyFiles = [
  "strategies/",
  "└── meticulous/",
  "    ├── strategy.yaml",
  "    ├── decision-policy.yaml",
  "    ├── evidence-schema.json",
  "    ├── fixtures/",
  "    ├── examples/",
  "    ├── prompts/",
  "    └── tests/",
];
---

<BaseLayout
  title="Extending Deterministic Replay with an Investigation Layer"
  description="An independent engineering exploration of how deterministic replay evidence can enter QA Agents through a configurable investigation layer, explicit policy, and human review."
  canonicalPath="/projects/qa-agents/meticulous/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/qa-agents/" },
    { label: "Extending Deterministic Replay with an Investigation Layer" },
  ]}
>
  <article class="meticulous-writeup">
    <header class="case-hero wide-case">
      <p class="eyebrow">INDEPENDENT ENGINEERING EXPLORATION</p>
      <h1>Extending deterministic replay with an investigation layer</h1>
      <p class="lede">
        This project tested whether deterministic replay evidence could become
        an input to QA Agents without turning QA Agents into a replay engine or
        a Meticulous-specific runtime. Meticulous's public replay model offered
        the shape of deterministic evidence; the useful architectural result was
        Quality Strategy, an investigation layer that separates evidence
        acquisition from evidence interpretation.
      </p>
      <p class="disclaimer">
        Independent exploration using simulated replay data inspired by public
        replay-testing concepts. Not an official Meticulous integration and not
        built with private APIs, production data, or replay internals.
      </p>
      <details class="executive-summary" open>
        <summary>
          <span>30-second summary</span>
          <span>Full article about 6 minutes</span>
        </summary>
        <div class="executive-summary-content">
          <dl class="summary-grid">
            <div>
              <dt>Problem</dt>
              <dd>
                QA Agents already organized software-quality evidence into
                findings and recommendations. Adding deterministic replay
                exposed places where investigation behavior was still coupled to
                one evidence shape.
              </dd>
            </div>
            <div>
              <dt>Change</dt>
              <dd>
                Introduced Quality Strategy abstraction separating system being
                investigated from rules used to validate and interpret evidence.
              </dd>
            </div>
            <div>
              <dt>Proof</dt>
              <dd>
                Simulated pricing investigation grouped sessions into workflows,
                separated expected pricing change from shared rounding
                regression, found coverage gap, produced policy-constrained
                <code>HOLD</code>.
              </dd>
            </div>
            <div>
              <dt>Boundary</dt>
              <dd>
                Replay remains deterministic source of evidence. QA Agents
                investigates evidence. Human makes final decision.
              </dd>
            </div>
          </dl>
          <div class="summary-actions">
            <a href="/projects/qa-agents/meticulous/replay/">
              Open the interactive replay
            </a>
            {
              repositoryUrl && (
                <ExternalLink
                  href={repositoryUrl}
                  label="View the QA Agents repository"
                />
              )
            }
          </div>
        </div>
      </details>
    </header>

    <section class="page-section wide-case split-section">
      <div>
        <h2>QA Agents and deterministic replay</h2>
      </div>
      <div class="prose">
        <p>
          QA Agents began as an experimental software-quality investigation
          system. It works downstream of test execution by collecting available
          evidence, organizing findings, identifying gaps and uncertainty, and
          preparing a structured recommendation for a human reviewer. It is not
          intended to replace browser automation, test runners, or the systems
          that produce the original evidence.
        </p>
        <p>
          Meticulous's public product model describes one such
          evidence-producing layer. A replay platform captures user sessions,
          selects those relevant to a code change, replays them against base and
          head versions, and produces inspectable differences. The value of that
          system comes from repeatability: the behavior has already been
          reproduced through a deterministic process before anyone attempts to
          interpret it.
        </p>
        <p>
          The systems therefore have separate responsibilities. Replay
          establishes what changed. QA Agents investigates the resulting
          evidence without rewriting it, reproducing the replay engine, or
          taking authority away from the reviewer. Introducing replay-shaped
          evidence into QA Agents exposed assumptions inside the existing
          investigation engine, which led to the integration problem described
          below.
        </p>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>The integration problem</h2>
      </div>
      <div class="prose">
        <p>
          Passing replay-shaped evidence through the existing investigation path
          exposed a coupling problem inside QA Agents. Validation, clustering
          inputs, classification assumptions, summary behavior, decision rules,
          and CLI strategy selection still lived too close to the investigation
          engine.
        </p>
        <p>
          A narrow solution would have been to add a <code>meticulous</code>{
            " "
          }
          runtime mode and branch through the engine whenever replay evidence appeared.
          That would have worked for the demo, but it would have mixed evidence-source
          identity with investigation behavior. API contract tests, accessibility
          audits, production traces, or static analysis would each become another
          branch.
        </p>
        <p>
          QA Agents needed an abstraction for interpretation behavior, not a
          vendor-inspired mode embedded throughout the runtime.
        </p>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case split-section">
        <div>
          <h2>The Quality Strategy abstraction</h2>
        </div>
        <div class="prose">
          <p>
            The resulting split is between a <code>Profile</code>{" "}and a{" "}
            <code>Quality Strategy</code>. A profile describes who or what is
            being investigated: repository conventions, application routes, test
            layout, integrations, and tracker metadata. A Quality Strategy
            describes how a class of evidence should be validated, interpreted,
            and constrained.
          </p>
          <p>
            The implemented strategy layer includes a filesystem-backed
            {" "}<code>StrategyRegistry</code>, strategy discovery through{" "}
            <code>strategy.yaml</code>, explicit decision rules in{" "}
            <code>decision-policy.yaml</code>, typed investigation domain
            objects, replay validation, clustering and classification config,
            summary actions, CLI-boundary serialization, tests, and generated
            artifacts.
          </p>
          <p>
            Runtime loading stays narrower than the directory shape: the
            investigation path loads <code>strategy.yaml</code>,
            {" "}<code>decision-policy.yaml</code>, and input evidence. The
            remaining files document, validate, or demonstrate the strategy.
          </p>
          <div
            class="definition-pair"
            aria-label="Profile and quality strategy distinction"
          >
            <div>
              <strong>Profile</strong>
              <span>the target under investigation</span>
            </div>
            <div>
              <strong>Quality Strategy</strong>
              <span>the rules for interpreting a class of evidence</span>
            </div>
          </div>
          <details class="supporting-details">
            <summary>Strategy directory excerpt</summary>
            <pre><code>{strategyFiles.join("\n")}</code></pre>
          </details>
        </div>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case">
        <div class="section-heading">
          <h2>Investigation pipeline</h2>
          <p>
            Replay remains responsible for capturing, selecting, executing, and
            comparing sessions. QA Agents starts after an immutable evidence
            package exists, then applies the strategy to produce traceable
            findings and a policy-constrained recommendation.
          </p>
        </div>
        <div
          class="architecture-diagram"
          aria-label="Replay and QA Agents responsibility flow"
        >
          <div>
            <strong>Pull request</strong>
            <span>annual-plan pricing change</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Replay platform</strong>
            <span>capture • select • replay • compare</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Immutable evidence package</strong>
            <span>sessions • diffs • branches • coverage</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Quality Strategy</strong>
            <span>configure interpretation rules</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Investigation pipeline</strong>
            <span>cluster • classify • audit • evaluate policy</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Human review</strong>
            <span>review and decide</span>
          </div>
        </div>
        <p class="boundary-note">
          This exploration assumes replay evidence already exists. It does not
          simulate or reproduce Meticulous internals.
        </p>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>A simulated pricing investigation</h2>
      </div>
      <div class="prose">
        <p>
          The worked example uses a simulated annual-plan pricing change. The
          replay summary contains {evaluatedSessions} evaluated sessions,{" "}
          {selectedSessions} selected sessions, and {affectedSessions} affected sessions.
          Because multiple sessions can represent the same workflow or defect, the
          strategy groups them into {workflowCount} workflow clusters before producing
          findings.
        </p>
        <p>
          The generated investigation separates {expectedDiffCount} expected textual
          differences from {regressionDiffCount} functional differences. The expected
          differences match <code>{knownExpectation.id}</code>, an explicit
          annual discount label change from <code>Save 10%</code> to{" "}
          <code>Save 12%</code>. The functional differences identify one shared
          one-cent rounding regression: <code>$108.00</code> to{" "}
          <code>$107.99</code>.
        </p>
        <p>
          The coverage audit also finds one changed branch without selected
          replay coverage: legacy coupon plus prorated annual upgrade. Because a
          confirmed functional regression matches the configured policy rule,
          the generated recommendation is <code>{recommendation}</code>. The
          artifact marks <code>human_decision_required</code>, so the
          recommendation remains advisory.
        </p>
        <pre
          class="terminal"><code>python3 -m qa_agents investigate \
  --strategy meticulous \
  --input strategies/meticulous/fixtures/pricing-change.input.json \
  --output strategies/meticulous/examples/pricing-change.investigation.json</code></pre>
        <div class="finding-grid">
          <article>
            <h3>Expected product change</h3>
            <ul>
              <li>{expectedDiffCount} textual differences</li>
              <li><code>Save 10%</code> to <code>Save 12%</code></li>
              <li>matched explicit expectation evidence</li>
              <li><code>{knownExpectation.id}</code></li>
            </ul>
          </article>
          <article>
            <h3>Confirmed regression</h3>
            <ul>
              <li>{regressionDiffCount} functional differences</li>
              <li><code>$108.00</code> to <code>$107.99</code></li>
              <li>one shared rounding regression</li>
            </ul>
          </article>
          <article>
            <h3>Residual coverage risk</h3>
            <ul>
              <li>one changed branch not exercised</li>
              <li>legacy coupon plus prorated annual upgrade</li>
              <li>
                coverage risk: {investigation.coverage_audit.coverage_risk}
              </li>
            </ul>
          </article>
        </div>
        <details class="supporting-details">
          <summary>Generated artifact and replay</summary>
          <p>
            The artifact is generated from simulated source data. The replay
            route is a static presentation around the same investigation.
          </p>
          <div class="inline-links">
            {
              artifactUrl && (
                <ExternalLink
                  href={artifactUrl}
                  label="View generated artifact"
                />
              )
            }
            <a
              class="button secondary"
              href="/projects/qa-agents/meticulous/replay/"
            >
              Open the interactive evidence replay
            </a>
          </div>
        </details>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>What changed during implementation</h2>
      </div>
      <div class="prose">
        <p>
          QA Agents does not sit inside replay execution or rewrite its output.
          Raw sessions, differences, branches, and coverage records remain
          immutable evidence. Workflows, findings, coverage gaps, policy
          decisions, and final results are separate typed claims that retain
          source references.
        </p>
        <p>
          The first pass was strategy-shaped, but review showed that some
          behavior still lived directly in Python. Clustering and classification
          were partly configurable, while summary behavior and CLI discovery
          blurred the strategy boundary.
        </p>
        <p>
          The refinement moved clustering features, classification rules, and
          summary next actions into strategy configuration; kept decision rules
          explicit and deterministic; separated discovery from the CLI through
          {" "}<code>StrategyRegistry</code>; retained typed objects until
          serialization; constrained recommendations through policy; and made
          malformed evidence actionable.
        </p>
        <pre
          class="terminal"><code>qa-agents investigate: Invalid evidence for strategy 'meticulous':
  - missing top-level field: case_id
  - source must be an object
  - sessions[0] missing session_id</code></pre>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case split-section">
        <div>
          <h2>Verification and limitations</h2>
        </div>
        <div class="prose">
          <ul class="compact-list">
            <li>38 tests passing</li>
            <li>compile check passing</li>
            <li>generated artifact reproducible</li>
            <li>malformed evidence tested</li>
            <li>all source data marked simulated</li>
            <li>no private APIs used</li>
          </ul>
          <pre
            class="terminal"><code>.venv/bin/python -m pytest
.venv/bin/python -m compileall qa_agents</code></pre>
          <p class="fine-note">
            Ruff and mypy are not currently configured as project checks.
          </p>
          <ul class="compact-list single">
            <li>
              One implemented strategy does not prove every future strategy will
              fit.
            </li>
            <li>The engine remains replay-evidence-specific in places.</li>
            <li>
              Runtime validation is currently hand-coded rather than driven by
              {" "}<code>evidence-schema.json</code>.
            </li>
            <li>
              <code>decision-policy.yaml</code> currently contains JSON-shaped policy
              configuration.
            </li>
            <li>This is not a live Meticulous integration.</li>
            <li>This does not build or reproduce a replay engine.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case closing-section">
        <div>
          <h2>What changed in QA Agents</h2>
          <p>
            The Meticulous-inspired strategy is useful as a concrete
            implementation, but the broader result is the separation it forced
            inside QA Agents: target, evidence source, interpretation strategy,
            decision policy, and final human review now sit behind clearer
            boundaries. Future evidence sources should enter through additional
            strategies instead of becoming new runtime modes.
          </p>
        </div>
        <div class="closing-links">
          <ExternalLink href={meticulousUrl} label="Visit Meticulous" />
          {
            architectureUrl && (
              <ExternalLink
                href={architectureUrl}
                label="Read Quality Strategy Architecture"
              />
            )
          }
          {
            artifactUrl && (
              <ExternalLink
                href={artifactUrl}
                label="View generated investigation artifact"
              />
            )
          }
          <a href="/projects/qa-agents/">Main QA Agents project</a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .meticulous-writeup {
    display: grid;
  }

  .case-hero {
    display: grid;
    gap: var(--space-5);
    padding-block: var(--space-hero) var(--space-12);
  }

  .case-hero h1 {
    max-width: 980px;
    font-size: var(--text-page-title);
  }

  .case-hero .lede {
    max-width: 960px;
  }

  .disclaimer,
  .fine-note,
  .boundary-note {
    max-width: 840px;
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .executive-summary {
    max-width: 920px;
    border: 1px solid rgba(55, 40, 38, 0.18);
    border-left: 0.34rem solid var(--blue);
    border-radius: 6px;
    padding: var(--space-4);
    background: rgba(255, 248, 239, 0.68);
  }

  .executive-summary summary {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    align-items: baseline;
    justify-content: space-between;
    color: var(--color-text);
    cursor: pointer;
    font-weight: 700;
  }

  .executive-summary summary::marker {
    color: var(--blue);
  }

  .executive-summary summary span:last-child {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .executive-summary summary:focus-visible,
  .supporting-details summary:focus-visible,
  .summary-actions a:focus-visible {
    outline: 2px solid var(--blue);
    outline-offset: 4px;
  }

  .executive-summary-content {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .summary-grid {
    display: grid;
    gap: var(--space-3);
    margin: 0;
  }

  .summary-grid div {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr);
    gap: var(--space-3);
  }

  .summary-grid dt {
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 700;
    text-transform: uppercase;
  }

  .summary-grid dd {
    margin: 0;
    color: var(--color-text-muted);
  }

  .summary-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .split-section {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: var(--section-gap);
    align-items: start;
  }

  .split-section h2,
  .section-heading h2,
  .closing-section h2 {
    font-size: var(--text-h2);
  }

  .prose {
    display: grid;
    gap: var(--space-5);
  }

  .prose p,
  .section-heading p,
  .closing-section p {
    max-width: var(--reading-width);
    color: var(--color-text-muted);
  }

  .section-heading {
    display: grid;
    gap: var(--space-3);
    max-width: 820px;
    margin-bottom: var(--space-8);
  }

  .architecture-diagram {
    display: grid;
    gap: var(--space-3);
    max-width: 860px;
    margin-bottom: var(--space-8);
  }

  .architecture-diagram div,
  .definition-pair div,
  .finding-grid article {
    border: 1px solid rgba(55, 40, 38, 0.18);
    border-radius: 6px;
    background: rgba(248, 240, 231, 0.72);
  }

  .architecture-diagram div {
    display: grid;
    gap: var(--space-1);
    border-left: 0.34rem solid var(--blue);
    padding: var(--space-4);
  }

  .architecture-diagram div:nth-of-type(2) {
    border-left-color: var(--houseplant);
  }

  .architecture-diagram div:nth-of-type(3) {
    border-left-color: var(--khaki);
  }

  .architecture-diagram div:nth-of-type(4) {
    border-left-color: var(--rust);
  }

  .architecture-diagram div:nth-of-type(5) {
    border-left-color: var(--lavender);
  }

