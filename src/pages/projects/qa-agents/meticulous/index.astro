---
import { getCollection } from "astro:content";
import ExternalLink from "@/components/ExternalLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import investigation from "@/data/qa-agents/meticulous-pricing-investigation.json";
import input from "@/data/qa-agents/meticulous-pricing-input.json";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const meticulousUrl = "https://www.meticulous.ai/";
const repositoryUrl = project.data.repositoryUrl;
const architectureUrl = repositoryUrl
  ? `${repositoryUrl}/blob/main/docs/strategy-architecture.md`
  : undefined;
const artifactUrl = repositoryUrl
  ? `${repositoryUrl}/blob/main/strategies/meticulous/examples/pricing-change.investigation.json`
  : undefined;

const allDiffs: Record<string, unknown>[] = input.sessions.flatMap((session) =>
  session.differences.map((difference) => ({ ...difference })),
);
const expectedDiffs = allDiffs.filter(
  (difference) => difference.expected === true,
);
const regressionDiffs = allDiffs.filter(
  (difference) => difference.severity === "regression",
);
const knownExpectation = input.known_expectations[0];

const evaluatedSessions =
  investigation.replay_summary.sessions_evaluated.toLocaleString();
const selectedSessions =
  investigation.replay_summary.sessions_selected.toLocaleString();
const affectedSessions = investigation.replay_summary.sessions_affected;
const workflowCount = investigation.summary.affected_workflows;
const expectedDiffCount = expectedDiffs.length;
const regressionDiffCount = regressionDiffs.length;
const coverageGapCount = investigation.summary.coverage_gaps;
const recommendation = investigation.summary.recommendation.toUpperCase();
const matchedRule = investigation.policy_decision.matched_rule;

const implementationItems = [
  "StrategyRegistry",
  "filesystem-backed strategy discovery",
  "strategy-driven clustering features",
  "strategy-driven classification rules",
  "explicit deterministic decision policy",
  "typed investigation domain objects",
  "actionable evidence validation errors",
  "serialization at the CLI boundary",
  "tests and generated artifacts",
];

const strategyFiles = [
  "strategies/",
  "└── meticulous/",
  "    ├── strategy.yaml",
  "    ├── decision-policy.yaml",
  "    ├── evidence-schema.json",
  "    ├── fixtures/",
  "    ├── examples/",
  "    ├── prompts/",
  "    └── tests/",
];
---

<BaseLayout
  title="Extending Deterministic Replay with an Investigation Layer"
  description="An independent engineering exploration of how deterministic replay evidence can enter QA Agents through a configurable investigation layer, explicit policy, and human review."
  canonicalPath="/projects/qa-agents/meticulous/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/qa-agents/" },
    { label: "Extending Deterministic Replay with an Investigation Layer" },
  ]}
>
  <article class="meticulous-writeup">
    <header class="case-hero wide-case">
      <p class="eyebrow">INDEPENDENT ENGINEERING EXPLORATION</p>
      <h1>Extending deterministic replay with an investigation layer</h1>
      <p class="lede">
        This project tested whether deterministic replay evidence could become
        an input to QA Agents without turning QA Agents into a replay engine or
        a Meticulous-specific runtime. The useful architectural result was an
        investigation layer, configured through Quality Strategy, that separates
        evidence acquisition from evidence interpretation.
      </p>
      <p class="disclaimer">
        Independent exploration using simulated data. Not an official Meticulous
        integration and not built with private APIs or data.
      </p>
      <div class="button-row">
        <ExternalLink href={meticulousUrl} label="Visit Meticulous" />
        {
          repositoryUrl && (
            <ExternalLink
              href={repositoryUrl}
              label="View QA Agents repository"
            />
          )
        }
        {
          architectureUrl && (
            <ExternalLink
              href={architectureUrl}
              label="Read Quality Strategy Architecture"
            />
          )
        }
        <a class="button secondary" href="/projects/qa-agents/">
          Main QA Agents project
        </a>
      </div>
    </header>

    <section class="page-section wide-case opening-grid">
      <div>
        <h2>Overview</h2>
      </div>
      <div class="prose">
        <p>
          QA Agents already existed as an investigation system for organizing
          software-quality evidence, identifying gaps, and producing
          recommendations that remain subject to human review. After studying
          Meticulous's publicly documented replay model, I wanted to test
          whether replay evidence could become one input to that investigation
          system.
        </p>
        <p>
          The purpose was narrow: preserve deterministic replay as the source of
          truth, pass a simulated replay artifact into QA Agents, and examine
          what had to change inside QA Agents for that integration to stay
          modular. The project uses synthetic replay data inspired by public
          replay-testing concepts. It does not use Meticulous internals, private
          APIs, or production data.
        </p>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case split-section">
        <div>
          <h2>QA Agents and deterministic replay</h2>
        </div>
        <div class="prose">
          <p>
            QA Agents is not another browser automation tool. Its existing role
            is downstream of test execution: collect evidence, organize what is
            known, expose uncertainty, and make the next human decision easier
            to review.
          </p>
          <p>
            Meticulous's public product model describes a different and valuable
            layer. A replay platform captures user sessions, selects sessions
            relevant to a code change, replays them against base and head
            versions, compares the results, and produces inspectable evidence.
            The value of that layer comes from repeatability: before anyone
            interprets the result, the changed behavior has already been
            reproduced against a stable replay process.
          </p>
          <p>
            That made the integration boundary direct rather than dramatic.
            Replay should produce evidence. QA Agents should investigate that
            evidence without mutating it, reproducing replay, or claiming
            authority over the final merge decision.
          </p>
          <ExternalLink
            href={meticulousUrl}
            label="Learn about Meticulous's replay testing platform"
          />
        </div>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>The integration problem</h2>
      </div>
      <div class="prose">
        <p>
          Introducing replay-shaped evidence exposed a coupling problem in QA
          Agents. Some behavior that should have belonged to an interpretation
          layer still lived too close to the investigation engine: evidence
          validation, clustering inputs, classification assumptions, summary
          behavior, decision rules, and CLI strategy selection.
        </p>
        <p>
          A narrow solution would have been to add a <code>meticulous</code>{
            " "
          }
          runtime mode and branch through the engine whenever replay evidence appeared.
          That would have worked for the demo, but it would have mixed evidence-source
          identity with investigation behavior. The next evidence source, such as
          API contract tests, accessibility audits, production traces, or static analysis,
          would have required another branch and another special case.
        </p>
        <p>
          The engine should not need to know where evidence originated in order
          to validate it, cluster it, classify it, summarize it, and evaluate a
          recommendation. QA Agents needed an abstraction for interpretation
          behavior, not a vendor-inspired mode embedded throughout the runtime.
        </p>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case split-section">
        <div>
          <h2>The Quality Strategy abstraction</h2>
        </div>
        <div class="prose">
          <p>
            The resulting split is between a <code>Profile</code>{" "}and a{" "}
            <code>Quality Strategy</code>. A profile describes who or what is
            being investigated: repository conventions, application routes, test
            layout, integrations, and tracker metadata. A Quality Strategy
            describes how a class of evidence should be validated, interpreted,
            clustered, classified, summarized, and constrained.
          </p>
          <p>
            The implemented strategy layer includes a filesystem-backed
            {" "}<code>StrategyRegistry</code>, strategy discovery through{" "}
            <code>strategy.yaml</code>, explicit decision rules in{" "}
            <code>decision-policy.yaml</code>, typed investigation domain
            objects, replay evidence validation, clustering features,
            classification rules, summary actions, CLI-boundary serialization,
            tests, and generated artifacts.
          </p>
          <p>
            Runtime loading is intentionally narrower than the directory shape.
            The current investigation path loads <code>strategy.yaml</code>,
            {" "}<code>decision-policy.yaml</code>, and the input evidence. The
            schema, prompts, example artifact, README, and strategy-specific
            tests document, validate, or demonstrate the strategy.
          </p>
          <div
            class="definition-pair"
            aria-label="Profile and quality strategy distinction"
          >
            <div>
              <strong>Profile</strong>
              <span>the target under investigation</span>
            </div>
            <div>
              <strong>Quality Strategy</strong>
              <span>the rules for interpreting a class of evidence</span>
            </div>
          </div>
          <ul class="compact-list">
            {implementationItems.map((item) => <li>{item}</li>)}
          </ul>
          <details class="supporting-details">
            <summary>Strategy directory excerpt</summary>
            <pre><code>{strategyFiles.join("\n")}</code></pre>
          </details>
        </div>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case">
        <div class="section-heading">
          <h2>Investigation pipeline</h2>
          <p>
            Replay remains responsible for capturing, selecting, executing, and
            comparing sessions. QA Agents starts after an immutable evidence
            package exists, then applies the configured strategy to produce
            traceable findings and a policy-constrained recommendation for human
            review.
          </p>
        </div>
        <div
          class="architecture-diagram"
          aria-label="Replay and QA Agents responsibility flow"
        >
          <div>
            <strong>Pull request</strong>
            <span>annual-plan pricing change</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Replay platform</strong>
            <span>capture • select • replay • compare</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Immutable evidence package</strong>
            <span>sessions • diffs • branches • coverage</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Quality Strategy</strong>
            <span>configure interpretation rules</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Investigation pipeline</strong>
            <span>cluster • classify • audit • evaluate policy</span>
          </div>
          <span aria-hidden="true">↓</span>
          <div>
            <strong>Human review</strong>
            <span>review and decide</span>
          </div>
        </div>
        <div class="responsibility-columns">
          <section>
            <h3>Replay platform responsibilities</h3>
            <ul>
              <li>session capture</li>
              <li>session selection</li>
              <li>deterministic execution</li>
              <li>base-versus-head comparison</li>
              <li>raw evidence production</li>
            </ul>
          </section>
          <section>
            <h3>QA Agents responsibilities</h3>
            <ul>
              <li>evidence validation</li>
              <li>workflow clustering</li>
              <li>difference classification</li>
              <li>coverage analysis</li>
              <li>policy evaluation</li>
              <li>human-facing recommendation</li>
            </ul>
          </section>
        </div>
        <p class="boundary-note">
          This exploration assumes replay evidence already exists. It does not
          simulate or reproduce Meticulous internals.
        </p>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>A simulated pricing investigation</h2>
      </div>
      <div class="prose">
        <p>
          The worked example uses a simulated annual-plan pricing change. The
          replay summary contains {evaluatedSessions} evaluated sessions,{" "}
          {selectedSessions} selected sessions, and {affectedSessions} affected sessions.
          QA Agents does not treat those affected sessions as separate issues. Multiple
          sessions can represent the same product workflow or the same underlying
          defect, so the strategy groups them into{" "}
          {workflowCount} workflow clusters before producing findings.
        </p>
        <p>
          The generated investigation separates {expectedDiffCount} expected textual
          differences from {regressionDiffCount} functional differences. The expected
          differences match <code>{knownExpectation.id}</code>, an explicit
          expectation that the annual discount label changed from{" "}
          <code>Save 10%</code> to <code>Save 12%</code>. The functional
          differences identify one shared one-cent rounding regression, where
          the annual total changes from <code>$108.00</code> to{" "}
          <code>$107.99</code>.
        </p>
        <p>
          The coverage audit also finds one changed branch without selected
          replay coverage: legacy coupon plus prorated annual upgrade. Because a
          confirmed functional regression matches the configured policy rule,
          the generated recommendation is <code>{recommendation}</code>. The
          artifact also marks <code>human_decision_required</code>, so the
          recommendation is advisory rather than autonomous authority.
        </p>
        <pre
          class="terminal"><code>python3 -m qa_agents investigate \
  --strategy meticulous \
  --input strategies/meticulous/fixtures/pricing-change.input.json \
  --output strategies/meticulous/examples/pricing-change.investigation.json</code></pre>
        <div class="run-output" aria-label="Simulated investigation outcome">
          <span>{evaluatedSessions} sessions evaluated</span>
          <span>{selectedSessions} sessions selected</span>
          <span>{affectedSessions} sessions affected</span>
          <span>{workflowCount} product workflows</span>
          <span>{expectedDiffCount} expected differences</span>
          <span
            >{investigation.summary.confirmed_regressions} shared rounding regression</span
          >
          <span>{coverageGapCount} uncovered changed branch</span>
          <span>Policy rule: {matchedRule}</span>
          <span>Recommendation: {recommendation}</span>
        </div>
        <div class="finding-grid">
          <article>
            <h3>Expected product change</h3>
            <ul>
              <li>{expectedDiffCount} textual differences</li>
              <li><code>Save 10%</code> to <code>Save 12%</code></li>
              <li>matched explicit expectation evidence</li>
              <li><code>{knownExpectation.id}</code></li>
            </ul>
          </article>
          <article>
            <h3>Confirmed regression</h3>
            <ul>
              <li>{regressionDiffCount} functional differences</li>
              <li><code>$108.00</code> to <code>$107.99</code></li>
              <li>one shared rounding regression</li>
            </ul>
          </article>
          <article>
            <h3>Residual coverage risk</h3>
            <ul>
              <li>one changed branch not exercised</li>
              <li>legacy coupon plus prorated annual upgrade</li>
              <li>
                coverage risk: {investigation.coverage_audit.coverage_risk}
              </li>
            </ul>
          </article>
        </div>
        <details class="supporting-details">
          <summary>Generated artifact and replay</summary>
          <p>
            The linked artifact is generated from simulated source data checked
            into the QA Agents repository. The interactive replay route remains
            a static presentation around the same investigation artifact.
          </p>
          <div class="inline-links">
            {
              artifactUrl && (
                <ExternalLink
                  href={artifactUrl}
                  label="View generated artifact"
                />
              )
            }
            <a
              class="button secondary"
              href="/projects/qa-agents/meticulous/replay/"
            >
              Open the interactive evidence replay
            </a>
          </div>
        </details>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case">
        <div class="section-heading">
          <h2>Implementation decisions</h2>
        </div>
        <div class="decision-list">
          <article>
            <h3>Preserve deterministic evidence</h3>
            <p>
              QA Agents do not sit inside replay execution or rewrite its
              output. Raw sessions, differences, branches, and coverage records
              remain the source of truth, while clusters and findings preserve
              references back to session IDs, difference IDs, branch IDs, and
              workflow cluster IDs.
            </p>
          </article>
          <article>
            <h3>Model workflows and findings explicitly</h3>
            <p>
              The implementation uses typed domain objects such as
              {" "}<code>WorkflowCluster</code>,{" "}
              <code>DifferenceFinding</code>, <code>CoverageFinding</code>,{" "}
              <code>PolicyDecision</code>, and{" "}
              <code>InvestigationResult</code>. Those objects represent
              different claims, so the system does not collapse raw session
              counts into bug reports.
            </p>
          </article>
          <article>
            <h3>Constrain recommendations with policy</h3>
            <p>
              <code>apply_decision_policy</code> computes metrics from the investigation
              and applies explicit deterministic rules. A recommendation can explain
              why the system suggests holding or reviewing a change, but it does not
              merge, approve, or bypass the reviewer.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>How the architecture changed during review</h2>
      </div>
      <div class="prose">
        <p>
          The first pass was strategy-shaped, but review showed that some
          important behavior still lived directly in Python. Clustering and
          classification were partly configurable, while summary behavior and
          CLI discovery still made the strategy boundary less explicit than it
          needed to be.
        </p>
        <p>
          The refinement moved clustering features, classification rules, and
          summary next actions into strategy configuration; kept decision rules
          explicit and deterministic; separated discovery from the CLI through
          {" "}<code>StrategyRegistry</code>; retained typed objects until
          serialization; and made malformed evidence actionable.
        </p>
        <pre
          class="terminal"><code>qa-agents investigate: Invalid evidence for strategy 'meticulous':
  - missing top-level field: case_id
  - source must be an object
  - sessions[0] missing session_id</code></pre>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case split-section">
        <div>
          <h2>Verification</h2>
        </div>
        <div class="prose">
          <ul class="proof-list">
            <li>38 tests passing</li>
            <li>compile check passing</li>
            <li>generated artifact reproducible</li>
            <li>malformed evidence tested</li>
            <li>all source data marked simulated</li>
            <li>no private APIs used</li>
          </ul>
          <pre
            class="terminal"><code>.venv/bin/python -m pytest
.venv/bin/python -m compileall qa_agents</code></pre>
          <p class="fine-note">
            Ruff and mypy are not currently configured as project checks.
          </p>
        </div>
      </div>
    </section>

    <section class="page-section wide-case split-section">
      <div>
        <h2>Limitations</h2>
      </div>
      <div class="prose">
        <ul class="compact-list single">
          <li>
            One implemented strategy does not prove every future strategy will
            fit.
          </li>
          <li>The engine remains replay-evidence-specific in places.</li>
          <li>
            Runtime validation is currently hand-coded rather than driven by
            {" "}<code>evidence-schema.json</code>.
          </li>
          <li>
            <code>decision-policy.yaml</code> currently contains JSON-shaped policy
            configuration.
          </li>
          <li>This is not a live Meticulous integration.</li>
          <li>This does not build or reproduce a replay engine.</li>
        </ul>
      </div>
    </section>

    <section class="page-section content-band">
      <div class="wide-case closing-section">
        <div>
          <h2>What changed in QA Agents</h2>
          <p>
            The Meticulous-inspired strategy is useful as a concrete
            implementation, but the broader result is the separation it forced
            inside QA Agents. The target being investigated, the source of
            evidence, the rules used to interpret that evidence, and the final
            human decision now sit behind clearer boundaries.
          </p>
          <p>
            That separation lets replay remain an evidence-producing layer while
            QA Agents performs a bounded investigation over the evidence. Future
            evidence sources should be able to enter through additional
            strategies instead of becoming new engine modes scattered across the
            runtime.
          </p>
        </div>
        <div class="closing-links">
          <ExternalLink href={meticulousUrl} label="Visit Meticulous" />
          {
            repositoryUrl && (
              <ExternalLink
                href={repositoryUrl}
                label="View QA Agents repository"
              />
            )
          }
          {
            architectureUrl && (
              <ExternalLink
                href={architectureUrl}
                label="Read Quality Strategy Architecture"
              />
            )
          }
          {
            artifactUrl && (
              <ExternalLink
                href={artifactUrl}
                label="View generated investigation artifact"
              />
            )
          }
          <a href="/projects/qa-agents/meticulous/replay/">
            Open the interactive evidence replay
          </a>
          <a href="/projects/qa-agents/">Main QA Agents project</a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .meticulous-writeup {
    display: grid;
  }

  .case-hero {
    display: grid;
    gap: var(--space-5);
    padding-block: var(--space-hero) var(--space-12);
  }

  .case-hero h1 {
    max-width: 980px;
    font-size: var(--text-page-title);
  }

  .case-hero .lede {
    max-width: 960px;
  }

  .disclaimer,
  .fine-note,
  .boundary-note {
    max-width: 840px;
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .opening-grid,
  .split-section {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: var(--section-gap);
    align-items: start;
  }

  .opening-grid h2,
  .split-section h2,
  .section-heading h2,
  .closing-section h2 {
    font-size: var(--text-h2);
  }

  .prose {
    display: grid;
    gap: var(--space-5);
  }

  .prose p,
  .section-heading p,
  .closing-section p {
    max-width: var(--reading-width);
    color: var(--color-text-muted);
  }

  .section-heading {
    display: grid;
    gap: var(--space-3);
    max-width: 820px;
    margin-bottom: var(--space-8);
  }

  .architecture-diagram {
    display: grid;
    gap: var(--space-3);
    max-width: 860px;
    margin-bottom: var(--space-8);
  }

  .architecture-diagram div,
  .definition-pair div,
  .finding-grid article,
  .responsibility-columns section,
  .decision-list article {
    border: 1px solid rgba(55, 40, 38, 0.18);
    border-radius: 6px;
    background: rgba(248, 240, 231, 0.72);
  }

  .architecture-diagram div {
    display: grid;
    gap: var(--space-1);
    border-left: 0.34rem solid var(--blue);
    padding: var(--space-4);
  }

  .architecture-diagram div:nth-of-type(2) {
    border-left-color: var(--houseplant);
  }

  .architecture-diagram div:nth-of-type(3) {
    border-left-color: var(--khaki);
  }

  .architecture-diagram div:nth-of-type(4) {
    border-left-color: var(--rust);
  }

  .architecture-diagram div:nth-of-type(5) {
    border-left-color: var(--lavender);
  }

  .architecture-diagram span[aria-hidden] {
    justify-self: center;
    color: var(--blue);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .architecture-diagram div span,
  .definition-pair span {
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .responsibility-columns,
  .finding-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .responsibility-columns {
    margin-bottom: var(--space-5);
  }

  .responsibility-columns section,
  .finding-grid article,
  .decision-list article {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
  }

  .responsibility-columns ul,
  .finding-grid ul {
    margin: 0;
    color: var(--color-text-muted);
  }

  .definition-pair {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .definition-pair div {
    display: grid;
    gap: var(--space-2);
    border-left: 0.32rem solid var(--blue);
    padding: var(--space-4);
  }

  .definition-pair div:nth-child(2) {
    border-left-color: var(--rust);
  }

  .compact-list,
  .proof-list {
    columns: 2;
    max-width: 820px;
    padding-left: var(--space-5);
  }

  .compact-list.single {
    columns: 1;
  }

  .supporting-details {
    max-width: 760px;
    border: 1px solid rgba(55, 40, 38, 0.18);
    border-radius: 6px;
    padding: var(--space-4);
    background: rgba(255, 248, 239, 0.58);
  }

  .supporting-details summary {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
