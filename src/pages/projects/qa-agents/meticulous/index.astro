    justify-self: center;
    color: var(--blue);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .architecture-diagram div span,
  .definition-pair span {
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .finding-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .finding-grid article {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
  }

  .finding-grid ul {
    margin: 0;
    color: var(--color-text-muted);
  }

  .definition-pair {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .definition-pair div {
    display: grid;
    gap: var(--space-2);
    border-left: 0.32rem solid var(--blue);
    padding: var(--space-4);
  }

  .definition-pair div:nth-child(2) {
    border-left-color: var(--rust);
  }

  .compact-list {
    columns: 2;
    max-width: 820px;
    padding-left: var(--space-5);
  }

  .compact-list.single {
    columns: 1;
  }

  .supporting-details {
    max-width: 760px;
    border: 1px solid rgba(55, 40, 38, 0.18);
    border-radius: 6px;
    padding: var(--space-4);
    background: rgba(255, 248, 239, 0.58);
  }

  .supporting-details summary {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
  }

  .supporting-details[open] summary {
