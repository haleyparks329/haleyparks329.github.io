  }

  pre {
    overflow-x: auto;
    border: 1px solid rgba(55, 40, 38, 0.24);
    border-radius: 6px;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--blue-soft) 38%, var(--canvas));
    color: var(--color-text);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .terminal {
    background: color-mix(in srgb, var(--ink) 88%, var(--plum));
    color: var(--paper);
  }

  .finding-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .finding-grid article {
    border-left: 0.32rem solid var(--blue);
  }

  .finding-grid article:nth-child(2) {
    border-left-color: var(--rust);
  }

  .finding-grid article:nth-child(3) {
    border-left-color: var(--khaki);
  }

  .closing-section {
    display: grid;
    gap: var(--space-6);
    padding-bottom: var(--space-hero);
  }

  .inline-links,
  .closing-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  @media (max-width: 900px) {
    .split-section,
    .definition-pair,
    .finding-grid,
    .summary-grid div {
      grid-template-columns: 1fr;
    }

    .compact-list {
      columns: 1;
    }
  }
</style>
