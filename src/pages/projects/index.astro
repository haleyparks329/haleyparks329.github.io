---
import { getCollection } from "astro:content";
import PageIntro from "@/components/PageIntro.astro";
import ProjectDirectoryCard from "@/components/ProjectDirectoryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects"
  description="Public project workspaces for Haley Parks' active systems, experiments, and publishing environment."
  canonicalPath="/projects/"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Projects" }]}
>
  <section class="site-shell projects-page">
    <PageIntro
      title="Projects"
      description="Active systems, experiments, and long-running bodies of work."
      text="Open a project workspace to inspect its overview, demos, related writing, and repository trail."
      meta={["5 active systems", "Public workspaces", "Repo-backed"]}
      note="Choose a file, then wander."
      accent="olive"
      width="wide"
    />
    <div class="project-directory-grid" aria-label="Project catalogue">
      {projects.map((project) => <ProjectDirectoryCard project={project} />)}
    </div>

    <nav class="project-page-links" aria-label="Project page next paths">
      <a href="/explore/">Browse all work in What’s Here?</a>
      <a href="/explore/trails/how-i-build/">Follow the How I Build trail</a>
      <a href="/explore/trails/ai-systems/">Follow the AI Systems trail</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .projects-page {
    margin-top: 0;
    padding-bottom: var(--space-8);
  }

  .project-directory-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
    align-items: stretch;
    margin-top: var(--page-section-start);
    margin-bottom: var(--space-8);
  }

  .project-page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    border-block: var(--border-width) solid var(--color-border);
    padding-block: var(--space-4);
  }

  .project-page-links a {
    color: var(--plum);
    font-size: var(--font-size-small);
    font-weight: 600;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 960px) {
    .project-directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .project-directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
