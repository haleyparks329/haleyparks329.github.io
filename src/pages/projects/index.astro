---
import { getCollection } from "astro:content";
import InteriorHeader from "@/components/InteriorHeader.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects"
  description="Public project summaries for The Human Model, Career Intelligence, and QA Agents."
>
  <section class="interior-container projects-page">
    <InteriorHeader
      eyebrow="Projects"
      title="Active systems shelf"
      text="Each project page frames the system as a public case study: the research question, evidence objects, current boundaries, and where the repository tells the deeper truth."
      meta={["3 active systems", "Public notes", "Repo-backed"]}
      objectLabel="Desk index"
      objectText="Research objects opened from the homepage desk."
      accent="olive"
    />
    <div class="project-shelf" aria-label="Active project objects">
      <div class="project-shelf-primary">
        {
          projects
            .filter((project) => project.data.slug === "the-human-model")
            .map((project) => <ProjectCard project={project} />)
        }
      </div>

      <div class="project-shelf-secondary">
        {
          projects
            .filter((project) => project.data.slug !== "the-human-model")
            .map((project) => <ProjectCard project={project} />)
        }
      </div>
    </div>

    <nav class="project-page-links" aria-label="Project page next paths">
      <a href="/explore/">Browse all work in What’s Here?</a>
      <a href="/explore/trails/how-i-build/">Follow the How I Build trail</a>
      <a href="/explore/trails/ai-systems/">Follow the AI Systems trail</a>
    </nav>
  </section>

  <section class="page-section">
    <div class="interior-container section-grid">
      <SectionHeading
        eyebrow="Ownership model"
        title="Presentation here, implementation elsewhere"
      />
      <div class="interior-note workspace-object surface-ochre tape-left">
        <p>
          This website owns the public story. Each repository owns the
          implementation and technical documentation.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .projects-page {
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .project-shelf {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(19rem, 0.95fr);
    gap: clamp(1rem, 2vw, 1.35rem);
    align-items: start;
    margin-bottom: clamp(2rem, 4vw, 4rem);
  }

  .project-page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    border-block: var(--border-width) solid var(--color-border);
    padding-block: var(--space-4);
  }

  .project-page-links a {
    color: var(--plum);
    font-size: var(--font-size-small);
    font-weight: 850;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .project-shelf-primary,
  .project-shelf-secondary {
    display: grid;
    min-width: 0;
    align-content: start;
    gap: clamp(1rem, 2vw, 1.35rem);
  }

  .project-shelf-primary > :global(*),
  .project-shelf-secondary > :global(*) {
    height: auto;
    min-height: 0;
    align-self: start;
  }

  :global(.projects-page .interior-header h1) {
    max-width: 15ch;
  }

  :global(.project-shelf-secondary .project-career-intelligence) {
    margin-top: clamp(0.25rem, 1vw, 0.7rem);
  }

  @media (max-width: 980px) {
    .project-shelf {
      grid-template-columns: 1fr;
    }

    :global(.project-shelf-secondary .project-career-intelligence) {
      margin-top: 0;
    }
  }
</style>
