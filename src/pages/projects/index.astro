---
import { getCollection } from "astro:content";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects"
  description="Public project summaries for The Human Model, Career Intelligence, and QA Agents."
>
  <section class="page-section container">
    <SectionHeading
      eyebrow="Projects"
      title="A small public map of active systems"
      text="Each project keeps its implementation details in its own repository. This page gives the short version: what the project is, what question it explores, current status, and where to read more."
    />
    <div class="card-grid project-list">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="page-section content-band">
    <div class="container section-grid">
      <SectionHeading
        eyebrow="Ownership model"
        title="Presentation here, implementation elsewhere"
      />
      <div class="stack">
        <p>
          The Human Model, Career Intelligence, and QA Agents each keep their
          canonical code and technical documentation in their own repositories.
          This website owns public presentation, navigation, cross-project
          storytelling, and publishing.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .project-list {
    margin-top: 2rem;
  }
</style>
