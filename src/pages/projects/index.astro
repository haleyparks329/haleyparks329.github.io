---
import { getCollection } from "astro:content";
import PageIntro from "@/components/PageIntro.astro";
import ProjectFile from "@/components/ProjectFile.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects"
  description="Public project summaries for The Human Model, Career Intelligence, and QA Agents."
>
  <section class="wide-case projects-page">
    <PageIntro
      eyebrow="Projects"
      title="Things I'm building"
      text="Public project files for the systems that are active enough to inspect: what they explore, what exists today, and where the repository tells the deeper truth."
      meta={["3 active systems", "Public notes", "Repo-backed"]}
      note="Same desk, calmer shelf."
      accent="olive"
      width="wide"
    />
    <div class="project-shelf" aria-label="Active project objects">
      <div class="project-shelf-primary">
        {
          projects
            .filter((project) => project.data.slug === "the-human-model")
            .map((project) => (
              <ProjectFile project={project} variant="featured" />
            ))
        }
      </div>

      <div class="project-shelf-secondary">
        {
          projects
            .filter((project) => project.data.slug !== "the-human-model")
            .map((project) => <ProjectFile project={project} />)
        }
      </div>
    </div>

    <nav class="project-page-links" aria-label="Project page next paths">
      <a href="/explore/">Browse all work in What’s Here?</a>
      <a href="/explore/trails/how-i-build/">Follow the How I Build trail</a>
      <a href="/explore/trails/ai-systems/">Follow the AI Systems trail</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .projects-page {
    padding-bottom: var(--space-8);
  }

  .project-shelf {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(19rem, 0.95fr);
    gap: var(--space-6);
    align-items: start;
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .project-page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    border-block: var(--border-width) solid var(--color-border);
    padding-block: var(--space-4);
  }

  .project-page-links a {
    color: var(--plum);
    font-size: var(--font-size-small);
    font-weight: 600;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .project-shelf-primary,
  .project-shelf-secondary {
    display: grid;
    min-width: 0;
    align-content: start;
    gap: var(--space-6);
  }

  @media (max-width: 980px) {
    .project-shelf {
      grid-template-columns: 1fr;
    }
  }
</style>
