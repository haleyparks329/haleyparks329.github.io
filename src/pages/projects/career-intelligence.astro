---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCaseStudy from "@/components/ProjectCaseStudy.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "career-intelligence",
);
if (!project) {
  throw new Error("Missing Career Intelligence project entry");
}

const relatedLogs = (await getCollection("fieldLog"))
  .filter((entry) => ["evidence-before-claims"].includes(entry.data.slug))
  .map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    href: `/field-log/#${entry.data.slug}`,
  }));

const evidence = [
  {
    title: "Source-backed career evidence",
    text: "The public slice starts with structured synthetic career data and validates it against a schema before any generated materials are produced.",
  },
  {
    title: "Separated reasoning layers",
    text: "Evidence ranking, role matching, positioning, interview prep, and rendering stay separated so outputs remain grounded in what the data supports.",
  },
  {
    title: "Synthetic demo workflow",
    text: "The public repository includes a deterministic Andy Barks example for inspecting outputs without exposing private career data.",
  },
];

const systems = [
  {
    title: "Structured evidence",
    text: "Career details become typed source material instead of loose resume language.",
  },
  {
    title: "Evidence ranking",
    text: "The system ranks source-backed evidence before turning it into match reports or positioning notes.",
  },
  {
    title: "Person-model boundaries",
    text: "Reflection and preference signals can shape reasoning without becoming unsupported resume claims.",
  },
  {
    title: "Conservative rendering",
    text: "Generated artifacts are treated as demo outputs and helpers, not automated application submission or recruiter outreach.",
  },
];
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/career-intelligence/"
>
  <ProjectCaseStudy
    project={project}
    eyebrow="Research case study"
    thesis="A source-backed career reasoning engine that keeps evidence, person context, fit analysis, and generated materials in their own lanes."
    researchQuestion={project.data.coreQuestion}
    evidence={evidence}
    systems={systems}
    boundaries={[
      "Public synthetic data model and schema validation",
      "Source-backed evidence ranking and role match analysis",
      "No claims of automated application submission or recruiter outreach",
      "No production users or performance metrics claimed",
    ]}
    links={[
      ...(project.data.repositoryUrl
        ? [
            {
              href: project.data.repositoryUrl,
              label: "Career Intelligence repository",
              external: true,
            },
          ]
        : []),
      {
        href: "https://github.com/haleyparks329/career-intelligence/tree/main/examples/andy-barks/generated",
        label: "Synthetic demo outputs",
        external: true,
      },
    ]}
    relatedLogs={relatedLogs}
    featuredObject={{
      title: "Career reasoning flow",
      text: "The interesting question is not only whether a person matches a job description. It is whether a system can preserve the evidence behind a career story, surface transferable skills, keep caveats visible, and use a person model without turning reflection-only claims into resume claims.",
    }}
  >
    <div
      slot="featured"
      class="diagram"
      aria-label="Career Intelligence data flow"
    >
      <div class="diagram-row">
        <div class="diagram-node">Structured evidence</div>
        <div class="diagram-node">Schema validation</div>
        <div class="diagram-node">Evidence ranking</div>
      </div>
      <div class="diagram-node center">Career reasoning layer</div>
      <div class="diagram-row">
        <div class="diagram-node">Match report</div>
        <div class="diagram-node">Positioning notes</div>
        <div class="diagram-node">Interview prep</div>
      </div>
    </div>
  </ProjectCaseStudy>
</BaseLayout>
