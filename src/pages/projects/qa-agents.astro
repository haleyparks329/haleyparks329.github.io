---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCaseStudy from "@/components/ProjectCaseStudy.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const relatedLogs = (await getCollection("fieldLog"))
  .filter((entry) => ["evidence-before-claims"].includes(entry.data.slug))
  .map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    href: `/field-log/#${entry.data.slug}`,
  }));

const evidence = [
  {
    title: "Recorded evidence replay",
    text: "The public page features one replay built from a Little Bytes pricing diff, passing test run, coverage evidence, persisted gap, and Scribe recommendation.",
  },
  {
    title: "Profile-aware QA planning",
    text: "The experiment asks whether app profiles, shared rules, and stable gap records make QA planning more specific.",
  },
  {
    title: "Human review boundary",
    text: "The replay explicitly records that no autonomous patches, generated tests, or agent dispatches happened in the artifact.",
  },
];

const systems = [
  {
    title: "Agent specs",
    text: "Profile-aware agent descriptions and shared rules define how agents should act, block, or abstain.",
  },
  {
    title: "SQLite knowledge base",
    text: "Local-first persistence keeps fingerprints, gaps, and handoff debt inspectable.",
  },
  {
    title: "Advisory routing",
    text: "Recommendations can route attention without pretending to orchestrate full execution.",
  },
  {
    title: "Beacon prototype",
    text: "A narrow deterministic prototype turns simulated feature requests into QA plans for inspection.",
  },
];

const agentRoster = [
  {
    agent: "Beacon",
    emoji: "🧭",
    responsibility: "Scope QA work and create test plans",
    status: "Prototype via deterministic CLI",
  },
  {
    agent: "Patch",
    emoji: "🩹",
    responsibility: "Investigate and repair failing browser tests",
    status: "Planned beyond fingerprinting and routing foundations",
  },
  {
    agent: "Lookout",
    emoji: "🔭",
    responsibility: "Explore for bugs and risky behavior",
    status: "Planned",
  },
  {
    agent: "Scribe",
    emoji: "✍️",
    responsibility:
      "Author or update tests from accepted plans, specs, bugs, or gaps",
    status: "Prototype via stubs and routing target",
  },
  {
    agent: "Inspector",
    emoji: "🔍",
    responsibility: "Review coverage gaps and system behavior",
    status: "Prototype via KB query surfaces",
  },
];
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/qa-agents/"
>
  <ProjectCaseStudy
    project={project}
    eyebrow="Research case study"
    thesis="An experiment in agent-assisted QA where the important work is keeping context, gaps, and human review visible."
    researchQuestion={project.data.coreQuestion}
    evidence={evidence}
    systems={systems}
    boundaries={[
      "Implemented foundations and prototype slices are public",
      "Browser probing, selector healing, live dashboards, and PR creation remain planned unless the repository shows otherwise",
      "The replay is recorded evidence, not a live autonomous browser run",
      "The system recommends next action; it does not claim full handoff execution",
    ]}
    boundaryItems={[
      {
        label: "Implemented",
        text: "Implemented foundations and prototype slices are public",
      },
      {
        label: "Planned",
        text: "Browser probing, selector healing, live dashboards, and PR creation remain planned unless the repository shows otherwise",
      },
      {
        label: "Demonstrated",
        text: "The replay is recorded evidence, not a live autonomous browser run",
      },
      {
        label: "Boundary",
        text: "The system recommends next action; it does not claim full handoff execution",
      },
    ]}
    links={[
      {
        href: "/projects/qa-agents/demo/",
        label: "Interactive evidence replay",
      },
      ...(project.data.repositoryUrl
        ? [
            {
              href: project.data.repositoryUrl,
              label: "QA Agents repository",
              external: true,
            },
          ]
        : []),
    ]}
    relatedLogs={relatedLogs}
    featuredObject={{
      title: "Evidence replay",
      text: "The replay turns one concrete scenario into an inspectable object: change, tests, coverage gap, persisted record, and recommendation. It is intentionally framed as evidence, not autonomy.",
    }}
  >
    <div slot="featured" class="replay-object">
      <ol>
        <li>Little Bytes pricing changed</li>
        <li>Tests passed</li>
        <li>Coverage gap found</li>
        <li>Gap persisted</li>
        <li>Scribe recommended next action</li>
      </ol>
      <a class="button secondary" href="/projects/qa-agents/demo/">
        Open evidence replay
      </a>
      <div class="strategy-replay-note">
        <p class="eyebrow">Strategy exploration</p>
        <h3>Meticulous-inspired replay investigation</h3>
        <p>
          A simulated example showing how QA Agents can turn deterministic
          replay evidence into workflow clusters, findings, coverage risks, and
          a policy-constrained merge recommendation.
        </p>
        <a href="/projects/qa-agents/meticulous/"> View strategy replay → </a>
      </div>
    </div>
  </ProjectCaseStudy>
  <section class="page-section wide-case agent-roster-section">
    <div>
      <p class="eyebrow">Full team</p>
      <h2>QA agent roster</h2>
    </div>
    <div class="agent-roster" aria-label="QA Agents full team">
      {
        agentRoster.map((agent) => (
          <article class="agent-roster-item">
            <h3>
              <span aria-hidden="true">{agent.emoji}</span>
              {agent.agent}
            </h3>
            <p>{agent.responsibility}</p>
            <span>{agent.status}</span>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .agent-roster-section {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: var(--section-gap);
    align-items: start;
  }

  .agent-roster-section h2 {
    font-family: var(--font-serif);
    font-size: var(--font-size-section-title);
  }

  .agent-roster {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--grid-gap);
  }

  .agent-roster-item {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
    border-left: 0.3rem solid var(--plum);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    background: var(--color-surface-raised);
  }

  .agent-roster-item h3 {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    margin: 0;
  }

  .agent-roster-item p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .agent-roster-item span:not([aria-hidden]) {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 800;
    text-transform: uppercase;
  }

  .replay-object {
    display: grid;
    gap: var(--space-4);
  }

  .replay-object ol {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding-left: var(--space-5);
  }

  .strategy-replay-note {
    display: grid;
    gap: var(--space-2);
    border: 1px solid rgba(55, 40, 38, 0.18);
    border-left: 0.28rem solid var(--blue);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    background: rgba(248, 240, 231, 0.58);
  }

  .strategy-replay-note h3,
  .strategy-replay-note p {
    margin: 0;
  }

  .strategy-replay-note h3 {
    font-size: 1.02rem;
  }

  .strategy-replay-note p:not(.eyebrow) {
    color: var(--color-text-muted);
    font-size: var(--font-size-small);
  }

  .strategy-replay-note a {
    width: fit-content;
    color: var(--plum);
    font-weight: 850;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 760px) {
    .agent-roster-section,
    .agent-roster {
      grid-template-columns: 1fr;
    }
  }
</style>
