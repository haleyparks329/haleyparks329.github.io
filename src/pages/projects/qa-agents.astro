---
import { getCollection } from "astro:content";
import ExternalLink from "@/components/ExternalLink.astro";
import StatusBadge from "@/components/StatusBadge.astro";
import TagList from "@/components/TagList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/qa-agents/"
>
  <section class="page-section container text-page">
    <p class="eyebrow">Experimental project</p>
    <h1>{project.data.title}</h1>
    <p class="lede">{project.data.summary}</p>
    <div class="button-row">
      <StatusBadge status={project.data.status} accent={project.data.accent} />
      {
        project.data.repositoryUrl && (
          <ExternalLink href={project.data.repositoryUrl} label="Repository" />
        )
      }
    </div>
    <TagList tags={project.data.tags} />

    <h2>Short overview</h2>
    <p>
      QA Agents is an early experiment exploring where agent-based workflows may
      support software-quality work.
    </p>

    <h2>Problem being explored</h2>
    <p>
      Generating tests is easy to demo. Useful QA work depends on context:
      critical flows, risk areas, constraints, app profiles, previous gaps, and
      the parts of the system where a human still needs to inspect the result.
    </p>

    <h2>Current experiment</h2>
    <p>
      The repository explores a local-first QA agent operating system with
      profile-aware agent specs, shared rules, a SQLite knowledge base, stable
      error fingerprinting, gap records, advisory routing, and a narrow
      deterministic Herbie prototype for turning simulated feature requests into
      QA plans.
    </p>
    <p>
      The recorded evidence replay is built from a real Little Bytes diff,
      passing test run, coverage evidence, persisted gap, and Quill
      recommendation.
    </p>

    <h2>What is being tested</h2>
    <ul class="quiet-list split-list">
      <li>Whether app profiles make QA planning more specific</li>
      <li>How agents should act, block, or abstain</li>
      <li>How gaps and handoff debt can stay inspectable</li>
      <li>
        Where advisory routing helps without pretending to orchestrate work
      </li>
    </ul>

    <h2>Status and link</h2>
    <p>
      This page stays intentionally small because the project is experimental.
      The repo includes implemented foundations and prototype slices, while
      browser probing, selector healing, digest workflows, live dashboards,
      handoff execution, and PR creation remain planned unless the repository
      shows otherwise.
    </p>
    <div class="button-row">
      <a class="button secondary" href="/projects/qa-agents/demo/">
        Interactive evidence replay
      </a>
      {
        project.data.repositoryUrl && (
          <ExternalLink
            href={project.data.repositoryUrl}
            label="QA Agents repository"
          />
        )
      }
    </div>
  </section>
</BaseLayout>
