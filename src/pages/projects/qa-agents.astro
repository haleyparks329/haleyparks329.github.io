---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCaseStudy from "@/components/ProjectCaseStudy.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "qa-agents",
);
if (!project) {
  throw new Error("Missing QA Agents project entry");
}

const relatedLogs = (await getCollection("fieldLog"))
  .filter((entry) => ["evidence-before-claims"].includes(entry.data.slug))
  .map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    href: `/field-log/#${entry.data.slug}`,
  }));

const evidence = [
  {
    title: "Recorded evidence replay",
    text: "The public page features one replay built from a Little Bytes pricing diff, passing test run, coverage evidence, persisted gap, and Quill recommendation.",
  },
  {
    title: "Profile-aware QA planning",
    text: "The experiment asks whether app profiles, shared rules, and stable gap records make QA planning more specific.",
  },
  {
    title: "Human review boundary",
    text: "The replay explicitly records that no autonomous patches, generated tests, or agent dispatches happened in the artifact.",
  },
];

const systems = [
  {
    title: "Agent specs",
    text: "Profile-aware agent descriptions and shared rules define how agents should act, block, or abstain.",
  },
  {
    title: "SQLite knowledge base",
    text: "Local-first persistence keeps fingerprints, gaps, and handoff debt inspectable.",
  },
  {
    title: "Advisory routing",
    text: "Recommendations can route attention without pretending to orchestrate full execution.",
  },
  {
    title: "Herbie prototype",
    text: "A narrow deterministic prototype turns simulated feature requests into QA plans for inspection.",
  },
];
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/qa-agents/"
>
  <ProjectCaseStudy
    project={project}
    eyebrow="Research case study"
    thesis="An experiment in agent-assisted QA where the important work is keeping context, gaps, and human review visible."
    researchQuestion={project.data.coreQuestion}
    evidence={evidence}
    systems={systems}
    boundaries={[
      "Implemented foundations and prototype slices are public",
      "Browser probing, selector healing, live dashboards, and PR creation remain planned unless the repository shows otherwise",
      "The replay is recorded evidence, not a live autonomous browser run",
      "The system recommends next action; it does not claim full handoff execution",
    ]}
    boundaryItems={[
      {
        label: "Implemented",
        text: "Implemented foundations and prototype slices are public",
      },
      {
        label: "Planned",
        text: "Browser probing, selector healing, live dashboards, and PR creation remain planned unless the repository shows otherwise",
      },
      {
        label: "Demonstrated",
        text: "The replay is recorded evidence, not a live autonomous browser run",
      },
      {
        label: "Boundary",
        text: "The system recommends next action; it does not claim full handoff execution",
      },
    ]}
    links={[
      {
        href: "/projects/qa-agents/demo/",
        label: "Interactive evidence replay",
      },
      ...(project.data.repositoryUrl
        ? [
            {
              href: project.data.repositoryUrl,
              label: "QA Agents repository",
              external: true,
            },
          ]
        : []),
    ]}
    relatedLogs={relatedLogs}
    featuredObject={{
      title: "Evidence replay",
      text: "The replay turns one concrete scenario into an inspectable object: change, tests, coverage gap, persisted record, and recommendation. It is intentionally framed as evidence, not autonomy.",
    }}
  >
    <div slot="featured" class="replay-object">
      <ol>
        <li>Little Bytes pricing changed</li>
        <li>Tests passed</li>
        <li>Coverage gap found</li>
        <li>Gap persisted</li>
        <li>Quill recommended next action</li>
      </ol>
      <a class="button secondary" href="/projects/qa-agents/demo/">
        Open evidence replay
      </a>
    </div>
  </ProjectCaseStudy>
</BaseLayout>

<style>
  .replay-object {
    display: grid;
    gap: var(--space-4);
  }

  .replay-object ol {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding-left: var(--space-5);
  }
</style>
