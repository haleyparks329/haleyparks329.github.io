---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCaseStudy from "@/components/ProjectCaseStudy.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "the-human-model",
);
if (!project) {
  throw new Error("Missing The Human Model project entry");
}

const relatedLogs = (await getCollection("fieldLog"))
  .filter((entry) =>
    ["attention-is-the-scarce-resource", "evidence-before-claims"].includes(
      entry.data.slug,
    ),
  )
  .map((entry) => ({
    title: entry.data.title,
    summary: entry.data.summary,
    href: `/field-log/#${entry.data.slug}`,
  }));

const evidence = [
  {
    title: "Human signals as evidence",
    text: "The public story connects wearable data, training logs, conversational context, biomechanics, and machine learning without claiming a finished generalized coaching product.",
  },
  {
    title: "Feedback loop",
    text: "The core research loop is Measure -> Model -> Reason -> Adapt: collect signals, structure them, reason about the person changing over time, and learn from the next action.",
  },
  {
    title: "Implemented surfaces",
    text: "Bridget, dashboard work, predictive models, movement analysis, and hardware experiments are presented as system parts with different maturity levels.",
  },
];

const systems = [
  {
    title: "Bridget",
    text: "Captures conversations, observations, and context that numbers miss, turning everyday interactions into structured evidence.",
  },
  {
    title: "Decision Support Dashboard",
    text: "Brings recovery, training, body measurements, and system health together as a review layer for better questions and next decisions.",
  },
  {
    title: "Predictive and movement models",
    text: "Explores whether past training, recovery, and movement data can become hypotheses that are tested in real sessions.",
  },
  {
    title: "Experimental hardware",
    text: "Investigates which additional signals might make the Human Model more complete beyond today's wearable data.",
  },
];
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/the-human-model/"
>
  <ProjectCaseStudy
    project={project}
    eyebrow="Research case study"
    thesis="A personal research platform for understanding adaptation as a changing system, not a pile of disconnected metrics."
    researchQuestion={project.data.coreQuestion}
    evidence={evidence}
    systems={systems}
    boundaries={[
      "Active personal research platform",
      "Experimental modeling and interface work",
      "Building in public through docs, examples, and public summaries",
      "Not a finished product or generalized coaching system",
    ]}
    boundaryItems={[
      {
        label: "Implemented",
        text: "Active personal research platform",
      },
      {
        label: "Demonstrated",
        text: "Building in public through docs, examples, and public summaries",
      },
      {
        label: "Planned",
        text: "Experimental modeling and interface work",
      },
      {
        label: "Boundary",
        text: "Not a finished product or generalized coaching system",
      },
    ]}
    links={[
      ...(project.data.repositoryUrl
        ? [
            {
              href: project.data.repositoryUrl,
              label: "Human Model repository",
              external: true,
            },
          ]
        : []),
      {
        href: "https://github.com/haleyparks329/the-human-model/tree/main/examples",
        label: "Public examples",
        external: true,
      },
    ]}
    relatedLogs={relatedLogs}
    featuredObject={{
      title: "Measure -> Model -> Reason -> Adapt",
      text: "Most fitness tools stop at measurement. The Human Model asks what comes next: how scattered signals can become structured evidence, how that evidence can support reasoning, and how the next action can teach the system something new.",
    }}
  >
    <div
      slot="featured"
      class="artifact-flow loop-flow"
      aria-label="Measure, model, reason, adapt loop"
    >
      <span>Measure</span>
      <span>Model</span>
      <span>Reason</span>
      <span>Adapt</span>
    </div>
  </ProjectCaseStudy>
</BaseLayout>
