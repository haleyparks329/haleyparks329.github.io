---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "career-intelligence",
);
if (!project) {
  throw new Error("Missing Career Intelligence project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
---

<BaseLayout
  title={`System | ${project.data.title}`}
  description="How Career Intelligence connects career evidence, role matching, positioning, prep, and generated public-safe artifacts."
  canonicalPath="/projects/career-intelligence/system/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/career-intelligence/" },
    { label: "System" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="System"
    documentSummary="Inputs, processing, outputs, current status, and the public-safe technical notes behind the career reasoning workflow."
  >
    <ProjectDocumentContent
      statusRows={document.statusRows}
      currentDirection={document.currentDirection}
      howItWorks={document.howItWorks}
      appendix={document.appendix}
      nextHref="/projects/career-intelligence/research/"
      nextLabel="Open the deep dives"
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
