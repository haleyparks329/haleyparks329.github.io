---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { connectedDestinations } from "@/data/navigation";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "career-intelligence",
);
if (!project) {
  throw new Error("Missing Career Intelligence project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
const continueLinks = connectedDestinations(
  "project-career-intelligence-research",
);
---

<BaseLayout
  title={`Deep Dives | ${project.data.title}`}
  description="Career Intelligence examples, learnings, current limits, and related writing."
  canonicalPath="/projects/career-intelligence/research/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/career-intelligence/" },
    { label: "Deep Dives" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="Deep Dives"
    documentSummary="Examples, lessons, and limitations from treating career work as evidence-backed reasoning."
  >
    <ProjectDocumentContent
      example={document.example}
      learnings={document.learnings}
      notSolved={document.notSolved}
      continueLinks={continueLinks}
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
