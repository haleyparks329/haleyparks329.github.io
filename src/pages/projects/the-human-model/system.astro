---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "the-human-model",
);
if (!project) {
  throw new Error("Missing The Human Model project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
---

<BaseLayout
  title={`System | ${project.data.title}`}
  description="How The Human Model connects inputs, processing, outputs, storage notes, and technical appendix details."
  canonicalPath="/projects/the-human-model/system/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/the-human-model/" },
    { label: "System" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="System"
    documentSummary="Inputs, processing, outputs, Bridget's role, and the technical notes currently safe to summarize publicly."
  >
    <ProjectDocumentContent
      howItWorks={document.howItWorks}
      appendix={document.appendix}
      nextHref="/projects/the-human-model/research/"
      nextLabel="View the research"
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
