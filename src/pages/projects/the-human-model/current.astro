---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { connectedDestinations } from "@/data/navigation";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "the-human-model",
);
if (!project) {
  throw new Error("Missing The Human Model project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
const continueLinks = connectedDestinations("project-the-human-model-current");
---

<BaseLayout
  title={`Current Project | ${project.data.title}`}
  description="Current status, active work, limitations, and direction for The Human Model."
  canonicalPath="/projects/the-human-model/current/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/the-human-model/" },
    { label: "Current Project" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="Current Project"
    documentSummary="What exists today, what is active now, and where the project is being cleaned up next."
  >
    <ProjectDocumentContent
      statusRows={document.statusRows}
      currentDirection={document.currentDirection}
      continueLinks={continueLinks}
      nextHref="/projects/the-human-model/system/"
      nextLabel="View the system"
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
