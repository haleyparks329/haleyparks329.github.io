---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { relatedLinksForHrefs } from "@/data/navigation";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "the-human-model",
);
if (!project) {
  throw new Error("Missing The Human Model project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
const continueLinks = relatedLinksForHrefs(
  [
    "/projects/the-human-model/current/",
    "/projects/bridget/",
    "/field-log/attention-is-the-scarce-resource/",
    "/projects/career-intelligence/",
    "/explore/",
  ],
  "project-the-human-model",
);
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonicalPath="/projects/the-human-model/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="Overview"
    documentSummary="What The Human Model is, why it exists, and what kind of work it is trying to make easier to reason about."
  >
    <ProjectDocumentContent
      abstract={document.abstract}
      why={document.why}
      actuallyDoes={document.actuallyDoes}
      links={document.links}
      continueLinks={continueLinks}
      nextHref="/projects/the-human-model/current/"
      nextLabel="View current work"
    />
    <p class="bridget-relationship">
      The Human Model tries to understand patterns in my performance. <a
        href="/projects/bridget/">Bridget</a
      > is a separate orchestration system that helps keep the information those patterns
      depend on from getting lost.
    </p>
  </ProjectWorkspaceLayout>
</BaseLayout>

<style>
  .bridget-relationship {
    max-width: var(--reading-measure);
    margin-top: var(--space-6);
    border-left: 0.22rem solid var(--plum);
    padding: var(--space-3) var(--space-4);
    background: color-mix(in srgb, var(--plum) 7%, var(--paper));
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .bridget-relationship a {
    color: var(--plum);
    font-weight: 650;
  }
</style>
