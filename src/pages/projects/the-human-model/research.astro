---
import { getCollection } from "astro:content";
import ProjectDocumentContent from "@/components/ProjectDocumentContent.astro";
import { projectDocumentForSlug } from "@/data/project-documents";
import { connectedDestinations } from "@/data/navigation";
import { workspaceForSlug } from "@/data/project-workspaces";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectWorkspaceLayout from "@/layouts/ProjectWorkspaceLayout.astro";

const project = (await getCollection("projects")).find(
  (entry) => entry.data.slug === "the-human-model",
);
if (!project) {
  throw new Error("Missing The Human Model project entry");
}

const workspace = workspaceForSlug(project.data.slug);
const document = projectDocumentForSlug(project.data.slug);
const continueLinks = connectedDestinations("project-the-human-model-research");
---

<BaseLayout
  title={`Research | ${project.data.title}`}
  description="Research examples, learnings, open limits, and public-safe evidence for The Human Model."
  canonicalPath="/projects/the-human-model/research/"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects/" },
    { label: project.data.title, href: "/projects/the-human-model/" },
    { label: "Research" },
  ]}
>
  <ProjectWorkspaceLayout
    project={project}
    workspace={workspace}
    documentTitle="Research"
    documentSummary="Concrete examples, what the work has taught me, and the limits that keep the project honest."
  >
    <ProjectDocumentContent
      example={document.example}
      learnings={document.learnings}
      notSolved={document.notSolved}
      continueLinks={continueLinks}
    />
  </ProjectWorkspaceLayout>
</BaseLayout>
