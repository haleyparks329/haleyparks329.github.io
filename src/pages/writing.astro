---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const fieldLogEntries = (await getCollection("fieldLog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const writingCategories = [
  {
    title: "Research Notes",
    summary: "Open questions, experiments, and synthesis from active work.",
    category: "Research",
  },
  {
    title: "Systems Thinking",
    summary: "Notes on how pieces connect, fail, adapt, and become useful.",
    category: "Systems",
  },
  {
    title: "Human Model",
    summary:
      "Writing about performance, context, training, and person-centered AI.",
    category: "Human Modeling",
  },
  {
    title: "Personal Computing",
    summary:
      "Ideas about software that remembers and coordinates on a person's behalf.",
    category: "Personal AI",
  },
  {
    title: "Build Notes",
    summary: "Implementation notes once public writeups are ready.",
    category: "Build Notes",
  },
];
---

<BaseLayout
  title="Writing"
  description="Notes on personal AI, human modeling, performance systems, software, and building in public."
>
  <section class="writing-page">
    <header class="writing-header reading-column">
      <p class="eyebrow">Writing</p>
      <h1>
        Longer notes on personal AI, human modeling, systems thinking, and
        building in public.
      </h1>
      <p>
        This is the publication shelf for more finished essays. Longer pieces
        are still being organized; shorter active observations live in the Field
        Log.
      </p>
    </header>

    <section class="featured-publication" aria-labelledby="featured-writing">
      <div>
        <p class="eyebrow">Featured essay</p>
        <h2 id="featured-writing">Publication object coming soon</h2>
      </div>
      <article class="publication-object">
        <p class="eyebrow">Drafting shelf</p>
        <h3>No long-form essay is published here yet.</h3>
        <p>
          When the first essay is ready, this space will hold one featured piece
          with its title, summary, category, and reading time. Until then, the
          page stays honest about what exists.
        </p>
      </article>
    </section>

    <section class="reading-column article-index" aria-labelledby="essay-index">
      <div class="section-kicker">
        <p class="eyebrow">Essay archive</p>
        <h2 id="essay-index">Planned shelves</h2>
      </div>

      <div class="article-list">
        {
          writingCategories.map((item) => (
            <article class="article-row">
              <p class="article-date">Draft shelf</p>
              <div>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <p class="article-meta">{item.category} · Reading time TBD</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <aside class="reading-column field-log-bridge">
      <p>
        <strong>Looking for shorter notes?</strong>
        {" "}
        The Field Log contains active build observations and working thoughts.
      </p>
      <a href="/field-log/">Open Field Log</a>
    </aside>

    {
      fieldLogEntries.length > 0 && (
        <section
          class="reading-column latest-notes"
          aria-labelledby="latest-field-log"
        >
          <div class="section-kicker">
            <p class="eyebrow">From Field Log</p>
            <h2 id="latest-field-log">Recent working notes</h2>
          </div>
          <div class="note-link-list">
            {fieldLogEntries.slice(0, 3).map((entry) => (
              <article>
                <p>{entry.data.category}</p>
                <h3>{entry.data.title}</h3>
                <p>{entry.data.summary}</p>
                <a href={`/field-log/#${entry.data.slug}`}>Read note</a>
              </article>
            ))}
          </div>
        </section>
      )
    }
  </section>
</BaseLayout>

<style>
  .writing-page {
    padding-bottom: clamp(3rem, 6vw, 5.5rem);
  }

  .writing-header {
    padding-block: clamp(2.4rem, 5vw, 4rem);
  }

  .writing-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.4vw, 3.25rem);
    line-height: 1.05;
  }

  .writing-header p:not(.eyebrow) {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  .featured-publication {
    display: grid;
    grid-template-columns: minmax(0, 0.58fr) minmax(0, 1fr);
    gap: var(--section-gap);
    width: min(var(--case-width), calc(100% - var(--container-gutter)));
    margin-inline: auto;
    border-block: var(--border-width) solid var(--color-border);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
  }

  .featured-publication h2,
  .section-kicker h2 {
    font-family: var(--font-serif);
    font-size: var(--font-size-section-title);
  }

  .publication-object {
    position: relative;
    min-width: 0;
    border: var(--border-width) solid var(--color-border);
    border-left: 0.35rem solid var(--lavender);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .publication-object::before {
    position: absolute;
    top: -0.62rem;
    right: 12%;
    width: 3.8rem;
    height: 0.85rem;
    background: color-mix(in srgb, var(--khaki) 44%, transparent);
    content: "";
    transform: rotate(-2deg);
  }

  .publication-object h3 {
    margin-bottom: var(--space-3);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.2vw, 2rem);
  }

  .publication-object p:not(.eyebrow) {
    color: var(--color-text-muted);
  }

  .article-index,
  .field-log-bridge,
  .latest-notes {
    margin-top: clamp(2.5rem, 5vw, 4.5rem);
  }

  .section-kicker {
    margin-bottom: var(--space-5);
  }

  .article-list,
  .note-link-list {
    display: grid;
    border-top: var(--border-width) solid var(--color-border);
  }

  .article-row {
    display: grid;
    grid-template-columns: minmax(7.5rem, 0.24fr) minmax(0, 1fr);
    gap: var(--space-5);
    border-bottom: var(--border-width) solid var(--color-border);
    padding-block: var(--space-5);
  }

  .article-date,
  .article-meta,
  .note-link-list article > p:first-child {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-row h3,
  .note-link-list h3 {
    margin-bottom: var(--space-2);
    font-family: var(--font-serif);
    font-size: 1.35rem;
  }

  .article-row p:not(.article-date, .article-meta),
  .note-link-list article > p:not(:first-child) {
    color: var(--color-text-muted);
  }

  .article-meta {
    margin-top: var(--space-3);
  }

  .field-log-bridge {
    border-left: 0.3rem solid var(--khaki);
    padding: var(--space-5);
    background: color-mix(in srgb, var(--paper) 72%, transparent);
  }

  .field-log-bridge p {
    margin-bottom: var(--space-3);
  }

  .note-link-list article {
    border-bottom: var(--border-width) solid var(--color-border);
    padding-block: var(--space-4);
  }

  @media (max-width: 820px) {
    .featured-publication,
    .article-row {
      grid-template-columns: 1fr;
    }
  }
</style>
