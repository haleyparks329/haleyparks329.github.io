---
import { getCollection } from "astro:content";
import StatusBadge from "@/components/StatusBadge.astro";
import TagList from "@/components/TagList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/site.config";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const featuredProjects = projects.filter((project) => project.data.featured);
const fieldLogEntries = (await getCollection("fieldLog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const latestFieldLog = fieldLogEntries[0];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <section class="desk-page container" aria-labelledby="desk-title">
    <div class="desk-intro desk-object">
      <p class="eyebrow">The desk</p>
      <h1 id="desk-title">{siteConfig.name}</h1>
      <p class="tagline">{siteConfig.tagline}</p>
      <p class="lede">
        A warm public workbench for personal AI systems, performance modeling,
        career reasoning, and software that pays attention to context.
      </p>
      <div class="button-row">
        <a class="button" href="/projects/">View Projects</a>
        <a class="button secondary" href="/explore/">Explore</a>
      </div>
    </div>

    <aside
      class="mini-me-note desk-object sticky-object surface surface-pad"
      aria-labelledby="mini-me-title"
      data-note="Mini Me left this where you would find it."
    >
      <p class="eyebrow">Mini Me</p>
      <h2 id="mini-me-title">Static note from the desk</h2>
      <p>
        Mini Me is the small imagined companion for this site: part index card,
        part research assistant, part reminder that the useful version of AI
        should feel like it knows where the good notes are.
      </p>
      <p class="status-line">
        Desk status: notes open, systems humming, iced matcha nearby.
      </p>
      <span class="mini-me-mark" aria-hidden="true"></span>
    </aside>

    <div class="current-desk desk-object diagram-object surface surface-pad">
      <p class="eyebrow">Current desk</p>
      <h2 id="current-desk">What is open right now</h2>
      <div class="current-note-list" aria-labelledby="current-desk">
        <article>
          <a
            href="/projects/qa-agents/meticulous/"
            title="Open the QA Agents strategy replay"
          >
            <h3>Improving QA replay UX</h3>
          </a>
          <p>
            Making the replay-to-investigation handoff easier to inspect without
            overstating what the agent layer has built.
          </p>
        </article>
        <article>
          <a
            href="/writing/the-desk-as-workbench/"
            title="Open the desk-as-workbench note"
          >
            <h3>Designing adaptive navigation</h3>
          </a>
          <p>
            Letting visitors search directly or wander through connected
            projects, notes, topics, and demos.
          </p>
        </article>
        <article>
          <a href="/projects/the-human-model/" title="Open The Human Model">
            <h3>Working on Human Model review layers</h3>
          </a>
          <p>
            Keeping Bridget, dashboards, and model outputs connected to the
            evidence they are meant to preserve.
          </p>
        </article>
      </div>
      <div class="desk-flow" aria-hidden="true">
        <span>input</span>
        <i></i>
        <span>model</span>
        <i></i>
        <span>insight</span>
      </div>
    </div>

    <div class="project-heading desk-object">
      <p class="eyebrow">Flagship projects</p>
      <h2 id="flagship-projects">Things worth picking up</h2>
      <p>
        Each object on the desk points to a larger system: what it explores,
        what is implemented publicly, and where the repo tells the deeper truth.
      </p>
    </div>

    {
      featuredProjects.map((project, index) => (
        <article
          class={`project-object desk-object surface surface-pad ${project.data.accent} object-${project.data.accent} ${
            index === 0 ? "is-focal" : ""
          }`}
          data-note={
            index === 0
              ? undefined
              : project.data.accent === "olive"
                ? "Ruled pages are for keeping the evidence honest."
                : "Blueprint mode: useful systems leave review traces."
          }
        >
          <div class="project-object-top">
            <StatusBadge
              status={project.data.status}
              accent={project.data.accent}
            />
            <h3>{project.data.title}</h3>
          </div>
          <p>{project.data.summary}</p>
          <p class="question">
            <strong>Question:</strong> {project.data.coreQuestion}
          </p>
          <TagList tags={project.data.tags} />
          {project.data.slug === "qa-agents" ? (
            <nav
              class="project-actions qa-agent-actions"
              aria-label="QA Agents links"
            >
              <a
                class="project-action project-action-notes"
                href="/projects/qa-agents/"
              >
                <span aria-hidden="true">CS</span>
                <span>Case Study</span>
              </a>
              <a
                class="project-action project-action-replay"
                href="/projects/qa-agents/demo/"
              >
                <span aria-hidden="true">D</span>
                <span>Demo</span>
              </a>
              <a
                class="project-action"
                href={project.data.repositoryUrl}
                target="_blank"
                rel="noreferrer"
              >
                <span aria-hidden="true">R</span>
                <span>Repository</span>
              </a>
            </nav>
          ) : (
            <nav
              class="project-actions"
              aria-label={`${project.data.title} links`}
            >
              <a
                class="project-action"
                href={`/projects/${project.data.slug}/`}
                aria-label={`Open ${project.data.title} case study`}
              >
                <span aria-hidden="true">CS</span>
                <span>Case Study</span>
              </a>
              <a
                class="project-action"
                href={project.data.repositoryUrl}
                target="_blank"
                rel="noreferrer"
              >
                <span aria-hidden="true">R</span>
                <span>Repository</span>
              </a>
            </nav>
          )}
        </article>
      ))
    }

    <article
      class="field-log-preview desk-object field-log-object surface surface-pad"
      data-note="A little margin note from the edge of the work."
    >
      <div class="field-log-heading">
        <p class="eyebrow">Field log</p>
        <a href="/field-log/">View full log</a>
      </div>
      <h2 id="field-log">Notes from the edge of the work</h2>
      {
        latestFieldLog ? (
          <>
            <h3>{latestFieldLog.data.title}</h3>
            <blockquote>{latestFieldLog.data.excerpt}</blockquote>
            <p>{latestFieldLog.data.summary}</p>
            <a href={`/field-log/${latestFieldLog.data.slug}/`}>
              Read the field log
            </a>
          </>
        ) : (
          <>
            <h3>Field Log is being organized</h3>
            <p>
              Notes will collect the edges of the work: build observations,
              system questions, and practical decisions worth remembering.
            </p>
            <a href="/field-log/">Visit Field Log</a>
          </>
        )
      }
    </article>

    <a
      class="about-note desk-object sticky-object surface surface-pad"
      href="/about/"
      aria-label="About Haley Parks"
      data-note="Small note, actual person."
    >
      <span class="eyebrow">About</span>
      <span>Researcher, builder, lifelong learner.</span>
    </a>

    <a
      class="writing-note desk-object sticky-object surface surface-pad"
      href="/writing/"
      aria-label="Read Haley Parks writing"
      data-note="The longer trail of thinking lives here."
    >
      <span class="eyebrow">Writing</span>
      <span>Read the longer notes.</span>
    </a>

    <div
      class="desk-photo desk-object photo-object surface decorative-object"
      aria-hidden="true"
      data-note="Caffeine status: plausibly structural."
    >
      <span>matcha + deep work</span>
    </div>
  </section>
</BaseLayout>

<style>
  .desk-page {
    display: grid;
    width: min(1560px, calc(100% - clamp(2rem, 4vw, 5rem)));
    grid-template-columns: repeat(16, minmax(0, 1fr));
    grid-auto-rows: auto;
    gap: clamp(0.85rem, 1.35vw, 1.25rem);
    align-items: start;
    padding-block: clamp(1.65rem, 3vw, 2.75rem) clamp(2.75rem, 5vw, 4.5rem);
  }

  .desk-object {
    --desk-lift: 0;
    --desk-tilt: 0deg;
    position: relative;
    min-width: 0;
    transform: rotate(var(--desk-tilt)) translateY(var(--desk-lift));
    transform-origin: center;
    transition:
      border-color var(--motion-fast),
      box-shadow var(--motion-fast),
      transform 220ms ease;
  }

  .desk-object.surface {
    box-shadow: 0 12px 26px rgba(55, 40, 38, 0.055);
  }

  .desk-page .surface-pad {
    padding: clamp(0.95rem, 1.35vw, 1.15rem);
  }

  .desk-object.surface:hover,
  .desk-object.surface:focus-within {
    --desk-lift: -0.28rem;
    z-index: 10;
    border-color: var(--color-border-strong);
    box-shadow: 0 16px 36px rgba(55, 40, 38, 0.085);
  }

  .decorative-object.surface:hover,
  .decorative-object.surface:focus-within {
    --desk-lift: 0;
    z-index: auto;
    border-color: var(--color-border);
    box-shadow: 0 12px 26px rgba(55, 40, 38, 0.055);
  }

  .desk-object[data-note]::after {
    position: absolute;
    z-index: 20;
    right: var(--space-4);
    bottom: calc(100% + 0.35rem);
    max-width: min(15rem, 90%);
    border: var(--border-width) solid rgba(55, 40, 38, 0.12);
    border-radius: var(--radius-sm);
    padding: 0.35rem 0.5rem;
    background: color-mix(in srgb, var(--paper) 88%, white);
    color: var(--color-text-muted);
    content: attr(data-note);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.35;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.35rem);
    transition:
      opacity var(--motion-fast),
      transform var(--motion-fast);
  }

  .desk-object[data-note]:hover::after,
  .desk-object[data-note]:focus-within::after {
    opacity: 1;
    transform: translateY(0);
  }

  .desk-object::before {
    position: absolute;
    z-index: 1;
    top: -0.85rem;
    left: 14%;
    width: 4.5rem;
    height: 1.2rem;
    background: color-mix(in srgb, var(--khaki) 46%, transparent);
    content: "";
    opacity: 0.58;
    transform: rotate(-4deg);
  }

  .desk-intro {
    grid-column: 1 / span 4;
    grid-row: 1;
    align-self: start;
    max-width: 21rem;
    padding-top: clamp(1.25rem, 3vw, 3.5rem);
    padding-right: var(--space-4);
  }

  .desk-intro::before,
  .project-heading::before {
    content: none;
  }

  .desk-intro h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.35rem, 2.9vw, 3.2rem);
    font-weight: 700;
    letter-spacing: 0;
  }

  .tagline {
    max-width: var(--measure);
    margin-top: var(--space-3);
    color: var(--accent-primary);
    font-family: var(--font-serif);
    font-size: clamp(1.12rem, 1.45vw, 1.55rem);
    font-weight: 800;
    line-height: 1.15;
  }

  .lede {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.42;
  }

  .button-row {
    gap: 0.6rem;
    margin-top: var(--space-5);
  }

  .button {
    min-height: 40px;
    padding: 0.62rem 0.78rem;
    font-size: 0.86rem;
  }

  .mini-me-note {
    --desk-tilt: -1.4deg;
    grid-column: 11 / span 3;
    grid-row: 3;
    align-self: start;
    min-height: 11.5rem;
    border-color: rgba(122, 91, 139, 0.2);
    background: var(--lavender);
    color: #4b3158;
  }

  .mini-me-note h2 {
    margin-bottom: var(--space-3);
    font-size: clamp(1.15rem, 1.4vw, 1.55rem);
  }

  .mini-me-note h2 {
    font-family: var(--font-sans);
    letter-spacing: 0;
  }

  .field-log-preview h3 {
    margin-bottom: 0.45rem;
    font-family: var(--font-sans);
    font-size: clamp(0.98rem, 1vw, 1.12rem);
    line-height: 1.2;
  }

  .mini-me-note p:not(.eyebrow) {
    font-family: var(--font-hand);
    font-size: 0.86rem;
    line-height: 1.34;
  }

  .status-line {
    border-top: var(--border-width) solid rgba(122, 91, 139, 0.2);
    padding-top: var(--space-4);
    color: #4b3158;
    font-weight: var(--font-weight-strong);
  }

  .mini-me-mark {
    position: absolute;
    right: var(--space-5);
    bottom: var(--space-5);
    width: 1.65rem;
    height: 1.65rem;
    border: 2px solid currentColor;
    border-radius: 50%;
    opacity: 0.48;
  }

  .mini-me-mark::before,
  .mini-me-mark::after {
    position: absolute;
    content: "";
  }

  .mini-me-mark::before {
    top: 0.68rem;
    left: 0.55rem;
    width: 0.25rem;
    height: 0.25rem;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0.75rem 0 0 currentColor;
  }

  .mini-me-mark::after {
    left: 0.62rem;
    bottom: 0.48rem;
    width: 0.8rem;
    height: 0.42rem;
    border-bottom: 2px solid currentColor;
    border-radius: 0 0 999px 999px;
  }

  .current-desk {
    grid-column: 9 / span 5;
    grid-row: 1;
    border-color: rgba(79, 134, 168, 0.2);
    background:
      linear-gradient(rgba(79, 134, 168, 0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 134, 168, 0.1) 1px, transparent 1px),
      color-mix(in srgb, var(--blue-soft) 34%, var(--paper));
    background-size:
      100% 3.5rem,
      3.5rem 100%,
      auto;
  }

  .current-desk h2,
  .project-heading h2,
  .field-log-preview h2 {
    font-family: var(--font-serif);
    font-weight: 700;
  }

  .current-desk h2 {
    max-width: 12ch;
    font-size: clamp(1.9rem, 2.35vw, 2.5rem);
    line-height: 0.98;
  }

  .current-note-list {
    display: grid;
    gap: 0.62rem;
    margin-top: var(--space-4);
  }

  .current-note-list article {
    display: grid;
    grid-template-columns: minmax(6.5rem, 0.56fr) minmax(0, 1.44fr);
    gap: var(--space-3);
    border-top: var(--border-width) solid var(--color-border);
    padding-top: var(--space-2);
  }

  .current-note-list h3,
  .current-note-list p {
    margin: 0;
  }

  .current-note-list h3 {
    color: var(--rust);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    overflow-wrap: anywhere;
  }

  .current-note-list p {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    line-height: 1.3;
  }

  .desk-flow {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto;
    gap: 0.45rem;
    align-items: center;
    margin-top: var(--space-3);
    color: var(--blue);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    overflow: hidden;
  }

  .desk-flow i {
    position: relative;
    min-width: 0;
    overflow: hidden;
    height: 1px;
    background: currentColor;
  }

  .desk-flow i::after {
    content: none;
  }

  .project-heading {
    grid-column: 1 / span 3;
    grid-row: 2;
    align-self: start;
    padding-top: clamp(1.75rem, 4vw, 4.25rem);
    padding-right: var(--space-4);
  }

  .project-heading h2 {
    font-size: clamp(1.8rem, 2vw, 2.35rem);
    overflow-wrap: anywhere;
  }

  .project-heading p:not(.eyebrow) {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .project-object {
    display: grid;
    align-content: start;
    gap: 0.68rem;
    overflow: visible;
    color: var(--color-text);
  }

  .project-object h3 {
    font-family: var(--font-sans);
    font-size: clamp(1.08rem, 1.3vw, 1.38rem);
  }

  .project-object p {
    font-size: 0.86rem;
    line-height: 1.38;
  }

  .project-object.rust {
    grid-column: 5 / span 4;
    grid-row: 1;
    border-color: rgba(145, 80, 91, 0.18);
    background:
      radial-gradient(
        circle at 72% 82%,
        rgba(145, 80, 91, 0.09) 0 18%,
        transparent 18.5%
      ),
      linear-gradient(
        90deg,
        rgba(145, 80, 91, 0.16) 0 0.42rem,
        transparent 0.42rem
      ),
      color-mix(in srgb, var(--paper) 86%, white);
    box-shadow: var(--shadow-raised);
  }

  .project-object.olive {
    --desk-tilt: -0.7deg;
    grid-column: 4 / span 4;
    grid-row: 2;
    border-color: rgba(111, 126, 29, 0.2);
    background:
      linear-gradient(rgba(86, 97, 19, 0.1) 1px, transparent 1px),
      color-mix(in srgb, var(--olive) 82%, var(--paper));
    background-size: 100% 2.1rem;
  }

  .project-object.blue {
    --desk-tilt: 0.6deg;
    grid-column: 8 / span 4;
    grid-row: 2;
    border-color: rgba(79, 134, 168, 0.18);
    background:
      linear-gradient(rgba(79, 134, 168, 0.14) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 134, 168, 0.12) 1px, transparent 1px),
      var(--blue-soft);
    background-size:
      1.8rem 1.8rem,
      1.8rem 1.8rem,
      auto;
  }

  .project-object.is-focal::after {
    position: absolute;
    right: var(--space-5);
    bottom: var(--space-5);
    width: 8.5rem;
    height: 5rem;
    border-bottom: var(--border-width) solid rgba(145, 80, 91, 0.3);
    border-left: var(--border-width) solid rgba(145, 80, 91, 0.3);
    content: "";
    opacity: 0.75;
  }

  .project-object-top {
    display: grid;
    gap: 0.8rem;
  }

  .project-object p {
    color: var(--color-text-muted);
  }

  .project-object :global(.status) {
    border-color: rgba(55, 40, 38, 0.12);
    background: rgba(255, 248, 239, 0.66);
    color: var(--color-text);
  }

  .project-object.rust :global(.status) {
    color: var(--rust);
  }

  .project-object.olive :global(.status) {
    color: #566113;
  }

  .project-object.blue :global(.status) {
    color: #355f7c;
  }

  .project-object .question {
    border-top: var(--border-width) solid rgba(55, 40, 38, 0.14);
    padding-top: 0.7rem;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    line-height: 1.35;
  }

  .project-object :global(.tags li) {
    background: rgba(255, 248, 239, 0.5);
    color: var(--color-text);
  }

  .project-object a {
    align-self: end;
    color: var(--rust);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.48rem;
    align-items: center;
    align-self: end;
  }

  .project-action {
    display: inline-flex;
    gap: 0.34rem;
    align-items: center;
    width: fit-content;
  }

  .project-action-notes {
    color: var(--color-text-muted);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  .project-action-replay {
    border: var(--border-width) solid rgba(79, 134, 168, 0.34);
    border-radius: var(--radius-sm);
    padding: 0.34rem 0.52rem;
    background: color-mix(in srgb, var(--blue) 14%, var(--paper));
    color: #294e68;
    font-weight: var(--font-weight-heavy);
    text-decoration: none;
    box-shadow:
      1px 1px 0 rgba(55, 40, 38, 0.1),
      inset 1px 1px 0 rgba(255, 248, 239, 0.72);
  }

  .project-action-replay:hover {
    color: #294e68;
    background: color-mix(in srgb, var(--blue) 20%, var(--paper));
  }

  .field-log-preview {
    grid-column: 12 / span 5;
    grid-row: 2;
    border-color: rgba(55, 40, 38, 0.12);
    background:
      linear-gradient(
        90deg,
        rgba(145, 80, 91, 0.13) 0 0.32rem,
        transparent 0.32rem
      ),
      color-mix(in srgb, var(--paper) 90%, white);
  }

  .field-log-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .field-log-heading a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .field-log-preview h2 {
    margin-bottom: 0.45rem;
    font-size: clamp(1.05rem, 1.15vw, 1.25rem);
    line-height: 1.1;
  }

  .field-log-preview > p:not(.eyebrow) {
    color: var(--color-text-muted);
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .field-log-preview blockquote {
    margin: 0;
    border-left: var(--border-accent) solid var(--rust);
    padding-left: 0.85rem;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.15vw, 1.18rem);
    font-weight: var(--font-weight-heavy);
    line-height: 1.12;
  }

  .about-note,
  .writing-note {
    display: grid;
    align-content: space-between;
    min-height: 7rem;
    color: inherit;
    font-family: var(--font-hand);
    font-size: 0.95rem;
    line-height: 1.55;
    text-decoration: none;
  }

  .mini-me-note .eyebrow,
  .about-note .eyebrow {
    color: #6b4a7a;
  }

  .about-note {
    --desk-tilt: -2deg;
    grid-column: 14 / span 2;
    grid-row: 3;
    border-color: rgba(122, 91, 139, 0.2);
    background: var(--lavender);
    color: #4b3158;
  }

  .writing-note {
    --desk-tilt: 1.5deg;
    grid-column: 8 / span 2;
    grid-row: 3;
    border-color: rgba(125, 91, 20, 0.14);
    background: var(--khaki);
