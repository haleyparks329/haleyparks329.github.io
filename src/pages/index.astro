---
import { getCollection } from "astro:content";
import ProjectFile from "@/components/ProjectFile.astro";
import StatusBadge from "@/components/StatusBadge.astro";
import { homepageState } from "@/data/homepage";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/site.config";

const projects = await getCollection("projects");
const projectBySlug = new Map(
  projects.map((project) => [project.data.slug, project]),
);
const featuredWorkProject = projectBySlug.get(
  homepageState.featuredWork.projectSlug,
);

if (!featuredWorkProject) {
  throw new Error(
    `Missing featured work project: ${homepageState.featuredWork.projectSlug}`,
  );
}

const flagshipProjects = homepageState.projectOrder.map((slug) => {
  const project = projectBySlug.get(slug);
  if (!project) throw new Error(`Missing homepage project: ${slug}`);
  return project;
});

const fieldLogEntries = (await getCollection("fieldLog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const latestFieldLog = fieldLogEntries[0];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <section class="desk-page" aria-labelledby="desk-title">
    <header class="desk-intro">
      <p class="eyebrow">AI Product Engineer</p>
      <h1 id="desk-title">{siteConfig.name}</h1>
      <p class="tagline">{siteConfig.tagline}</p>
      <p class="lede">
        I build human-centered systems that connect data, behavior, context, and
        goals without hiding the reasoning behind them.
      </p>
      <nav class="hero-actions" aria-label="Homepage introduction">
        <a class="button" href="/projects/">View Projects</a>
        <a class="button secondary" href="/explore/">Explore</a>
      </nav>
    </header>

    <article class="featured-work collection-artifact">
      <div class="featured-work-heading">
        <div>
          <p class="eyebrow">{homepageState.featuredWork.label}</p>
          <h2>{featuredWorkProject.data.title}</h2>
        </div>
        <StatusBadge
          status={featuredWorkProject.data.status}
          accent={featuredWorkProject.data.accent}
        />
      </div>
      <p class="artifact-title">{homepageState.featuredWork.artifactTitle}</p>
      <p class="featured-summary">{homepageState.featuredWork.summary}</p>
      <nav
        class="featured-actions"
        aria-label={`${featuredWorkProject.data.title} featured work links`}
      >
        <a
          class="button featured-primary"
          href={homepageState.featuredWork.primaryAction.href}
        >
          {homepageState.featuredWork.primaryAction.label}
        </a>
        <a
          class="featured-secondary"
          href={homepageState.featuredWork.secondaryAction.href}
        >
          {homepageState.featuredWork.secondaryAction.label}
        </a>
      </nav>
      <div class="evidence-path" aria-hidden="true">
        <span>reasoning</span><i></i><span>evidence</span><i></i><span
          >handoff</span
        >
      </div>
    </article>

    <section
      class="current-desk collection-artifact"
      aria-labelledby="current-desk-title"
    >
      <div class="section-heading">
        <p class="eyebrow">Current Desk</p>
        <h2 id="current-desk-title">Additional work in view</h2>
      </div>
      <div class="current-note-list">
        {
          homepageState.currentDesk.map((entry) => (
            <article>
              <h3>
                <a href={entry.href}>{entry.title}</a>
              </h3>
              <p>{entry.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="flagship-projects" aria-labelledby="flagship-projects">
      <div class="project-heading">
        <p class="eyebrow">Flagship Projects</p>
        <h2 id="flagship-projects">Long-running systems</h2>
        <p>
          Project overviews, implementation evidence, and repositories for the
          systems at the center of my work.
        </p>
      </div>
      <div class="project-collection">
        {
          flagshipProjects.map((project) => (
            <div class={`project-object ${project.data.accent}`}>
              <ProjectFile project={project} variant="desk" />
            </div>
          ))
        }
      </div>
    </section>

    <article class="field-log-preview collection-artifact">
      <div class="field-log-heading">
        <div>
          <p class="eyebrow">Latest Field Log</p>
          <p class="artifact-annotation">
            {homepageState.annotations.fieldLog}
          </p>
        </div>
        <a href="/field-log/">View all</a>
      </div>
      {
        latestFieldLog ? (
          <>
            <h2>{latestFieldLog.data.title}</h2>
            {latestFieldLog.data.excerpt && (
              <blockquote>{latestFieldLog.data.excerpt}</blockquote>
            )}
            <p>{latestFieldLog.data.summary}</p>
            <a
              class="field-log-action"
              href={`/field-log/${latestFieldLog.data.slug}/`}
            >
              Read the field log
            </a>
          </>
        ) : (
          <>
            <h2>Field Log is being organized</h2>
            <p>
              Notes will collect build observations, system questions, and
              practical decisions worth remembering.
            </p>
            <a class="field-log-action" href="/field-log/">
              Visit Field Log
            </a>
          </>
        )
      }
    </article>

    <a
      class="writing-note portal-artifact"
      href="/writing/"
      aria-label="Read Haley Parks writing"
    >
      <span class="eyebrow">Writing</span>
      <strong>Investigations, case studies, and ideas from active work.</strong>
      <span class="portal-cue">Read writing →</span>
    </a>

    <a
      class="about-note portal-artifact"
      href="/about/"
      aria-label="About Haley Parks"
    >
      <span class="eyebrow">About</span>
      <strong>Researcher, builder, lifelong learner.</strong>
      <span class="portal-cue">About Haley →</span>
    </a>

    <aside
      class="mini-me-note display-artifact"
      aria-labelledby="mini-me-title"
    >
      <p class="eyebrow">{homepageState.miniMe.label}</p>
      <h2 id="mini-me-title">{homepageState.miniMe.title}</h2>
      <p>{homepageState.miniMe.body}</p>
      <p class="status-line">{homepageState.miniMe.status}</p>
      <span class="mini-me-mark" aria-hidden="true"></span>
    </aside>
  </section>
</BaseLayout>

<style>
  .desk-page {
    display: grid;
    width: min(1420px, calc(100% - clamp(2rem, 5vw, 5rem)));
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(1rem, 1.6vw, 1.5rem);
    align-items: start;
    margin-inline: auto;
    padding-block: clamp(2rem, 4vw, 3.75rem) clamp(3rem, 6vw, 5rem);
  }

  .desk-intro {
    grid-column: 1 / span 5;
    align-self: center;
    max-width: 34rem;
    padding: clamp(1rem, 2vw, 2rem) clamp(1rem, 2vw, 2rem)
      clamp(1rem, 2vw, 2rem) 0;
  }

  .desk-intro h1 {
    margin-top: var(--space-2);
    font-size: clamp(3.5rem, 7vw, 6.8rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 0.9;
  }

  .tagline {
    max-width: 24ch;
    margin: var(--space-5) 0 0;
    color: var(--accent-primary);
    font-size: clamp(1.25rem, 2vw, 1.85rem);
    font-weight: 600;
    line-height: 1.15;
  }

  .lede {
    max-width: 35rem;
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.55;
  }

  .hero-actions,
  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    margin-top: var(--space-5);
  }

  .hero-actions .button,
  .featured-actions .button {
    min-height: 44px;
  }

  .collection-artifact,
  .portal-artifact,
  .display-artifact {
    min-width: 0;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-paper);
  }

  .collection-artifact {
    transition:
      border-color var(--motion-fast),
      box-shadow var(--motion-fast);
  }

  .collection-artifact:focus-within {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-raised);
  }

  .featured-work {
    grid-column: 6 / -1;
    position: relative;
    overflow: hidden;
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    border-color: rgba(79, 134, 168, 0.28);
    background:
      linear-gradient(rgba(79, 134, 168, 0.13) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79, 134, 168, 0.09) 1px, transparent 1px),
      color-mix(in srgb, var(--blue-soft) 58%, var(--paper));
    background-size:
      3.5rem 3.5rem,
      3.5rem 3.5rem,
      auto;
  }

  .featured-work::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0.38rem;
    background: var(--blue);
    content: "";
  }

  .featured-work-heading {
    display: flex;
    gap: var(--space-4);
    align-items: start;
    justify-content: space-between;
  }

  .featured-work h2 {
    margin-top: var(--space-2);
    font-size: clamp(2rem, 3.8vw, 3.6rem);
    line-height: 0.98;
  }

  .artifact-title {
    margin: clamp(1.25rem, 2vw, 1.75rem) 0 0;
    color: #355f7c;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
  }

  .featured-summary {
    max-width: 42rem;
    margin: var(--space-3) 0 0;
    color: var(--color-text);
    font-size: clamp(1.05rem, 1.5vw, 1.28rem);
    line-height: 1.48;
  }

  .featured-primary {
    background: #355f7c;
  }

  .featured-primary:hover,
  .featured-primary:focus-visible {
    background: var(--plum);
  }

  .featured-secondary {
    color: var(--color-text);
    font-weight: 650;
    text-underline-offset: 0.2em;
  }

  .evidence-path {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto;
    gap: var(--space-2);
    align-items: center;
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    color: #355f7c;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .evidence-path i {
    height: 1px;
    background: currentColor;
  }

  .current-desk {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(13rem, 0.28fr) minmax(0, 0.72fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    margin-top: clamp(0.5rem, 2vw, 1.5rem);
    padding: clamp(1.25rem, 2.5vw, 2rem);
    background: color-mix(in srgb, var(--paper) 85%, white);
  }

  .section-heading h2,
  .project-heading h2 {
    margin-top: var(--space-2);
    font-size: var(--text-h2);
  }

  .current-note-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  .current-note-list article {
    border-left: 0.25rem solid var(--blue);
    padding-left: var(--space-4);
  }

  .current-note-list h3 {
    font-size: var(--text-body);
    line-height: 1.25;
  }

  .current-note-list h3 a {
    color: var(--color-text);
  }

  .current-note-list p {
    margin: var(--space-2) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.48;
  }

  .flagship-projects {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(13rem, 0.24fr) minmax(0, 0.76fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    margin-top: clamp(1rem, 3vw, 2.5rem);
  }

  .project-heading {
    padding-top: var(--space-4);
  }

  .project-heading p:not(.eyebrow) {
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .project-collection {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 1.7vw, 1.4rem);
    align-items: stretch;
  }

  .project-object,
  .project-object :global(.project-file) {
    height: 100%;
  }

  .field-log-preview {
    grid-column: 1 / span 7;
    padding: clamp(1.25rem, 2.5vw, 2rem);
    background:
      linear-gradient(
        90deg,
        rgba(145, 80, 91, 0.13) 0 0.34rem,
        transparent 0.34rem
      ),
      var(--color-surface);
  }

  .field-log-heading {
    display: flex;
    gap: var(--space-4);
    align-items: start;
    justify-content: space-between;
  }

  .artifact-annotation {
    margin: var(--space-1) 0 0;
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  .field-log-preview h2 {
    margin-top: var(--space-5);
    font-size: var(--text-h3);
  }

  .field-log-preview blockquote {
    margin: var(--space-3) 0;
    border-left: 0.25rem solid var(--rust);
    padding-left: var(--space-3);
    color: var(--color-text);
    font-size: clamp(1rem, 1.4vw, 1.22rem);
    font-weight: 600;
    line-height: 1.25;
  }

  .field-log-preview blockquote + p,
  .field-log-preview h2 + p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.48;
  }

  .field-log-action {
    display: inline-block;
    margin-top: var(--space-4);
  }

  .portal-artifact {
    display: grid;
    align-content: space-between;
    min-height: 13rem;
    gap: var(--space-4);
    padding: clamp(1.2rem, 2vw, 1.6rem);
    color: inherit;
    text-decoration: none;
    transition:
      border-color var(--motion-fast),
      box-shadow var(--motion-fast),
      transform var(--motion-fast);
  }

  .portal-artifact:hover,
  .portal-artifact:focus-visible {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-raised);
    transform: translateY(-0.2rem);
  }

  .portal-artifact strong {
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    line-height: 1.3;
  }

  .portal-cue {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .writing-note {
    grid-column: 8 / span 3;
    background: var(--sunny-note);
    color: #4d3710;
  }

  .about-note {
    grid-column: 11 / span 2;
    background: var(--lavender);
    color: #4b3158;
  }

  .mini-me-note {
    grid-column: 9 / -1;
    position: relative;
    min-height: 13rem;
    padding: clamp(1.2rem, 2vw, 1.6rem);
    border-color: rgba(122, 91, 139, 0.2);
    background: color-mix(in srgb, var(--lavender) 88%, var(--paper));
    color: #4b3158;
  }

  .mini-me-note h2 {
    margin-top: var(--space-3);
    font-size: var(--text-h3);
  }

  .mini-me-note p:not(.eyebrow) {
    max-width: 37rem;
    font-family: var(--font-hand);
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .status-line {
    margin-top: var(--space-4);
    border-top: var(--border-width) solid rgba(122, 91, 139, 0.2);
    padding-top: var(--space-4);
    font-weight: 600;
  }

  .mini-me-mark {
    position: absolute;
    right: var(--space-5);
    bottom: var(--space-5);
    width: 1.65rem;
    height: 1.65rem;
    border: 2px solid currentColor;
    border-radius: 50%;
    opacity: 0.42;
  }

  .mini-me-mark::before,
  .mini-me-mark::after {
    position: absolute;
    content: "";
  }

  .mini-me-mark::before {
    top: 0.68rem;
    left: 0.55rem;
    width: 0.25rem;
    height: 0.25rem;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0.75rem 0 0 currentColor;
  }

  .mini-me-mark::after {
    left: 0.62rem;
    bottom: 0.48rem;
    width: 0.8rem;
    height: 0.42rem;
    border-bottom: 2px solid currentColor;
    border-radius: 0 0 999px 999px;
  }

  @media (max-width: 1040px) {
    .desk-page {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }

    .desk-intro {
      grid-column: 1 / span 4;
    }

    .featured-work {
      grid-column: 5 / -1;
    }

    .current-desk,
    .flagship-projects {
      grid-column: 1 / -1;
    }

    .flagship-projects {
      grid-template-columns: 1fr;
    }

    .project-collection {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .field-log-preview {
      grid-column: 1 / span 5;
    }

    .writing-note {
      grid-column: 6 / span 3;
    }

    .about-note {
      grid-column: 6 / span 3;
    }

    .mini-me-note {
      grid-column: 4 / -1;
    }
  }

  @media (max-width: 720px) {
    .desk-page {
      grid-template-columns: 1fr;
      width: min(100% - 2rem, 42rem);
      padding-top: var(--space-6);
    }

    .desk-intro,
    .featured-work,
    .current-desk,
    .flagship-projects,
    .field-log-preview,
    .writing-note,
    .about-note,
    .mini-me-note {
      grid-column: auto;
    }

    .desk-intro {
      padding: 0 0 var(--space-3);
    }

    .desk-intro h1 {
      font-size: clamp(3.25rem, 17vw, 5rem);
    }

    .featured-work-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .current-desk,
    .flagship-projects {
      grid-template-columns: 1fr;
    }

    .current-note-list,
    .project-collection {
      grid-template-columns: 1fr;
    }

    .portal-artifact,
    .mini-me-note {
      min-height: 10rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-artifact,
    .portal-artifact {
      transition: none;
    }

    .portal-artifact:hover,
    .portal-artifact:focus-visible {
      transform: none;
    }
  }
</style>
