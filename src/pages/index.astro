---
import { getCollection } from "astro:content";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import StatusBadge from "@/components/StatusBadge.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/site.config";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const humanModel = projects.find(
  (project) => project.data.slug === "the-human-model",
);
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <section class="hero container">
    <p class="eyebrow">
      Personal AI systems, performance modeling, public work
    </p>
    <h1>{siteConfig.name}</h1>
    <p class="tagline">{siteConfig.tagline}</p>
    <p class="lede">
      I build human-centered systems that connect data, context, behavior, and
      goals. My work explores what becomes possible when software moves beyond
      storing information and begins helping people understand themselves.
    </p>
    <div class="button-row">
      <a class="button" href="/projects/the-human-model/"
        >Explore The Human Model</a
      >
      <a class="button secondary" href="/projects/">View all projects</a>
      <a class="button secondary" href={siteConfig.githubUrl}>GitHub</a>
    </div>
  </section>

  {
    humanModel && (
      <section class="page-section content-band">
        <div class="container flagship">
          <div>
            <p class="eyebrow">Flagship project</p>
            <h2>{humanModel.data.title}</h2>
          </div>
          <div class="stack">
            <StatusBadge
              status={humanModel.data.status}
              accent={humanModel.data.accent}
            />
            <p class="lede">{humanModel.data.summary}</p>
            <p>
              The work brings together personal data, adaptive modeling,
              biomechanics, and AI-assisted reasoning in a system that stays
              honest about what is working now, what is experimental, and what
              is still being explored.
            </p>
            <a href="/projects/the-human-model/">Read the project overview</a>
          </div>
        </div>
      </section>
    )
  }

  <section class="page-section container">
    <SectionHeading
      eyebrow="Selected projects"
      title="Systems for people, context, and decisions"
      text="This first version keeps the portfolio intentionally small while creating a clear place for future demos, research notes, and knowledge-graph work."
    />
    <div class="card-grid project-list">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="page-section content-band">
    <div class="container section-grid">
      <SectionHeading
        eyebrow="Philosophy"
        title="Attention is the scarce resource"
      />
      <div class="stack">
        <blockquote>
          Give the machines the burden of remembering, coordinating, searching,
          and connecting. Give people their attention back.
        </blockquote>
        <p>
          I am interested in personal computing that models the person, their
          context, goals, and relationships rather than presenting another CRUD
          interface and calling that understanding.
        </p>
      </div>
    </div>
  </section>

  <section class="page-section container">
    <div class="section-grid">
      <SectionHeading
        eyebrow="Current direction"
        title="Where the work is pointing"
      />
      <ul class="quiet-list split-list">
        <li>Personal AI and human modeling</li>
        <li>Adaptive performance systems</li>
        <li>Human-centered automation</li>
        <li>Digital self-ownership</li>
        <li>Interfaces that make technology personal and fun</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  .tagline {
    max-width: 760px;
    margin-top: 1rem;
    color: var(--rust);
    font-size: clamp(1.45rem, 3vw, 2.35rem);
    font-weight: 800;
    line-height: 1.15;
  }

  .flagship {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .project-list {
    margin-top: 2rem;
  }

  blockquote {
    margin: 0;
    border-left: 5px solid var(--rust);
    padding-left: 1.2rem;
    color: var(--ink);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 850;
    line-height: 1.2;
  }

  @media (max-width: 820px) {
    .flagship {
      grid-template-columns: 1fr;
    }
  }
</style>
