---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const entries = (await getCollection("fieldLog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "2-digit",
  year: "numeric",
});

const categoryTone = (category: string) => {
  const normalized = category.toLowerCase();
  if (normalized.includes("system")) return "systems";
  if (normalized.includes("build")) return "engineering";
  if (normalized.includes("desk")) return "desk";
  if (normalized.includes("experiment")) return "experiment";
  if (normalized.includes("growth")) return "growth";
  return "research";
};
---

<BaseLayout
  title="Field Log"
  description="Short public notes from Haley Parks' active AI systems, build work, and research questions."
  canonicalPath="/field-log/"
>
  <section class="interior-container field-log-page">
    <header class="field-log-header">
      <div>
        <p class="eyebrow">Field Log</p>
        <h1>Notes from the edge of the work</h1>
        <p>
          Short notes from the desk: build observations, system questions, and
          decisions worth keeping visible while the larger work is still moving.
        </p>
      </div>
      <dl aria-label="Field Log summary">
        <div>
          <dt>Entries</dt>
          <dd>{entries.length}</dd>
        </div>
        <div>
          <dt>Order</dt>
          <dd>Newest first</dd>
        </div>
      </dl>
    </header>

    <div class="editorial-list entry-list" aria-label="Field Log entries">
      {
        entries.map((entry) => (
          <article
            id={entry.data.slug}
            class={`field-entry tone-${categoryTone(entry.data.category)}`}
          >
            <div class="entry-meta">
              <time datetime={entry.data.pubDate.toISOString()}>
                {dateFormatter.format(entry.data.pubDate)}
              </time>
              <p>
                <span aria-hidden="true" />
                {entry.data.category}
              </p>
            </div>
            <div class="entry-body">
              <h2>{entry.data.title}</h2>
              <p class="entry-summary">{entry.data.summary}</p>
              <blockquote>{entry.data.excerpt}</blockquote>
              <ul class="tags" aria-label={`${entry.data.title} tags`}>
                {entry.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .field-log-page {
    padding-bottom: clamp(3rem, 6vw, 5.5rem);
  }

  .field-log-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 0.28fr);
    gap: var(--section-gap);
    align-items: end;
    padding-block: clamp(2.2rem, 4vw, 3.5rem);
  }

  .field-log-header > div {
    max-width: 780px;
  }

  .field-log-header h1 {
    max-width: 12ch;
    font-family: var(--font-serif);
    font-size: clamp(2.45rem, 4.4vw, 4.1rem);
    line-height: var(--line-height-display);
  }

  .field-log-header p:not(.eyebrow) {
    max-width: 680px;
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  dl {
    display: grid;
    gap: 0;
    margin: 0;
    border-block: var(--border-width) solid var(--color-border);
  }

  dl div {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    padding-block: var(--space-3);
  }

  dl div + div {
    border-top: var(--border-width) solid var(--color-border);
  }

  dt,
  dd {
    margin: 0;
  }

  dt {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 800;
    text-transform: uppercase;
  }

  dd {
    color: var(--color-text);
    font-weight: 800;
  }

  .entry-list {
    width: min(1080px, 100%);
    margin-inline: auto;
    border-top: var(--border-width) solid var(--color-border);
  }

  .field-entry {
    --entry-accent: var(--rust);
    display: grid;
    grid-template-columns: minmax(11rem, 0.34fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 3vw, 3rem);
    border-bottom: var(--border-width) solid var(--color-border);
    padding-block: var(--space-5);
    scroll-margin-top: var(--space-8);
  }

  .tone-systems {
    --entry-accent: var(--olive);
  }

  .tone-engineering {
    --entry-accent: var(--blue);
  }

  .tone-desk {
    --entry-accent: var(--lavender);
  }

  .tone-experiment {
    --entry-accent: var(--khaki);
  }

  .tone-growth {
    --entry-accent: var(--houseplant);
  }

  .entry-meta {
    display: grid;
    align-content: start;
    gap: 0.55rem;
  }

  time {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: var(--font-size-small);
    font-weight: 800;
  }

  .entry-meta p {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .entry-meta span {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--entry-accent);
  }

  .entry-body {
    min-width: 0;
  }

  .entry-body h2 {
    font-family: var(--font-serif);
    font-size: var(--font-size-object-heading);
  }

  .entry-summary {
    margin-top: var(--space-3);
    color: var(--color-text-muted);
  }

  blockquote {
    margin: var(--space-4) 0 var(--space-3);
    border-left: 0.25rem solid var(--entry-accent);
    padding-left: var(--space-4);
    color: var(--color-text);
    font-size: 1.02rem;
    font-weight: 800;
    line-height: var(--line-height-tight);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.52rem;
    background: color-mix(in srgb, var(--entry-accent) 12%, var(--paper));
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .field-log-header,
    .field-entry {
      grid-template-columns: 1fr;
    }

    .field-log-header h1 {
      max-width: 100%;
    }
  }
</style>
