---
import { getCollection } from "astro:content";
import InteriorHeader from "@/components/InteriorHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const entries = (await getCollection("fieldLog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "2-digit",
  year: "numeric",
});

const categoryTone = (category: string) => {
  const normalized = category.toLowerCase();
  if (normalized.includes("system")) return "systems";
  if (normalized.includes("build")) return "engineering";
  if (normalized.includes("desk")) return "desk";
  if (normalized.includes("experiment")) return "experiment";
  if (normalized.includes("growth")) return "growth";
  return "research";
};
---

<BaseLayout
  title="Field Log"
  description="Short public notes from Haley Parks' active AI systems, build work, and research questions."
  canonicalPath="/field-log/"
>
  <section class="interior-container field-log-page">
    <InteriorHeader
      eyebrow="Field Log"
      title="Notes from the edge of the work"
      text="Short notes from the desk: build observations, system questions, and decisions worth keeping visible while the larger work is still moving."
      meta={[`${entries.length} entries`, "Newest first", "Research notebook"]}
      objectLabel="Margin note"
      objectText="Latest entry pinned near the top."
      accent="sky"
    />

    <div class="editorial-list entry-list" aria-label="Field Log entries">
      {
        entries.map((entry, index) => (
          <article
            id={entry.data.slug}
            class={`field-entry workspace-object no-tape tone-${categoryTone(entry.data.category)} ${
              index === 0 ? "is-latest" : ""
            }`}
          >
            <div class="entry-meta">
              <time datetime={entry.data.pubDate.toISOString()}>
                {dateFormatter.format(entry.data.pubDate)}
              </time>
              <p>
                <span aria-hidden="true" />
                {entry.data.category}
              </p>
            </div>
            <div class="entry-body">
              <h2>{entry.data.title}</h2>
              <p class="entry-summary">{entry.data.summary}</p>
              <blockquote>{entry.data.excerpt}</blockquote>
              <ul class="tags" aria-label={`${entry.data.title} tags`}>
                {entry.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .field-log-page {
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  :global(.field-log-page .interior-header h1) {
    max-width: 22ch;
    font-size: clamp(2rem, 2.6vw, 2.7rem);
  }

  :global(.field-log-page .interior-header-copy) {
    max-width: 900px;
  }

  .entry-list {
    width: min(900px, 100%);
    margin-inline: auto;
    gap: 0.7rem;
  }

  .field-entry {
    --entry-accent: var(--rust);
    display: grid;
    grid-template-columns: 7.2rem minmax(0, 1fr);
    gap: 1rem;
    min-height: 0;
    padding: 0.9rem 1rem;
    scroll-margin-top: var(--space-8);
  }

  .field-entry.is-latest {
    --object-tilt: -0.35deg;
    border-left: 0.38rem solid var(--entry-accent);
    background:
      linear-gradient(rgba(55, 40, 38, 0.055) 1px, transparent 1px) 0 0 / 100%
        1.8rem,
      var(--object-surface);
  }

  .tone-systems {
    --entry-accent: var(--olive);
  }

  .tone-engineering {
    --entry-accent: var(--blue);
  }

  .tone-desk {
    --entry-accent: var(--lavender);
  }

  .tone-experiment {
    --entry-accent: var(--khaki);
  }

  .tone-growth {
    --entry-accent: var(--houseplant);
  }

  .entry-meta {
    display: grid;
    align-content: start;
    gap: 0.42rem;
  }

  time {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: var(--font-size-small);
    font-weight: 800;
  }

  .entry-meta p {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .entry-meta span {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--entry-accent);
  }

  .entry-body {
    min-width: 0;
  }

  .entry-body h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 1.65vw, 1.65rem);
    line-height: 1.08;
  }

  .entry-summary {
    margin-top: 0.4rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.45;
  }

  blockquote {
    margin: 0.55rem 0;
    border-left: 0.25rem solid var(--entry-accent);
    padding-left: 0.7rem;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.52rem;
    background: color-mix(in srgb, var(--entry-accent) 12%, var(--paper));
    color: var(--color-text-muted);
    font-size: var(--font-size-micro);
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .field-entry {
      grid-template-columns: 1fr;
    }
  }
</style>
