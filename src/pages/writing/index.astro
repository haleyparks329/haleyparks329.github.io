---
import { getCollection } from "astro:content";
import WritingEditorialRow from "@/components/WritingEditorialRow.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";

const entries = (await getCollection("writing"))
  .filter((entry) => !entry.data.draft)
  .map((entry) => ({
    data: entry.data,
    href: entry.data.routePath ?? `/writing/${entry.data.slug}/`,
  }))
  .sort(
    (a, b) =>
      b.data.pubDate.getTime() - a.data.pubDate.getTime() ||
      a.data.title.localeCompare(b.data.title),
  );
---

<BaseLayout
  title="Writing"
  description="Notes, investigations, essays, and accumulated thinking from active work."
  canonicalPath="/writing/"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Writing" }]}
>
  <section class="writing-editorial">
    <PageIntro
      title="Writing"
      description="An editorial archive of accumulated thinking."
      text="Notes, investigations, essays, and technical ideas connected to the systems I am building."
      meta={[`${entries.length} published pieces`, "Newest first"]}
      accent="lavender"
      width="wide"
      density="compact"
    />

    <div class="editorial-index" aria-label="Writing, newest first">
      {entries.map((entry) => <WritingEditorialRow entry={entry} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .writing-editorial {
    width: min(var(--site-max-width), calc(100% - (var(--site-gutter) * 2)));
    margin: 0 auto var(--space-12);
  }

  .editorial-index {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
    gap: clamp(1rem, 2.4vw, 1.75rem);
    margin-top: clamp(1.75rem, 4vw, 3rem);
  }

  @media (max-width: 760px) {
    .editorial-index {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
