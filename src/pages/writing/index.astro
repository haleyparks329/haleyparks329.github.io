---
import { getCollection } from "astro:content";
import WritingEditorialRow from "@/components/WritingEditorialRow.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/PageIntro.astro";

const collectionEntries = (await getCollection("writing"))
  .filter((entry) => !entry.data.draft)
  .map((entry) => ({
    data: entry.data,
    href: `/writing/${entry.data.slug}/`,
  }));

const routeBackedEntries = [
  {
    data: {
      title: "Extending Deterministic Replay with an Investigation Layer",
      description:
        "An independent engineering exploration of how deterministic replay evidence can enter QA Agents through a configurable investigation layer, explicit policy, and human review.",
      type: "case-study" as const,
      pubDate: new Date("2026-07-16"),
      topics: ["Agent Systems", "Software Quality"],
      relatedProject: "qa-agents",
    },
    href: "/projects/qa-agents/meticulous/",
  },
];

const entries = [...collectionEntries, ...routeBackedEntries].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const projectFilters = [
  { label: "All", value: "all" },
  { label: "Career Intelligence", value: "career-intelligence" },
  { label: "QA Agents", value: "qa-agents" },
];

const typeFilters = [
  { label: "All", value: "all" },
  { label: "Case Studies", value: "case-study" },
];

const sortOptions = [
  { label: "Newest", value: "newest" },
  { label: "Oldest", value: "oldest" },
  { label: "A–Z", value: "alpha" },
  { label: "Z–A", value: "reverse-alpha" },
];
---

<BaseLayout
  title="Writing"
  description="Investigations, case studies, and ideas from active work."
  canonicalPath="/writing/"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Writing" }]}
>
  <section class="writing-editorial">
    <PageIntro
      title="Writing"
      description="Investigations, case studies, and ideas from active work."
      text="Independent explorations and technical case studies connected to the systems I am building."
      meta={[`${entries.length} published investigations`]}
      accent="lavender"
      width="wide"
    />

    <section class="browse-panel" aria-labelledby="browse-writing">
      <h2 id="browse-writing">Browse writing</h2>
      <div class="control-grid" aria-label="Writing controls">
        <div class="control-group" aria-label="Sort writing">
          <span>Sort</span>
          <div>
            {
              sortOptions.map((option, index) => (
                <button
                  type="button"
                  data-sort={option.value}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {option.label}
                </button>
              ))
            }
          </div>
        </div>

        <div class="control-group" aria-label="Filter writing by project">
          <span>Project</span>
          <div>
            {
              projectFilters.map((filter, index) => (
                <button
                  type="button"
                  data-project-filter={filter.value}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {filter.label}
                </button>
              ))
            }
          </div>
        </div>

        <div class="control-group" aria-label="Filter writing by type">
          <span>Type</span>
          <div>
            {
              typeFilters.map((filter, index) => (
                <button
                  type="button"
                  data-type-filter={filter.value}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {filter.label}
                </button>
              ))
            }
          </div>
        </div>
      </div>

      <p class="writing-status" id="writing-status" aria-live="polite">
        Showing {entries.length} pieces, sorted newest.
      </p>
    </section>

    <div class="editorial-index" data-writing-results>
      {entries.map((entry) => <WritingEditorialRow entry={entry} />)}
    </div>

    <div data-empty-state-region></div>
    <template data-empty-state-template>
      <p class="empty-state" data-empty-state>
        <strong>Nothing filed here yet.</strong>
        <span>Try another project or return to all writing.</span>
      </p>
    </template>
  </section>

  <script>
    const sortButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-sort]"),
    );
    const projectButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-project-filter]"),
    );
    const typeButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-type-filter]"),
    );
    const results = document.querySelector<HTMLElement>(
      "[data-writing-results]",
    );
    const rows = Array.from(
      document.querySelectorAll<HTMLElement>(".writing-editorial-row"),
    );
    const status = document.querySelector<HTMLElement>("#writing-status");
    const count = document.querySelector<HTMLElement>("#writing-result-count");
    const emptyStateRegion = document.querySelector<HTMLElement>(
      "[data-empty-state-region]",
    );
    const emptyStateTemplate = document.querySelector<HTMLTemplateElement>(
      "[data-empty-state-template]",
    );

    const state = {
      sort: "newest",
      project: "all",
      type: "all",
    };

    function setPressed(
      buttons: HTMLButtonElement[],
      attribute: string,
      activeValue: string,
    ) {
      buttons.forEach((button) => {
        button.setAttribute(
          "aria-pressed",
          String(button.dataset[attribute] === activeValue),
        );
      });
    }

    function sortRows(visibleRows: HTMLElement[]) {
      return visibleRows.sort((a, b) => {
        const aTitle = a.dataset.title ?? "";
        const bTitle = b.dataset.title ?? "";
        const aDate = Date.parse(a.dataset.pubDate ?? "");
        const bDate = Date.parse(b.dataset.pubDate ?? "");

        if (state.sort === "oldest") return aDate - bDate;
        if (state.sort === "alpha") return aTitle.localeCompare(bTitle);
        if (state.sort === "reverse-alpha") return bTitle.localeCompare(aTitle);
        return bDate - aDate;
      });
    }

    function setEmptyState(isEmpty: boolean) {
      if (!emptyStateRegion || !emptyStateTemplate) return;

      const existing =
        emptyStateRegion.querySelector<HTMLElement>("[data-empty-state]");
      if (isEmpty && !existing) {
        emptyStateRegion.append(emptyStateTemplate.content.cloneNode(true));
      }
      if (!isEmpty && existing) {
        existing.remove();
      }
    }

    function updateUrl() {
      const url = new URL(window.location.href);
      if (state.sort === "newest") {
        url.searchParams.delete("sort");
      } else {
        url.searchParams.set("sort", state.sort);
      }
      if (state.project === "all") {
        url.searchParams.delete("project");
      } else {
        url.searchParams.set("project", state.project);
      }
      if (state.type === "all") {
        url.searchParams.delete("type");
      } else {
        url.searchParams.set("type", state.type);
      }
      window.history.replaceState({}, "", url);
    }

    function applyWritingControls(updateHistory = true) {
      if (!results) return;

      const visibleRows = rows.filter((row) => {
        const projectMatches =
          state.project === "all" ||
          row.dataset.relatedProject === state.project;
        const typeMatches =
          state.type === "all" || row.dataset.writingType === state.type;
        return projectMatches && typeMatches;
      });

      rows.forEach((row) => {
        row.hidden = !visibleRows.includes(row);
      });
      sortRows(visibleRows).forEach((row) => results.append(row));

      setPressed(sortButtons, "sort", state.sort);
      setPressed(projectButtons, "projectFilter", state.project);
      setPressed(typeButtons, "typeFilter", state.type);

      const sortLabel =
        sortButtons.find((button) => button.dataset.sort === state.sort)
          ?.textContent ?? "Newest";
      const pieceLabel = visibleRows.length === 1 ? "piece" : "pieces";
      const investigationLabel =
        visibleRows.length === 1
          ? "published investigation"
          : "published investigations";
      const message = `Showing ${visibleRows.length} ${pieceLabel}, sorted ${sortLabel.toLowerCase()}.`;
      if (status) status.textContent = message;
      if (count) {
        count.textContent = `${visibleRows.length} ${investigationLabel}`;
      }
      setEmptyState(visibleRows.length === 0);
      if (updateHistory) updateUrl();
    }

    sortButtons.forEach((button) => {
      button.addEventListener("click", () => {
        state.sort = button.dataset.sort ?? "newest";
        applyWritingControls();
      });
    });

    projectButtons.forEach((button) => {
      button.addEventListener("click", () => {
        state.project = button.dataset.projectFilter ?? "all";
        applyWritingControls();
      });
    });

    typeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        state.type = button.dataset.typeFilter ?? "all";
        applyWritingControls();
      });
    });

    const params = new URLSearchParams(window.location.search);
    const initialSort = params.get("sort");
    const initialProject = params.get("project");
    const initialType = params.get("type");
    if (
      initialSort &&
      sortButtons.some((button) => button.dataset.sort === initialSort)
    ) {
      state.sort = initialSort;
    }
    if (
      initialProject &&
      projectButtons.some(
        (button) => button.dataset.projectFilter === initialProject,
      )
    ) {
      state.project = initialProject;
    }
    if (
      initialType &&
      typeButtons.some((button) => button.dataset.typeFilter === initialType)
    ) {
      state.type = initialType;
    }
    applyWritingControls(false);
  </script>
</BaseLayout>

<style>
  .writing-editorial {
    width: min(var(--site-max-width), calc(100% - (var(--site-gutter) * 2)));
    margin: 0 auto var(--space-12);
  }

  .published-count,
  .writing-status,
  .control-group > span {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .browse-panel {
    border-block: var(--border-width) solid var(--color-border);
    margin-top: var(--page-section-start);
    padding-block: var(--space-5);
  }

  .browse-panel h2 {
    font-size: 1rem;
  }

  .control-grid {
    display: grid;
    grid-template-columns: minmax(10rem, 0.8fr) minmax(16rem, 1.4fr) minmax(
        10rem,
        0.8fr
      );
    gap: clamp(1rem, 3vw, 2rem);
    margin-top: var(--space-4);
  }

  .control-group {
    display: grid;
    align-content: start;
    gap: var(--space-2);
  }

  .control-group div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem 0.8rem;
  }

  .control-group button {
    min-height: 44px;
    border: 0;
    border-bottom: 2px solid transparent;
    padding: 0.22rem 0;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.94rem;
    font-weight: 600;
  }

  .control-group button:hover,
  .control-group button[aria-pressed="true"] {
    border-bottom-color: var(--plum);
    color: var(--color-text);
  }

  .writing-status {
    margin-top: var(--space-4);
  }

  .editorial-index {
    margin-top: var(--space-6);
  }

  .empty-state {
    display: grid;
    gap: 0.2rem;
    border-block: var(--border-width) solid var(--color-border);
    margin-top: var(--space-6);
    padding-block: var(--space-6);
    color: var(--color-text-muted);
  }

  .empty-state strong {
    color: var(--color-text);
    font-size: var(--text-h3);
    font-weight: 600;
  }

  .empty-state span {
    max-width: 32rem;
  }

  @media (max-width: 860px) {
    .control-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
