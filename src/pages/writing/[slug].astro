---
import { getCollection, render } from "astro:content";
import ContinueExploring from "@/components/ContinueExploring.astro";
import ExternalLink from "@/components/ExternalLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import WritingDocumentHeader from "@/components/WritingDocumentHeader.astro";
import {
  destinationByHref,
  destinationsForProject,
  destinationToContentLink,
  relatedLinksForHrefs,
  trailsForHref,
} from "@/data/navigation";

export async function getStaticPaths() {
  const entries = (await getCollection("writing")).filter(
    (entry) => !entry.data.draft,
  );

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const relatedLinks = [
  entry.data.subjectUrl
    ? {
        href: entry.data.subjectUrl,
        label: `Visit ${entry.data.subjectName ?? "subject"}`,
        external: true,
      }
    : undefined,
  entry.data.repositoryUrl
    ? {
        href: entry.data.repositoryUrl,
        label: "View repository",
        external: true,
      }
    : undefined,
  entry.data.demoUrl
    ? {
        href: entry.data.demoUrl,
        label: "Open related demo",
        external: entry.data.demoUrl.startsWith("http"),
      }
    : undefined,
  entry.data.externalUrl
    ? {
        href: entry.data.externalUrl,
        label: "Open external reference",
        external: true,
      }
    : undefined,
].filter((link): link is { href: string; label: string; external: boolean } =>
  Boolean(link),
);

const pageHref = `/writing/${entry.data.slug}/`;
const pageDestination = destinationByHref(pageHref);
const continueLinks = relatedLinksForHrefs(
  entry.data.related,
  pageDestination?.id,
);
const associatedProject = entry.data.relatedProject
  ? destinationsForProject(entry.data.relatedProject).find(
      (destination) => destination.type === "project",
    )
  : undefined;
const associatedProjectLink = associatedProject
  ? destinationToContentLink(associatedProject)
  : undefined;
const readingLinks = continueLinks.filter(
  (link) =>
    link.type === "Writing" && link.href !== associatedProjectLink?.href,
);
const connectedLinks = continueLinks.filter(
  (link) =>
    link.type !== "Writing" && link.href !== associatedProjectLink?.href,
);
const trailMembership = trailsForHref(pageHref);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/writing/${entry.data.slug}/`}
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Writing", href: "/writing/" },
    { label: entry.data.title },
  ]}
>
  <article
    class="writing-document"
    data-writing-type={entry.data.type}
    data-tags={entry.data.tags.join(" ")}
    data-related-project={entry.data.relatedProject ?? ""}
  >
    <WritingDocumentHeader entry={entry} />
    <div class="document-body">
      <Content />
    </div>
    {
      trailMembership.length > 0 && (
        <aside class="trail-context" aria-label="Trail membership">
          <p>
            Appears in{" "}
            {trailMembership.map((trail, index) => (
              <>
                <a href={`/explore/trails/${trail.slug}/`}>{trail.label}</a>
                {index < trailMembership.length - 1 ? ", " : ""}
              </>
            ))}
            .
          </p>
        </aside>
      )
    }
    {
      associatedProjectLink && (
        <ContinueExploring
          title="Built Alongside"
          links={[associatedProjectLink]}
        />
      )
    }
    <ContinueExploring title="Continue Reading" links={readingLinks} />
    <ContinueExploring title="Related Work" links={connectedLinks} />
    {
      relatedLinks.length > 0 && (
        <section class="source-links" aria-labelledby="source-links">
          <h2 id="source-links">Source links</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li>
                {link.external ? (
                  <ExternalLink href={link.href} label={link.label} />
                ) : (
                  <a href={link.href}>{link.label}</a>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
    <p class="back-link">
      <a href="/writing/">Return to Writing</a>
    </p>
  </article>
</BaseLayout>

<style>
  .writing-document {
    width: min(var(--site-max-width), calc(100% - (var(--site-gutter) * 2)));
    margin-inline: auto;
  }

  .document-body {
    max-width: var(--reading-measure);
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .document-body :global(h2) {
    margin-top: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--space-3);
    border-top: var(--border-width) solid var(--color-border);
    padding-top: clamp(1.2rem, 3vw, 1.8rem);
    font-size: var(--text-h2);
    line-height: 1.08;
  }

  .document-body :global(h2:first-child) {
    margin-top: 0;
    border-top: 0;
    padding-top: 0;
  }

  .document-body :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    font-size: clamp(1.12rem, 1.5vw, 1.35rem);
    line-height: 1.15;
  }

  .document-body :global(p),
  .document-body :global(li) {
    color: var(--color-text-muted);
    font-size: clamp(0.98rem, 1vw, 1.05rem);
    line-height: 1.65;
  }

  .document-body :global(p),
  .document-body :global(ul),
  .document-body :global(ol) {
    margin-bottom: var(--space-4);
  }

  .document-body :global(ul),
  .document-body :global(ol) {
    padding-left: 1.25rem;
  }

  .document-body :global(strong) {
    color: var(--color-text);
  }

  .document-body :global(a),
  .source-links :global(a),
  .back-link a {
    color: var(--plum);
    font-weight: 600;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .document-body :global(summary:focus-visible) {
    outline: 3px solid var(--color-focus);
    outline-offset: 4px;
  }

  .document-body :global(.exploration-kicker),
  .document-body :global(.card-label) {
    margin-bottom: var(--space-2);
    color: var(--plum);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .document-body :global(.exploration-summary),
  .document-body :global(.status-panel),
  .document-body :global(.replay-card),
  .document-body :global(.implementation-panel) {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: clamp(1rem, 3vw, 1.4rem);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-soft);
  }

  .document-body :global(.exploration-summary),
  .document-body :global(.status-panel) {
    margin-block: clamp(1.5rem, 4vw, 2.5rem);
  }

  .document-body :global(.exploration-summary summary) {
    cursor: pointer;
    color: var(--color-text);
    font-weight: 600;
  }

  .document-body :global(.exploration-summary h2),
  .document-body :global(.status-panel h2),
  .document-body :global(.replay-card h2) {
    margin-top: var(--space-5);
    border-top: 0;
    padding-top: 0;
  }

  .document-body :global(.status-panel h2),
  .document-body :global(.replay-card h2) {
    margin-top: 0;
  }

  .document-body :global(.status-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .document-body :global(.status-grid > div) {
    border-left: 0.25rem solid var(--houseplant);
    padding-left: var(--space-4);
  }

  .document-body :global(.status-grid > div + div) {
    border-left-color: var(--khaki);
  }

  .document-body :global(.exploration-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }

  .document-body :global(.button-link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    border: var(--border-width) solid var(--accent-primary-border-strong);
    border-radius: var(--radius-md);
    padding: 0.62rem 0.86rem;
    background: var(--plum);
    color: var(--color-canvas);
    font-size: var(--font-size-small);
    font-weight: 600;
    text-decoration: none;
  }

  .document-body :global(.button-link:hover) {
    border-color: var(--houseplant);
    background: var(--houseplant);
    color: var(--color-canvas);
  }

  .document-body :global(.button-secondary) {
    background: transparent;
    color: var(--plum);
  }

  .document-body :global(.button-secondary:hover) {
    background: var(--color-tint);
    color: var(--plum);
  }

  .document-body :global(.replay-card) {
    margin-block: clamp(2rem, 5vw, 3rem);
    border-color: var(--accent-tertiary-border);
    background:
      linear-gradient(
        135deg,
        rgba(207, 231, 246, 0.44),
        rgba(248, 240, 231, 0.9)
      ),
      var(--color-surface-raised);
  }

  .document-body :global(.replay-metric) {
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: clamp(0.92rem, 1vw, 1rem);
    font-weight: 600;
  }

  .document-body :global(.implementation-panel) {
    margin-top: var(--space-4);
  }

  .document-body :global(pre) {
    overflow-x: auto;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    background: var(--color-code-surface);
    color: var(--color-text);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .source-links {
    margin-top: clamp(2.5rem, 5vw, 4.5rem);
    border-top: var(--border-width) solid var(--color-border);
    padding-top: var(--space-5);
  }

  .source-links h2 {
    margin-bottom: var(--space-3);
    font-size: var(--text-h3);
  }

  .trail-context {
    max-width: var(--reading-measure);
    border-top: var(--border-width) solid var(--color-border);
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-top: var(--space-4);
  }

  .trail-context p {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-micro);
    font-weight: 600;
    text-transform: uppercase;
  }

  .trail-context a {
    color: var(--plum);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .back-link {
    max-width: var(--reading-measure);
    border-top: var(--border-width) solid var(--color-border);
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-top: var(--space-5);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  @media (max-width: 680px) {
    .document-body :global(.status-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
