---
import { getCollection, render } from "astro:content";
import ContinueExploring from "@/components/ContinueExploring.astro";
import ExternalLink from "@/components/ExternalLink.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import WritingDocumentHeader from "@/components/WritingDocumentHeader.astro";
import { typeLabel } from "@/data/navigation";

export async function getStaticPaths() {
  const entries = (await getCollection("writing")).filter(
    (entry) => !entry.data.draft,
  );

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const projects = await getCollection("projects");
const fieldLog = await getCollection("fieldLog");
const writing = (await getCollection("writing")).filter(
  (item) => !item.data.draft,
);

const relatedLinks = [
  entry.data.subjectUrl
    ? {
        href: entry.data.subjectUrl,
        label: `Visit ${entry.data.subjectName ?? "subject"}`,
        external: true,
      }
    : undefined,
  entry.data.repositoryUrl
    ? {
        href: entry.data.repositoryUrl,
        label: "View repository",
        external: true,
      }
    : undefined,
  entry.data.demoUrl
    ? {
        href: entry.data.demoUrl,
        label: "Open related demo",
        external: entry.data.demoUrl.startsWith("http"),
      }
    : undefined,
  entry.data.externalUrl
    ? {
        href: entry.data.externalUrl,
        label: "Open external reference",
        external: true,
      }
    : undefined,
].filter((link): link is { href: string; label: string; external: boolean } =>
  Boolean(link),
);

function linkForHref(href: string) {
  const project = projects.find(
    (item) => `/projects/${item.data.slug}/` === href,
  );
  if (project) {
    return {
      href,
      label: project.data.title,
      type: "Case Study",
      summary: project.data.summary,
      topics: project.data.topics,
    };
  }

  const logEntry = fieldLog.find(
    (item) => `/field-log/${item.data.slug}/` === href,
  );
  if (logEntry) {
    return {
      href,
      label: logEntry.data.title,
      type: "Build Log",
      summary: logEntry.data.summary,
      topics: logEntry.data.topics,
    };
  }

  const writingEntry = writing.find(
    (item) => `/writing/${item.data.slug}/` === href,
  );
  if (writingEntry) {
    return {
      href,
      label: writingEntry.data.title,
      type: typeLabel(writingEntry.data.type),
      summary: writingEntry.data.description,
      topics: writingEntry.data.topics,
    };
  }

  if (href === "/explore/") {
    return {
      href,
      label: "Explore",
      type: "Explore",
      summary: "Browse the site by topic, type, current work, or surprise.",
      topics: ["Navigation"],
    };
  }

  if (href === "/compost-heap/") {
    return {
      href,
      label: "The Compost Heap",
      type: "Archive",
      summary: "Loose fragments and odd notes from the edge of the work.",
      topics: ["Adaptive UI"],
    };
  }

  return undefined;
}

const continueLinks = entry.data.related
  .map(linkForHref)
  .filter((link): link is NonNullable<ReturnType<typeof linkForHref>> =>
    Boolean(link),
  );
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/writing/${entry.data.slug}/`}
>
  <article
    class="writing-document"
    data-writing-type={entry.data.type}
    data-tags={entry.data.tags.join(" ")}
    data-related-project={entry.data.relatedProject ?? ""}
  >
    <WritingDocumentHeader entry={entry} />
    <div class="document-body">
      <Content />
    </div>
    {
      relatedLinks.length > 0 && (
        <section class="related-links" aria-labelledby="related-links">
          <h2 id="related-links">Related links</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li>
                {link.external ? (
                  <ExternalLink href={link.href} label={link.label} />
                ) : (
                  <a href={link.href}>{link.label}</a>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
    <ContinueExploring links={continueLinks} />
    <p class="back-link">
      <a href="/writing/">Return to Writing</a>
    </p>
  </article>
</BaseLayout>

<style>
  .writing-document {
    width: min(760px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .document-body {
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .document-body :global(h2) {
    margin-top: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--space-3);
    border-top: var(--border-width) solid var(--color-border);
    padding-top: clamp(1.2rem, 3vw, 1.8rem);
    font-size: clamp(1.45rem, 2.2vw, 2rem);
    line-height: 1.08;
  }

  .document-body :global(h2:first-child) {
    margin-top: 0;
    border-top: 0;
    padding-top: 0;
  }

  .document-body :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    font-size: clamp(1.12rem, 1.5vw, 1.35rem);
    line-height: 1.15;
  }

  .document-body :global(p),
  .document-body :global(li) {
    color: var(--color-text-muted);
    font-size: clamp(0.98rem, 1vw, 1.05rem);
    line-height: 1.65;
  }

  .document-body :global(p),
  .document-body :global(ul),
  .document-body :global(ol) {
    margin-bottom: var(--space-4);
  }

  .document-body :global(ul),
  .document-body :global(ol) {
    padding-left: 1.25rem;
  }

  .document-body :global(strong) {
    color: var(--color-text);
  }

  .document-body :global(a),
  .related-links :global(a),
  .back-link a {
    color: var(--plum);
    font-weight: 850;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .related-links {
    margin-top: clamp(2.5rem, 5vw, 4.5rem);
    border-top: var(--border-width) solid var(--color-border);
    padding-top: var(--space-5);
  }

  .related-links h2 {
    margin-bottom: var(--space-3);
    font-size: clamp(1.25rem, 1.8vw, 1.55rem);
  }

  .back-link {
    border-top: var(--border-width) solid var(--color-border);
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-top: var(--space-5);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }
</style>
